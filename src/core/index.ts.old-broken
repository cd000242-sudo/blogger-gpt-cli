  margin-bottom: 20px !important;
  font-weight: 700 !important;
}

/* 핵심요약표 */
.summary-table {
  margin-top: 40px;
  padding-top: 40px;
  border-top: 3px solid rgba(116, 185, 255, 0.15);
}

.summary-table h3 {
  font-size: 1.5rem;
  margin-bottom: 30px;
  background: linear-gradient(135deg, #74b9ff 0%, #a29bfe 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 700;
  text-align: center;
}

/* 요약 그리드 */
.summary-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 25px;
  background: transparent;
}

/* 요약 아이템 */
.summary-item {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(116, 185, 255, 0.15) 100%) !important;
  backdrop-filter: blur(10px);
  border: 3px solid rgba(255, 255, 255, 0.9) !important;
  border-radius: 20px !important;
  padding: 30px !important;
  min-height: auto !important;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  box-shadow: 0 8px 25px rgba(116, 185, 255, 0.15) !important;
}

.summary-item:hover {
  transform: translateY(-12px) rotate(1deg);
  box-shadow: 0 25px 55px rgba(116, 185, 255, 0.3) !important;
  background: linear-gradient(135deg, rgba(255, 255, 255, 1) 0%, rgba(116, 185, 255, 0.25) 100%) !important;
  border-color: #74b9ff !important;
}

/* 요약 아이템 제목 */
.summary-item-title {
  font-weight: 700 !important;
  background: linear-gradient(135deg, #74b9ff 0%, #a29bfe 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 15px !important;
  font-size: 1.25rem !important;
  color: transparent !important;
}

/* 요약 아이템 내용 */
.summary-item-content {
  color: var(--text-muted) !important;
  margin-bottom: 20px !important;
  line-height: 1.8;
  font-size: 0.98rem !important;
}

/* 요약 아이템 링크 */
.summary-item-link {
  display: inline-flex !important;
  align-items: center;
  padding: 10px 20px;
  background: linear-gradient(135deg, #74b9ff 0%, #a29bfe 100%) !important;
  color: white !important;
  text-decoration: none !important;
  font-size: 0.9rem !important;
