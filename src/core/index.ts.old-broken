import OpenAI from 'openai';
import { GoogleGenerativeAI } from '@google/generative-ai';
import { buildContentPrompt } from './prompt';
import { CompetitorAnalyzer } from './competitor-analyzer';
import { ContentQualityScorer } from './content-quality-scorer';
import { SmartKeywordGenerator } from './smart-keyword-generator';
import { ContentVariationGenerator } from './content-variation-generator';

/* ---------------------------------------------
 * AI 모델 폴백 시스템
 * --------------------------------------------- */
async function getAvailableGeminiModel(genAI: any, context: string = 'AI'): Promise<any> {
  const availableModels = [
    'gemini-2.0-flash-exp',
    'gemini-1.0-pro'
  ];
  
  for (const modelName of availableModels) {
    try {
      const model = genAI.getGenerativeModel({ model: modelName });
      console.log(`✅ ${context} 모델 선택: ${modelName}`);
      return { model, modelName };
    } catch (error) {
      console.log(`⚠️ ${modelName} 모델 사용 불가, 다음 모델 시도 중...`);
      continue;
    }
  }
  
  throw new Error('사용 가능한 AI 모델이 없습니다. API 키를 확인해주세요.');
}

/* ---------------------------------------------
 * 유틸: 모델이 전체 HTML을 내놔도 fragment만 추출
 * --------------------------------------------- */
function stripToFragment(s: string): string {
  if (!s) return '';
  const txt = String(s).trim();

  // 1) 우리가 요구한 스타일/랩퍼가 함께 온 경우 그대로 추출
  const style = txt.match(/<style[\s\S]*?<\/style>/i);
  const wrap  = txt.match(/<div[^>]*class=["'][^"']*\bwrap\b[^"']*["'][\s\S]*?<\/div>/i);
  if (style && wrap) return `${style[0]}\n${wrap[0]}`;

  // 2) body 안쪽만 존재하면 body만 추출
  const body = txt.match(/<body[^>]*>([\s\S]*?)<\/body>/i);
  if (body && body[1]) return body[1].trim();

  // 3) section이나 main 같은 컨테이너가 있으면 우선 추출
  const container = txt.match(/<(main|section)[^>]*>[\s\S]*?<\/\1>/i);
  if (container) return container[0].trim();

  // 4) 그냥 통째로 반환
  return txt;
}

/* ---------------------------------------------
 * 타입
 * --------------------------------------------- */
export type Provider = 'openai' | 'gemini';

export type GenInput = {
  topic: string;
  keywords: string | string[];
  minChars?: number;
  model?: string;
};

// RunOnePostPayload 타입은 아래에서 interface로 정의됨

/* ---------------------------------------------
 * OpenAI
 * --------------------------------------------- */
export async function generateWithOpenAI(opts: {
  apiKey: string;
  topic: string;
  keywords: string | string[];
  minChars?: number;
  model?: string;
}) {
  const keywordsCSV = Array.isArray(opts.keywords)
    ? opts.keywords.join(', ')
    : (opts.keywords ?? '');

  const prompt = buildContentPrompt({
    topic: opts.topic,
    keywordsCSV,
    minChars: opts.minChars ?? 3000,
  });

  const client = new OpenAI({ apiKey: opts.apiKey });
  const model  = opts.model || 'gpt-4o-mini';

  const res = await client.chat.completions.create({
    model,
    temperature: 0.7,
    max_tokens: 6000, // 긴 본문 대응
    messages: [
      {
        role: 'system',
        content:
          '너는 한국어 SEO 전문 에디터다. 지침을 엄격히 준수하고, 외부 리소스 없이 HTML fragment만 출력한다.',
      },
      { role: 'user', content: prompt },
    ],
  });

  const text = (res.choices?.[0]?.message?.content || '').toString();
  return stripToFragment(text);
}

/* ---------------------------------------------
 * Gemini
 * --------------------------------------------- */
// src/core/index.ts 내 기존 generateWithGemini를 이 버전으로 교체
export async function generateWithGemini(opts: {
  apiKey: string;
  topic: string;
  keywords: string | string[];
  minChars?: number;
  model?: string;
}) {
  const { GoogleGenerativeAI } = await import('@google/generative-ai');

  const min = opts.minChars ?? 10000; // 길게 쓰고 싶으면 UI에서도 높게
  const sessions = 7;
  const perTarget = Math.max(1600, Math.floor(min / sessions)); // 회차당 목표(공백 제외)

  const keywordsCSV = Array.isArray(opts.keywords) ? opts.keywords.join(', ') : (opts.keywords ?? '');

  // 🚀 차별화된 기발한 기능들 초기화
  const competitorAnalyzer = new CompetitorAnalyzer();
  const qualityScorer = new ContentQualityScorer();
  const keywordGenerator = new SmartKeywordGenerator();
  const variationGenerator = new ContentVariationGenerator();

  // 1. 경쟁사 분석
  console.log('🔍 경쟁사 분석 중...');
  const competitorAnalysis = await competitorAnalyzer.analyzeCompetitors(opts.topic, Array.isArray(opts.keywords) ? opts.keywords : [opts.keywords || '']);

  // 2. 스마트 키워드 생성
  console.log('🎯 스마트 키워드 생성 중...');
  const keywordStrategy = await keywordGenerator.generateSmartKeywords(opts.topic, Array.isArray(opts.keywords) ? opts.keywords : [opts.keywords || '']);

  // 3. 콘텐츠 변형 생성
  console.log('🔄 콘텐츠 변형 생성 중...');
  const variationStrategy = variationGenerator.generateVariations(opts.topic, Array.isArray(opts.keywords) ? opts.keywords : [opts.keywords || '']);


  // 5. 향상된 프롬프트 생성
  const enhancedPrompt = buildContentPrompt({ 
    topic: opts.topic, 
    keywordsCSV: keywordStrategy.combinations[0].primary + ', ' + keywordsCSV, 
    minChars: min 
  });

  const genAI = new GoogleGenerativeAI(opts.apiKey);
  
  // 사용 가능한 모델 목록 (우선순위 순)
  const availableModels = [
    'gemini-2.0-flash-exp',
    'gemini-1.0-pro'
  ];
  
  let model;
  let selectedModel = opts.model || 'gemini-2.0-flash-exp';
  
  // 모델 테스트 및 폴백
  const modelInfo = await getAvailableGeminiModel(genAI, '메인 콘텐츠 생성');
  model = genAI.getGenerativeModel({
    model: modelInfo.modelName,
    systemInstruction: enhancedPrompt,
  });

  // 유틸
  const visibleLen = (html: string) =>
    html.replace(/<style[\s\S]*?<\/style>/gi, '').replace(/<[^>]+>/g, '').replace(/\s+/g, '').length;
  const strip = (s: string) => {
    const style = s.match(/<style[\s\S]*?<\/style>/i);
    const wrap  = s.match(/<div[^>]*class=["'][^"']*\bwrap\b[^"']*["'][\s\S]*?<\/div>/i);
    if (style && wrap) return `${style[0]}\n${wrap[0]}`;
    return s.trim();
  };

  const ask = async (text: string, max = 12000) => {
    const r = await model.generateContent({
      contents: [{ role: 'user', parts: [{ text }] }],
      generationConfig: { temperature: 0.7, topP: 0.95, maxOutputTokens: max },
    });
    return r.response.text().trim();
  };

  // 1) 회차별 생성
  const parts: string[] = [];
  let baseStyle = '';

  for (let i = 1; i <= sessions; i++) {
    // 회차 전용 프롬프트
    const p = `
**${i}/${sessions}회차 애드센스 승인용 독창적 콘텐츠 작성**

[주제] ${opts.topic}
[키워드] ${keywordsCSV}
[목표] 공백 제외 ${perTarget}자 이상 (부족하면 확장)

[독창적 콘텐츠 작성법]
1. **완전히 새로운 접근**: 기존 글들과 1%도 유사하지 않은 독창적 접근법
2. **고유한 스토리텔링**: 매력적이고 독특한 스토리로 독자의 관심을 끌기
3. **차별화된 인사이트**: 다른 글에서 찾을 수 없는 독특하고 깊이 있는 통찰력
4. **혁신적 구조**: 표준적이지 않은 독창적이고 창의적인 콘텐츠 구성
5. **특별한 가치**: 독자에게 다른 글에서는 얻을 수 없는 특별한 가치와 정보

[애드센스 친화적 요소]
- **검증된 데이터**: 공식 기관, 정부기관, 공인된 기관의 신뢰할 수 있는 정보
- **실용적 가이드**: 독자가 바로 적용할 수 있는 구체적이고 실용적인 정보
- **전문적 분석**: 해당 분야에 대한 깊이 있는 지식과 전문성을 보여주는 내용
- **시각적 요소**: 표, 체크리스트, 인포그래픽으로 복잡한 정보를 구조화
- **스토리텔링**: 독자의 관심을 끌 수 있는 매력적인 스토리와 사례

[절대 금지사항]
- **Q&A 형식 사용 금지**: 질문과 답변 형식은 절대 사용하지 않음
- **템플릿식 구조 금지**: 표준적이거나 뻔한 구조 사용 금지
- **중복된 내용 금지**: 같은 내용을 반복하거나 유사한 표현 사용 금지
- **일반적인 표현 금지**: "몇 가지 핵심 주의사항이 있어요" 등 뻔한 표현 사용 금지
- **동일한 답변 금지**: 다른 주제라도 같은 답변을 제공하는 것 절대 금지
- **추측성 표현 금지**: "~일 것 같습니다", "~라고 합니다" 등 불확실한 표현 금지
- **검증되지 않은 데이터 금지**: 확실하지 않은 통계나 수치 사용 금지

[작성 요구사항]
- "문제제기/공감/해결책/이점/행동유도" 상위 제목은 숨김 처리
- 검증된 사실과 공식 절차만을 정확하게 설명
- 데이터/규정/용어는 정확히, 군더더기/중복 금지
- 요약/한줄정리/핵심정리, 프롬프트/지침 언급 금지
- <div class="wrap"> 내부에 바로 붙일 HTML 조각만 출력
- 중복문서, 유사문서, 특색없는 글에 절대 걸리지 않는 독창적이고 고유한 콘텐츠로 작성
`.trim();

    let piece = await ask(p, 12000);
    piece = strip(piece);

    // 스타일이 붙어온다면 첫 회차에서만 회수
    if (i === 1) {
      const st = piece.match(/<style[\s\S]*?<\/style>/i);
      if (st) {
        baseStyle = st[0];
        piece = piece.replace(st[0], '').trim();
      }
    }

    // 길이 미달 시 1~2회 확장
    let guard = 2;
    while (visibleLen(piece) < perTarget && guard-- > 0) {
      const need = Math.max(500, perTarget - visibleLen(piece));
      const extendPrompt = `
아래 회차 본문을 **애드센스 승인용 독창적 콘텐츠**로 **${need}자 이상** 더 자세히 확장하세요.

[독창적 확장 기법]
1. **완전히 새로운 정보 추가**: 기존 글들과 1%도 유사하지 않은 완전히 새로운 정보
2. **고유한 스토리텔링**: 매력적이고 독특한 스토리와 사례 추가
3. **차별화된 인사이트**: 다른 글에서 찾을 수 없는 독특하고 깊이 있는 통찰력
4. **혁신적 구조**: 표준적이지 않은 독창적이고 창의적인 콘텐츠 구성
5. **특별한 가치**: 독자에게 다른 글에서는 얻을 수 없는 특별한 가치와 정보

[애드센스 친화적 확장]
- **검증된 데이터**: 공식 기관, 정부기관, 공인된 기관의 신뢰할 수 있는 정보
- **실용적 가이드**: 독자가 바로 적용할 수 있는 구체적이고 실용적인 정보
- **전문적 분석**: 해당 분야에 대한 깊이 있는 지식과 전문성을 보여주는 내용
- **시각적 요소**: 표, 체크리스트, 인포그래픽으로 복잡한 정보를 구조화
- **스토리텔링**: 독자의 관심을 끌 수 있는 매력적인 스토리와 사례

[절대 금지사항]
- **Q&A 형식 사용 금지**: 질문과 답변 형식은 절대 사용하지 않음
- **템플릿식 구조 금지**: 표준적이거나 뻔한 구조 사용 금지
- **중복된 내용 금지**: 같은 내용을 반복하거나 유사한 표현 사용 금지
- **일반적인 표현 금지**: "몇 가지 핵심 주의사항이 있어요" 등 뻔한 표현 사용 금지
- **동일한 답변 금지**: 다른 주제라도 같은 답변을 제공하는 것 절대 금지
- **추측성 표현 금지**: "~일 것 같습니다", "~라고 합니다" 등 불확실한 표현 금지
- **검증되지 않은 데이터 금지**: 확실하지 않은 통계나 수치 사용 금지

[확장 요구사항]
- 새 소제목/사례/절차/표 추가
- 요약/한줄정리 금지
- wrap/style 없이 **본문 조각만** 출력
- 기존 톤과 일관성 유지
- 중복문서, 유사문서, 특색없는 글에 절대 걸리지 않는 독창적이고 고유한 콘텐츠로 확장

[현재 회차 본문]
${piece}
`.trim();
      const more = strip(await ask(extendPrompt, 8000));
      piece += `\n${more}`;
    }

    // 1회차 맨 위에 버튼형 목차와 CTA 생성
    if (i === 1) {
      const toc = `
<nav class="toc">
  <a href="#s1">1회차</a><a href="#s2">2회차</a><a href="#s3">3회차</a>
  <a href="#s4">4회차</a><a href="#s5">5회차</a><a href="#s6">6회차</a><a href="#s7">7회차</a>
</nav>
`.trim();
      
      const ctaSection = `
<div class="cta-section">
  <h3>지금 바로 시작하세요!</h3>
  <p>확실한 정보를 바탕으로 안전하게 진행하세요. 아래 단계별 가이드를 따라하시면 됩니다.</p>
  <a href="#s1" class="cta-button">바로 시작하기</a>
</div>
`.trim();
      
      piece = `${toc}\n${ctaSection}\n<section id="s${i}">\n${piece}\n</section>`;
    } else {
      piece = `<section id="s${i}">\n${piece}\n</section>`;
    }

    parts.push(piece);
  }

  // 2) 태그 10개 생성
  const tagsPrompt = `
주제 "${opts.topic}"와 키워드 "${keywordsCSV}"를 반영해,
검색 의도를 넓히는 **프리미엄 연관 태그 10개**를 만들어라.

[전문성 기반 태그 생성]
1. **SEO 최적화**: 검색 엔진에서 높은 순위를 차지할 수 있는 키워드
2. **다양성**: 주제의 다양한 측면을 다루는 태그 (기술적, 실용적, 트렌드)
3. **검색 친화적**: 실제 검색자가 사용할 만한 자연스러운 키워드
4. **계층적**: 상위 개념부터 세부 개념까지 포함 (브로드 → 롱테일)
5. **트렌드 반영**: 최신 트렌드와 관련된 키워드 포함
6. **실용성**: 독자가 관심을 가질 만한 실용적 키워드
7. **전문성**: 해당 분야의 전문 용어와 기술적 키워드 포함

[태그 품질 기준]
- 검색량이 높으면서 경쟁도가 적당한 키워드 우선
- 브랜드 키워드와 제품명보다는 일반적이고 지속적인 키워드
- 지역성이나 시기적 특성이 강한 키워드는 제외
- 독자가 실제로 검색할 만한 의도가 명확한 키워드

[태그 요구사항]
- 해시태그(#) 쓰지 말고 평문 라벨
- 오직 이 형식만 출력: <ul class="tags"><li>...</li> ... </ul>
`.trim();
  let tags = strip(await ask(tagsPrompt, 1024));
  if (!/^<ul class="tags">/i.test(tags)) {
    const list = ['가이드','절차','체크리스트','주의사항','비용','신청방법','서류','기간','사례','FAQ']
      .map(t => `<li>${t}</li>`).join('');
    tags = `<ul class="tags">${list}</ul>`;
  }

  // 3) 최종 HTML 조립
  const styleSafe = baseStyle || `<style>
  .wrap{max-width:920px;margin:24px auto;padding:8px 12px}
  .toc{display:flex;gap:8px;flex-wrap:wrap;margin:10px 0}
  .toc a{padding:8px 12px;border:1px solid #1f2937;border-radius:999px;text-decoration:none}
  .tags{display:flex;flex-wrap:wrap;gap:8px;padding:0;margin:18px 0}
  .tags li{list-style:none;padding:6px 10px;border:1px solid #1f2937;border-radius:999px}
</style>`;

  const html = `${styleSafe}
<div class="wrap">
${parts.join('\n\n')}
${tags}
</div>`.trim();

  // 6. 콘텐츠 품질 점수 분석
  console.log('📊 콘텐츠 품질 점수 분석 중...');
  const qualityAnalysis = qualityScorer.analyzeContent(html, opts.topic, Array.isArray(opts.keywords) ? opts.keywords : [opts.keywords || '']);

  // 7. 분석 결과 로깅
  console.log('🎯 콘텐츠 품질 점수:', qualityAnalysis.score);
  console.log('✅ 강점:', qualityAnalysis.strengths.join(', '));
  console.log('⚠️ 개선점:', qualityAnalysis.weaknesses.join(', '));
  console.log('💡 추천사항:', qualityAnalysis.recommendations.join(', '));
  console.log('🚨 애드센스 위험요소:', qualityAnalysis.adsenseRisk.join(', '));

  // 8. 경쟁사 분석 결과 로깅
  console.log('🔍 경쟁사 분석 결과:');
  console.log('- 차별화 전략:', competitorAnalysis.differentiationStrategy.join(', '));
  console.log('- 추천 접근법:', competitorAnalysis.recommendedApproach);
  console.log('- 독창성 점수:', competitorAnalysis.uniquenessScore + '/100');

  // 9. 스마트 키워드 결과 로깅
  console.log('🎯 스마트 키워드 결과:');
  console.log('- 추천 키워드:', keywordStrategy.combinations[0].primary);
  console.log('- 롱테일 키워드:', keywordStrategy.combinations[0].longTail.join(', '));
  console.log('- 경쟁도:', keywordStrategy.combinations[0].competition);
  console.log('- 독창성:', keywordStrategy.combinations[0].uniqueness + '/100');


  return html;
}

// ─────────────────────────────────────────────────────────────
// 플랫폼별 콘텐츠 생성 함수들
// ─────────────────────────────────────────────────────────────

// WordPress 전용 콘텐츠 생성
export async function generateWordPressContent(opts: {
  topic: string;
  keywords: string[];
  minChars: number;
  geminiKey: string;
  categories: string[];
  tags: string[];
}) {
  const { topic, keywords, minChars, geminiKey, categories, tags } = opts;
  
  const wpPrompt = `
            당신은 WordPress 전문 콘텐츠 크리에이터입니다.
            
            주제: ${topic}
            키워드: ${keywords.join(', ')}
            카테고리: ${categories.join(', ')}
            태그: ${tags.join(', ')}
            최소 글자수: ${minChars}자
            
            WordPress 전용 콘텐츠 가이드라인:
            
            🎨 WordPress 색상 설정 (반드시 적용):
            - 소제목: border-left: 4px solid #10b981 (파s텔 그린)
            - 본문 카드: background: linear-gradient(135deg, #f3e8ff 0%, #fae8ff 100%); border-left: 4px solid #c084fc (파s텔 보라)
            
            🎯 제목 작성 규칙:
            - 공식적이고 딱딱한 제목 절대 금지 (예: "신청 방법 및 절차", "가이드", "방법론")
            - 자연스럽고 매력적인 제목 작성 (예: "이거 진짜 좋아요", "완전 추천", "솔직한 후기")
            - 개인적 경험담 느낌의 제목 (예: "제가 직접 해봤는데", "실제로는 이렇게")
            - 과도한 키워드 나열 금지
            - 친근하고 구어체 느낌의 제목 선호
            
            📝 WordPress 콘텐츠 품질 기준:
            - 전문적이고 신뢰할 수 있는 톤 (Blogger보다 더 formal)
            - 깊이 있는 분석과 인사이트 제공
            - 실무진을 위한 구체적이고 실행 가능한 정보
            - 데이터와 통계 기반의 근거 있는 내용
            - WordPress 사용자들의 니즈에 맞는 실용적 가이드

🏗️ 본문 구조:
- 소제목 6개 이상 (분석형, 가이드형, 비교형 혼합)
- 각 섹션마다 구체적 수치와 실행 팁 포함
- 전문적인 체크리스트 및 비교표 활용
- 단계별 가이드와 베스트 프랙티스 포함
- WordPress 플러그인이나 테마 관련 정보 포함

💡 WordPress 특화 요소:
- WordPress 관리자 관점에서의 실용적 조언
- 플러그인 추천 및 설정 가이드
- 테마 커스터마이징 팁
- 성능 최적화 관련 정보
- 보안 및 백업 관련 조언

🚫 금지사항:
- 과도한 마케팅성 표현
- 개인적 경험담 위주의 내용 (Blogger와 차별화)
- 단순한 정보 나열
- WordPress와 무관한 일반적 내용

출력 형식 (JSON):
{
  "title": "WordPress SEO 최적화된 전문 제목",
  "metaDescription": "WordPress 사용자를 위한 메타 설명 (160자 이내)",
  "html": "WordPress 전용 완성된 HTML 콘텐츠",
  "featuredImageAlt": "WordPress 관련 대표 이미지 alt 텍스트",
  "internalLinks": ["WordPress 관련 글 제목들"],
  "socialShareText": "WordPress 커뮤니티 공유용 텍스트"
}
`;

  try {
    const { GoogleGenerativeAI } = await import('@google/generative-ai');
    const genAI = new GoogleGenerativeAI(geminiKey);
    
    // 폴백 시스템 적용
    const modelInfo = await getAvailableGeminiModel(genAI, 'WordPress 콘텐츠 생성');
    const model = modelInfo.model;

    const result = await model.generateContent(wpPrompt);
    const response = await result.response;
    const text = response.text();
    
    // JSON 파싱
    const jsonMatch = text.match(/\{[\s\S]*\}/);
    if (jsonMatch) {
      const parsed = JSON.parse(jsonMatch[0]);
      return {
        title: parsed.title || topic,
        html: parsed.html || `<h1>${topic}</h1><p>WordPress 콘텐츠 생성 중...</p>`,
        metaDescription: parsed.metaDescription || '',
        featuredImageAlt: parsed.featuredImageAlt || '',
        internalLinks: parsed.internalLinks || [],
        socialShareText: parsed.socialShareText || ''
      };
    }
    
    return {
      title: topic,
      html: `<h1>${topic}</h1><p>${text}</p>`,
      metaDescription: '',
      featuredImageAlt: '',
      internalLinks: [],
      socialShareText: ''
    };
  } catch (error) {
    console.error('WordPress 콘텐츠 생성 오류:', error);
    return {
      title: topic,
      html: `<h1>${topic}</h1><p>WordPress 콘텐츠 생성에 실패했습니다.</p>`,
      metaDescription: '',
      featuredImageAlt: '',
      internalLinks: [],
      socialShareText: ''
    };
  }
}

