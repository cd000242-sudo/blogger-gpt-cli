// 7회차 모드 제거됨 - MAX모드로 고정
  // 강화된 안전한 문자열 처리 함수
  function sanitizeString(str: any): string {
    if (typeof str !== 'string') {
      if (str === null || str === undefined) return '';
      return String(str);
    }
    
    return str
      .replace(/[\uD800-\uDFFF]/g, '') // 유효하지 않은 유니코드 서로게이트 쌍 제거
      .replace(/\0/g, '') // null 바이트 제거
      .replace(/[\x00-\x1F\x7F-\x9F]/g, '') // 제어 문자 제거
      .replace(/[^\uAC00-\uD7AF\u1100-\u11FF\u3130-\u318Fa-zA-Z0-9\s.,!?()[\]{}"'`~@#$%^&*+=|\\:;<>\/_-]/g, '') // 한국어, 영어, 숫자, 기본 특수문자만 허용
      .trim();
  }

// 7회차 모드 제거됨 - MAX모드로 고정

// ─────────────────────────────────────────────────────────────
// 커스텀 모드 글 생성 함수 (기본 Gemini 프롬프트)
// ─────────────────────────────────────────────────────────────

export async function generateCustomModeArticle(payload: RunOnePostPayload, onLog?: (s: string) => void): Promise<string> {
  // 강화된 안전한 문자열 처리 함수
  function sanitizeString(str: any): string {
    if (typeof str !== 'string') {
      if (str === null || str === undefined) return '';
      return String(str);
    }
    
    return str
      .replace(/[\uD800-\uDFFF]/g, '') // 유효하지 않은 유니코드 서로게이트 쌍 제거
      .replace(/\0/g, '') // null 바이트 제거
      .replace(/[\x00-\x1F\x7F-\x9F]/g, '') // 제어 문자 제거
      .replace(/[^\uAC00-\uD7AF\u1100-\u11FF\u3130-\u318Fa-zA-Z0-9\s.,!?()[\]{}"'`~@#$%^&*+=|\\:;<>\/_-]/g, '') // 한국어, 영어, 숫자, 기본 특수문자만 허용
      .trim();
  }

  const safeTopic = sanitizeString(payload.topic);
  const safeKeywords = Array.isArray(payload.keywords) 
    ? payload.keywords.map(k => sanitizeString(k)).join(', ')
    : sanitizeString(payload.keywords);

  const minChars = payload.minChars || 6000;

  onLog?.(`[PROGRESS] 커스텀 모드로 콘텐츠 생성 시작 (${minChars}자 목표)`);

  try {
    // 기본 Gemini 프롬프트 사용
    const customPrompt = `
당신은 전문 블로그 작가입니다. 다음 주제에 대해 고품질의 블로그 포스트를 작성해주세요.

주제: ${safeTopic}
키워드: ${safeKeywords}
최소 글자 수: ${minChars}자 이상

요구사항:
- SEO 최적화된 제목과 내용
- 독자에게 유용한 정보 제공
- 자연스러운 키워드 배치
- HTML 형식으로 출력
- 구조화된 내용 (제목, 소제목, 본문, 결론)

HTML 형식으로 작성해주세요.`;

    const genAI = new GoogleGenerativeAI(payload.geminiKey || '');
    const model = genAI.getGenerativeModel({
      model: 'gemini-2.0-flash-exp',
    });

    const result = await model.generateContent({
      contents: [{ role: 'user', parts: [{ text: customPrompt }] }],
      generationConfig: { temperature: 0.7, topP: 0.95, maxOutputTokens: 15000 },
    });

    const content = result.response.text().trim();
    onLog?.('[PROGRESS] 커스텀 모드 콘텐츠 생성 완료');

    return stripToFragment(content);
  } catch (error) {
    onLog?.(`❌ 커스텀 모드 생성 오류: ${error}`);
    throw error;
  }
}

// 프롬프트 모드 제거됨 - MAX모드로 고정

// ─────────────────────────────────────────────────────────────
// MAX 모드 글 생성 함수 (기존 5개 섹션 구조)
// ─────────────────────────────────────────────────────────────

export async function generateMaxModeArticle(payload: RunOnePostPayload, env: any, onLog?: (s: string) => void): Promise<string> {
  // 강화된 안전한 문자열 처리 함수
  function sanitizeString(str: any): string {
    if (typeof str !== 'string') {
      if (str === null || str === undefined) return '';
      return String(str);
    }
    
    // 메모리 효율적인 정리 (단계별 처리)
    let result = str.trim();
    
    // 1단계: 기본 정리
    if (result.length === 0) return '';
    
    // 2단계: 위험한 문자만 제거 (정규식 최소화)
    result = result
      .replace(/[\uD800-\uDFFF]/g, '') // 유효하지 않은 유니코드 서로게이트 쌍 제거
      .replace(/\0/g, '') // null 바이트 제거
      .replace(/[\x00-\x08\x0B\x0C\x0E-\x1F\x7F-\x9F]/g, ''); // 제어 문자 제거 (공백, 탭, 줄바꿈 제외)
    
    // 3단계: 길이 제한 (메모리 보호)
    if (result.length > 10000) {
      result = result.substring(0, 10000) + '...';
    }
    
    return result;
  }
    });

// 7회차 모드 제거됨 - MAX모드로 고정

// ─────────────────────────────────────────────────────────────
// 커스텀 모드 글 생성 함수 (기본 Gemini 프롬프트)
// ─────────────────────────────────────────────────────────────

export async function generateCustomModeArticle(payload: RunOnePostPayload, onLog?: (s: string) => void): Promise<string> {
  // 강화된 안전한 문자열 처리 함수
  function sanitizeString(str: any): string {
    if (typeof str !== 'string') {
      if (str === null || str === undefined) return '';
      return String(str);
    }
    
    return str
      .replace(/[\uD800-\uDFFF]/g, '') // 유효하지 않은 유니코드 서로게이트 쌍 제거
      .replace(/\0/g, '') // null 바이트 제거
      .replace(/[\x00-\x1F\x7F-\x9F]/g, '') // 제어 문자 제거
      .replace(/[^\uAC00-\uD7AF\u1100-\u11FF\u3130-\u318Fa-zA-Z0-9\s.,!?()[\]{}"'`~@#$%^&*+=|\\:;<>\/_-]/g, '') // 한국어, 영어, 숫자, 기본 특수문자만 허용
      .trim();
  }

  const safeTopic = sanitizeString(payload.topic);
  const safeKeywords = Array.isArray(payload.keywords) 
    ? payload.keywords.map(k => sanitizeString(k)).join(', ')
    : sanitizeString(payload.keywords);

  const minChars = payload.minChars || 6000;

  onLog?.(`[PROGRESS] 커스텀 모드로 콘텐츠 생성 시작 (${minChars}자 목표)`);

  try {
    // 기본 Gemini 프롬프트 사용
    const customPrompt = `
당신은 전문 블로그 작가입니다. 다음 주제에 대해 고품질의 블로그 포스트를 작성해주세요.

주제: ${safeTopic}
키워드: ${safeKeywords}
최소 글자 수: ${minChars}자 이상

요구사항:
- SEO 최적화된 제목과 내용
- 독자에게 유용한 정보 제공
- 자연스러운 키워드 배치
- HTML 형식으로 출력
- 구조화된 내용 (제목, 소제목, 본문, 결론)

HTML 형식으로 작성해주세요.`;

    const genAI = new GoogleGenerativeAI(payload.geminiKey || '');
    const model = genAI.getGenerativeModel({
      model: 'gemini-2.0-flash-exp',
    });

    const result = await model.generateContent({
      contents: [{ role: 'user', parts: [{ text: customPrompt }] }],
      generationConfig: { temperature: 0.7, topP: 0.95, maxOutputTokens: 15000 },
    });

    const content = result.response.text().trim();
    onLog?.('[PROGRESS] 커스텀 모드 콘텐츠 생성 완료');

    return stripToFragment(content);
  } catch (error) {
    onLog?.(`❌ 커스텀 모드 생성 오류: ${error}`);
    throw error;
  }
}

// 프롬프트 모드 제거됨 - MAX모드로 고정

// ─────────────────────────────────────────────────────────────
// MAX 모드 글 생성 함수 (기존 5개 섹션 구조)
// ─────────────────────────────────────────────────────────────

export async function generateMaxModeArticle(payload: RunOnePostPayload, env: any, onLog?: (s: string) => void): Promise<string> {
  // 강화된 안전한 문자열 처리 함수 (메모리 최적화)
  function sanitizeString(str: any): string {
    if (typeof str !== 'string') {
      if (str === null || str === undefined) return '';
      return String(str);
    }
    
    // 메모리 효율적인 정리 (단계별 처리)
    let result = str.trim();
    
    // 1단계: 기본 정리
    if (result.length === 0) return '';
    
    // 2단계: 위험한 문자만 제거 (정규식 최소화)
    result = result
      .replace(/[\uD800-\uDFFF]/g, '') // 유효하지 않은 유니코드 서로게이트 쌍 제거
      .replace(/\0/g, '') // null 바이트 제거
      .replace(/[\x00-\x08\x0B\x0C\x0E-\x1F\x7F-\x9F]/g, ''); // 제어 문자 제거 (공백, 탭, 줄바꿈 제외)
    
    // 3단계: 길이 제한 (메모리 보호)
    if (result.length > 10000) {
      result = result.substring(0, 10000) + '...';
    }
    
    return result;
  }
  
  // 크롤링 기반 제목 생성 함수
  async function generateSEOOptimizedTitle(topic: string, keywords: string[], crawledTitles: string[] = []): Promise<string> {
    try {
      const titlePrompt = `
당신은 SEO 전문가입니다. 다음 정보를 바탕으로 상위 노출 가능하고 클릭 유도력이 높은 제목을 생성해주세요.

주제: ${topic}
키워드: ${keywords.join(', ')}
크롤링된 제목들: ${crawledTitles.slice(0, 5).join(', ')}

제목 생성 요구사항:
- 크롤링한 제목을 기반으로 SEO에 최적화된 제목 생성
- 상위 노출 가능한 키워드 포함
- 클릭 유도력이 높은 제목 구조
- 40-70자 내외의 적절한 길이
- 검색 의도에 맞는 제목 작성
- "왜"보다는 "어떻게"에 비중을 둔 실용적 제목

제목만 출력해주세요 (HTML 태그 없이):`;

      const genAI = new GoogleGenerativeAI(geminiKey);
      const model = genAI.getGenerativeModel({
        model: 'gemini-2.0-flash-exp',
      });

      const result = await model.generateContent({
        contents: [{ role: 'user', parts: [{ text: titlePrompt }] }],
        generationConfig: { temperature: 0.7, topP: 0.95, maxOutputTokens: 200 },
      });

      return result.response.text().trim().replace(/[<>]/g, '');
    } catch (error) {
      console.log('제목 생성 실패, 기본 제목 사용:', error);
      return topic;
    }

  // 동적 CTA 생성 함수
  async function generateDynamicCTA(sectionTitle: string, content: string, keywords: string[]): Promise<string> {
    try {
      const ctaPrompt = `
당신은 CTA 전문가입니다. 다음 정보를 바탕으로 클릭 유도력이 높은 CTA를 생성해주세요.

섹션 제목: ${sectionTitle}
본문 내용: ${content.substring(0, 500)}...
키워드: ${keywords.join(', ')}

CTA 생성 요구사항:
- 크롤링을 기반으로 CTA 생성
- 수동 CTA 외 반드시 외부링크 동적 생성
- 후킹 멘트와 함께 CENTER 정렬로 배치
- 클릭 유도력이 높은 후킹 멘트 포함
- 관련성이 높은 외부 링크 포함

HTML 형식으로 출력해주세요:`;

      const genAI = new GoogleGenerativeAI(geminiKey);
      const model = genAI.getGenerativeModel({
        model: 'gemini-2.0-flash-exp',
      });

      const result = await model.generateContent({
        contents: [{ role: 'user', parts: [{ text: ctaPrompt }] }],
        generationConfig: { temperature: 0.7, topP: 0.95, maxOutputTokens: 500 },
      });

      return result.response.text().trim();
    } catch (error) {
      console.log('CTA 생성 실패:', error);
      return '';
    }
  }

  // 핵심요약표 생성 함수
  async function generateSummaryTable(content: string, keywords: string[]): Promise<string> {
    try {
      const tablePrompt = `
당신은 요약 전문가입니다. 다음 정보를 바탕으로 핵심요약표를 생성해주세요.

본문 내용: ${content.substring(0, 1000)}...
키워드: ${keywords.join(', ')}

핵심요약표 생성 요구사항:
- 4x4 또는 5x5 테이블 구조로 동적 생성
- 핵심 내용을 짧고 정확하게 요약
- 상황에 맞는 관련 링크 포함
- 본문의 핵심 내용을 정확하게 반영
- 독자가 빠르게 파악할 수 있는 구조

HTML 테이블 형식으로 출력해주세요:`;

      const genAI = new GoogleGenerativeAI(geminiKey);
      const model = genAI.getGenerativeModel({
        model: 'gemini-2.0-flash-exp',
      });

      const result = await model.generateContent({
        contents: [{ role: 'user', parts: [{ text: tablePrompt }] }],
        generationConfig: { temperature: 0.7, topP: 0.95, maxOutputTokens: 800 },
      });

      return result.response.text().trim();
    } catch (error) {
      console.log('핵심요약표 생성 실패:', error);
      return '';
    }
  }

  // 안전한 payload 처리
  const safeTopic = sanitizeString(payload.topic);
  if (safeTopic.length < 2) {
    throw new Error('주제는 최소 2자 이상이어야 합니다.');
  }

  const safeKeywords = Array.isArray(payload.keywords) 
    ? payload.keywords.map(sanitizeString).filter(Boolean)
    : sanitizeString(payload.keywords).split(',').map(k => sanitizeString(k)).filter(Boolean);
  
  const { provider, openaiKey, geminiKey, contentMode = 'external', manualCtas = {}, googleCseKey, googleCseCx } = payload;
  
  const minChars = Math.max(payload.minChars || 6000, 1000); // 최소 1000자 보장
  
  console.log(`📝 주제: ${safeTopic} | 모드: ${contentMode}`);
  
  // 키워드 추출 및 정제
  let keywordArray: string[] = [];
  if (safeKeywords && safeKeywords.length > 0) {
    keywordArray = safeKeywords;
    console.log(`🔑 사용자 입력 키워드: ${keywordArray.join(', ')}`);
  } else {
    // 주제에서 자동 키워드 추출
    console.log('🔍 주제에서 키워드 자동 추출 중...');
    const baseKeywords = [safeTopic];
    const relatedKeywords: string[] = [];
    
    // 연도/날짜 관련 키워드
    const yearMatch = safeTopic.match(/(\d{4})/);
    if (yearMatch) {
      relatedKeywords.push(yearMatch[1], `${yearMatch[1]}년`);
    }
    
    // 주제를 단어별로 분리하여 추가 키워드 생성
    const words = safeTopic.split(/[\s,]+/).filter(word => word.length > 1);
    relatedKeywords.push(...words);
    
    // 중복 제거 및 정제
    keywordArray = [...baseKeywords, ...relatedKeywords]
      .map(k => k.trim())
      .filter(k => k.length > 0)
      .filter((k, i, arr) => arr.indexOf(k) === i) // 중복 제거
      .slice(0, 10); // 최대 10개로 제한
    
    console.log(`🔍 추출된 키워드: ${keywordArray.join(', ')}`);
  }
  
  // 콘텐츠 모드에 따른 섹션 선택
  const getSectionsForMode = (mode: string): MaxModeSection[] => {
    const sections = CONTENT_MODE_SECTIONS_MAP[mode];
    if (sections) {
      return sections;
    }
    // 기본값은 SEO 최적화 모드 (기존 맥스 모드)
    return MAX_MODE_SECTIONS;
  };
  
  const sectionConfigs = getSectionsForMode(env.contentMode || 'external');
  const contentType = env.contentMode === 'spiderwebbing' ? '일관성/거미줄치기 전문' :
                     env.contentMode === 'adsense' ? '애드센스 승인 전문' :
                     env.contentMode === 'paraphrasing' ? '페러프레이징 전문' :
                     env.contentMode === 'internal' ? '내부 링크 최적화' :
                     env.contentMode === 'shopping' ? '쇼핑 모드' : 'SEO 최적화';
  
  console.log(`📋 콘텐츠 타입: ${contentType} | 섹션 수: ${sectionConfigs.length}개`);
  
  // Gemini 모델 초기화
  const { GoogleGenerativeAI } = await import('@google/generative-ai');
  const genAI = new GoogleGenerativeAI(geminiKey || '');
  const model = genAI.getGenerativeModel({ model: 'gemini-2.0-flash-exp' });
  
  // 1. 제목 생성
  console.log('✨ 제목 생성 중...');
  onLog?.('[PROGRESS] 5% - 제목 생성 중...');
  
  const titlePrompt = buildMaxModeTitlePrompt(contentMode, safeTopic, keywordArray);
  const titleResult = await model.generateContent(titlePrompt);
  let title = titleResult.response.text().trim();
  console.log(`✅ 제목: ${title}`);
  onLog?.('[PROGRESS] 18% - 제목 생성 완료');
  
  // 2. 크롤링 + AI로 최적화된 소제목 5개 생성
  console.log('🔍 소제목 분석 중...');
  onLog?.('[PROGRESS] 22% - 소제목 분석 중...');
  
  let optimalSubtopic: string[] = [];
  
  try {
    console.log('🔎 키워드 기반 소제목 수집 중...');
    onLog?.('[PROGRESS] 28% - 키워드 기반 소제목 수집 중...');
    
    optimalSubtopic = await generateOptimalSubtopic(safeTopic, keywordArray, {
      openaiKey,
      geminiKey,
      provider,
      naverClientId: (payload as any).naverClientId,
      naverClientSecret: (payload as any).naverClientSecret,
      googleCseKey,
      googleCseCx
    });
    console.log(`✅ 소제목 생성 완료: ${optimalSubtopic.length}개`);
    onLog?.('[PROGRESS] 32% - 소제목 생성 완료');
  } catch (error) {
    console.log('[CONTENT] 소제목 크롤링 실패, 기본 소제목 사용:', error);
    optimalSubtopic = [
      `${safeTopic}의 기본 개념과 이해`,
      `${safeTopic}의 주요 특징과 장점`, 
      `${safeTopic}의 활용 방법과 사례`,
      `${safeTopic}의 주의사항과 한계`,
      `${safeTopic}의 미래 전망과 발전 방향`
    ];
    onLog?.('[PROGRESS] 32% - 기본 소제목 사용');
  }
  
  // 3. 네이버 API → RSS → CSE 순서로 본문 내용 크롤링
  console.log('📄 본문 내용 수집 중...');
  onLog?.('[PROGRESS] 35% - 본문 내용 수집 중...');
  
  let crawledContents: any[] = [];
  let crawledCTAs: any[] = [];
  
  try {
    console.log('🌐 외부 콘텐츠 검색 중...');
    onLog?.('[PROGRESS] 40% - 외부 콘텐츠 검색 시작...');
    
    const crawlResult = await crawlAndMixContent(safeTopic, keywordArray, {
      openaiKey,
      geminiKey,
      provider,
      naverClientId: (payload as any).naverClientId,
      naverClientSecret: (payload as any).naverClientSecret,
      googleCseKey,
      googleCseCx
    });
    
    crawledContents = crawlResult.contents || [];
    crawledCTAs = crawlResult.ctas || [];
    
    console.log(`✅ 크롤링 완료: ${crawledContents.length}개 글, ${crawledCTAs.length}개 CTA`);
    onLog?.('[PROGRESS] 45% - 본문 내용 수집 완료');
    
  } catch (error) {
    console.log('[CONTENT] 크롤링 실패, 기본 모드로 진행:', error);
    onLog?.('[PROGRESS] 45% - 기본 모드로 진행');
    crawledContents = [];
    crawledCTAs = [];
  }
  
  // 4. 각 섹션별 콘텐츠 생성
  console.log(`📝 ${sectionConfigs.length}개 섹션 병렬 생성 시작...`);
  onLog?.('[PROGRESS] 50% - 섹션별 콘텐츠 생성 시작...');
  
  const sections: string[] = [];
  
  const sectionPromises = sectionConfigs.map(async (section, i) => {
    const subtopic = optimalSubtopic[i] || section.title;
    
    try {
      console.log(`📝 ${section.title} 섹션 생성 중... (${i + 1}/${sectionConfigs.length})`);
      
      const manualCta = manualCtas[i];
      
      // 크롤링된 CTA에서 해당 섹션에 맞는 CTA 선택
      const sectionCTAs = crawledCTAs || [];
      const relevantCTA = sectionCTAs
        .filter((cta: any) => cta.isExternal && cta.relevance > 5)
        .sort((a: any, b: any) => b.relevance - a.relevance)
        .find((cta: any) => 
          cta.text.toLowerCase().includes(subtopic.toLowerCase()) ||
          cta.text.toLowerCase().includes(keywordArray.join(' ').toLowerCase()) ||
          cta.context.toLowerCase().includes(subtopic.toLowerCase())
        ) || sectionCTAs
        .filter((cta: any) => cta.isExternal && cta.relevance > 5)
        .sort((a: any, b: any) => b.relevance - a.relevance)[0];
      
      // 동적 CTA 생성
      const dynamicCta = relevantCTA ? {
        url: relevantCTA.url,
        text: relevantCTA.text,
        hook: relevantCTA.hook || `💡 ${subtopic}에 대한 더 자세한 정보가 필요하신가요?`
      } : null;
      
      const finalCta = dynamicCta || manualCta;
      
      let sectionPrompt: string;
      
      if (env.contentMode === 'spiderwebbing' || env.contentMode === 'adsense' || env.contentMode === 'paraphrasing') {
        sectionPrompt = buildContentModePrompt(safeTopic, section, subtopic, env.contentMode, finalCta, payload.platform);
      } else {
        sectionPrompt = buildMaxModePromptWithSubtopic(contentMode, safeTopic, keywordArray, section, subtopic, finalCta, crawledContents, {}, payload.platform);
      }
      
      const sectionResult = await model.generateContent(sectionPrompt);
      const sectionContent = sectionResult.response.text().trim();
      
      console.log(`✅ ${section.title} 섹션 완료 (${sectionContent.length}자)`);
      return { index: i, content: sectionContent, success: true };
      
    } catch (sectionError: any) {
      console.error(`[SECTION ERROR] ${section.title} 섹션 생성 실패:`, sectionError);
      
      const fallbackContent = `<h2>${section.title}</h2><p>${subtopic}에 대한 내용을 준비 중입니다.</p>`;
      
      return { index: i, content: fallbackContent, success: false };
    }
  });
  
  // 모든 섹션 병렬 처리 완료 대기
  const sectionResults = await Promise.all(sectionPromises);
  
  // 결과를 순서대로 정렬
  sectionResults
    .sort((a, b) => a.index - b.index)
    .forEach(result => {
      sections.push(result.content);
      if (!result.success) {
        onLog?.(`❌ 섹션 ${result.index + 1} 생성 실패, 기본 콘텐츠 사용`);
      }
    });
  
  // 5. 전체 HTML 조합
  console.log('🔧 최종 HTML 조합 중...');
  onLog?.('[PROGRESS] 70% - 최종 HTML 조합 중...');
  
  const isWordPress = payload.platform === 'wordpress';
  const articleClass = isWordPress ? 'premium-article' : 'max-mode-article';
  const contentClass = isWordPress ? 'premium-content' : 'article-content';
  
  // 목차 생성 (WordPress만)
  const tableOfContents = generateTableOfContents(optimalSubtopic, isWordPress);
  
  // 핵심 요약표 생성
  const coreSummaryTable = generateCoreSummaryTable(safeTopic, keywordArray, optimalSubtopic);
  
  const contentHtml = `<div class="${contentClass}">
    ${tableOfContents}
    ${sections.join('\n\n')}
    ${coreSummaryTable}
  </div>`;
  
  // 해시태그 자동 생성
  const generateHashtags = (topic: string, keywords: string[], subtopics: string[]): string[] => {
    const hashtags = new Set<string>();
    
    keywords.forEach(keyword => {
      const cleanKeyword = keyword.trim().replace(/[^\w가-힣]/g, '');
      if (cleanKeyword.length > 1) {
        hashtags.add(`#${cleanKeyword}`);
      }
    });
    
    const topicWords = topic.split(/[\s,]+/).filter(word => word.length > 1);
    topicWords.forEach(word => {
      const cleanWord = word.replace(/[^\w가-힣]/g, '');
      if (cleanWord.length > 1) {
        hashtags.add(`#${cleanWord}`);
      }
    });
    
    subtopics.forEach(subtopic => {
      const subtopicWords = subtopic.split(/[\s,]+/).filter(word => word.length > 1);
      subtopicWords.forEach(word => {
        const cleanWord = word.replace(/[^\w가-힣]/g, '');
        if (cleanWord.length > 1 && cleanWord.length < 10) {
          hashtags.add(`#${cleanWord}`);
        }
      });
    });
    
    const commonHashtags = [
      '#정보', '#가이드', '#팁', '#꿀팁', '#유용한정보', 
      '#최신정보', '#업데이트', '#뉴스', '#트렌드', '#인기'
    ];
    
    commonHashtags.forEach(tag => hashtags.add(tag));
    
    return Array.from(hashtags).slice(0, 15);
  };

  const hashtags = generateHashtags(safeTopic, keywordArray, optimalSubtopic);
  
  // 면책사항 생성
  const generateDisclaimer = (): string => {
    return `
<div class="disclaimer-section" style="margin-top: 40px; padding: 20px; background: #f8f9fa; border-left: 4px solid #007bff; border-radius: 8px;">
  <h4 style="color: #007bff; margin-bottom: 15px; font-size: 1.1rem;">⚠️ 면책사항</h4>
  <p style="color: #666; line-height: 1.6; margin: 0; font-size: 0.9rem;">
    본 글은 정보 제공 목적으로 작성되었으며, 최신 정보는 공식 소스에서 확인하시기 바랍니다. 
    작성자의 개인적인 의견이 포함될 수 있으며, 투자나 중요한 결정을 내리기 전에는 전문가와 상담하시기 바랍니다. 
    정보의 정확성이나 완전성을 보장하지 않으며, 본 글의 내용으로 인한 손실이나 피해에 대해 책임지지 않습니다.
  </p>
</div>`;
  };

  const disclaimerHtml = generateDisclaimer();
  
  // 플랫폼별 CSS 스타일을 HTML에 직접 포함
  // 공통 CSS 스타일 함수 - 밝고 화려한 고급스러운 디자인
  const getCommonCSS = () => `
<style>
/* ===================================
   밝고 화려한 고급스러운 공통 스타일
   =================================== */

/* 루트 변수 - 밝고 화려한 색상 팔레트 + 폰트 크기 최적화 */
:root {
  --primary-gradient: linear-gradient(135deg, #ff6b6b 0%, #4ecdc4 50%, #45b7d1 100%);
  --secondary-gradient: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  --accent-gradient: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
  --success-gradient: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
  --warning-gradient: linear-gradient(135deg, #ffd89b 0%, #19547b 100%);
  --text-primary: #2d3748;
  --text-secondary: #4a5568;
  --text-white: #ffffff;
  --bg-white: rgba(255, 255, 255, 0.98);
  --bg-light: rgba(255, 255, 255, 0.9);
  --shadow-soft: 0 8px 25px rgba(255, 107, 107, 0.15);
  --shadow-medium: 0 15px 35px rgba(78, 205, 196, 0.2);
  --shadow-strong: 0 25px 50px rgba(69, 183, 209, 0.25);
  --border-radius: 20px;
  --border-radius-large: 30px;
  /* 폰트 크기 최적화 - 어르신들도 잘 읽을 수 있는 크기 */
  --font-size-base: 20px; /* 본문 텍스트 최소 20px */
  --font-size-h1: 36px;   /* H1 최소 32px 이상 */
  --font-size-h2: 30px;   /* H2 최소 28px 이상 */
  --font-size-h3: 26px;   /* H3 최소 24px 이상 */
  --line-height: 2.3;
}

/* 공통 섹션 스타일 - 밝고 화려한 디자인 */
.article-section {
  margin: 45px 0;
  background: var(--bg-white);
  backdrop-filter: blur(25px);
  border-radius: var(--border-radius-large);
  padding: 45px;
  box-shadow: var(--shadow-medium);
  border: 3px solid rgba(255, 255, 255, 0.3);
  position: relative;
  overflow: hidden;
}

.article-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6px;
  background: var(--primary-gradient);
  border-radius: var(--border-radius-large) var(--border-radius-large) 0 0;
}

.article-section::after {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, rgba(255, 107, 107, 0.1) 0%, transparent 70%);
  pointer-events: none;
}

/* 공통 본문 스타일 - 밝고 읽기 쉬운 디자인 + 문단 구조 최적화 */
.section-body {
  color: var(--text-primary) !important;
  line-height: var(--line-height);
  font-size: var(--font-size-base) !important;
  margin-bottom: 35px;
  position: relative;
  z-index: 1;
}

.section-body p {
  color: var(--text-primary) !important;
  line-height: var(--line-height);
  margin-bottom: 30px !important;
  font-weight: 500;
  font-size: var(--font-size-base) !important;
  text-shadow: 0 1px 2px rgba(255, 255, 255, 0.8);
  /* 문단 구조 최적화 - 3-4문단으로 나누어 가독성 극대화 */
  padding: 15px 0;
  border-left: 4px solid transparent;
  transition: border-left 0.3s ease;
}

.section-body p:nth-child(odd) {
  border-left-color: rgba(255, 107, 107, 0.3);
}

.section-body p:nth-child(even) {
  border-left-color: rgba(78, 205, 196, 0.3);
}

/* 문단별 구분을 위한 시각적 효과 */
.section-body p:not(:last-child)::after {
  content: '';
  display: block;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255, 107, 107, 0.2), transparent);
  margin: 20px 0;
}

/* 워드프레스 전용 버튼형 목차 스타일 */
.wordpress-toc {
  background: var(--success-gradient) !important;
  border-radius: var(--border-radius-large) !important;
  padding: 30px !important;
  margin: 30px 0 !important;
  box-shadow: var(--shadow-medium) !important;
  border: 3px solid rgba(255, 255, 255, 0.4) !important;
}

.wordpress-toc h3 {
  color: var(--text-primary) !important;
  font-size: var(--font-size-h3) !important;
  margin-bottom: 20px !important;
  text-align: center !important;
  font-weight: 800 !important;
}

.wordpress-toc ul {
  list-style: none !important;
  padding: 0 !important;
  margin: 0 !important;
  display: grid !important;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)) !important;
  gap: 15px !important;
}

.wordpress-toc li {
  margin: 0 !important;
}

.wordpress-toc a {
  display: block !important;
  padding: 15px 20px !important;
  background: var(--bg-white) !important;
  border-radius: 12px !important;
  color: var(--text-primary) !important;
  text-decoration: none !important;
  font-weight: 600 !important;
  font-size: 16px !important;
  transition: all 0.3s ease !important;
  border: 2px solid rgba(255, 255, 255, 0.3) !important;
  box-shadow: var(--shadow-soft) !important;
}

.wordpress-toc a:hover {
  transform: translateY(-2px) !important;
  box-shadow: var(--shadow-medium) !important;
  background: var(--primary-gradient) !important;
  color: var(--text-white) !important;
}

/* 공통 제목 스타일 - 화려한 그라디언트 + 단색 박스 스타일 */
.section-body h2 {
  font-size: var(--font-size-h2) !important;
  color: var(--text-white) !important;
  background: var(--primary-gradient) !important;
  padding: 20px 30px !important;
  border-radius: 15px !important;
  box-shadow: var(--shadow-medium) !important;
  text-align: left !important;
  margin: 40px 0 25px 0 !important;
  font-weight: 900 !important;
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3) !important;
  position: relative;
}

.section-body h2::before {
  content: '';
  position: absolute;
  bottom: -8px;
  left: 0;
  width: 60px;
  height: 4px;
  background: var(--secondary-gradient);
  border-radius: 2px;
}

.section-body h3 {
  font-size: var(--font-size-h3) !important;
  color: var(--text-white) !important;
  background: var(--secondary-gradient) !important;
  padding: 18px 25px !important;
  border-radius: 12px !important;
  box-shadow: var(--shadow-soft) !important;
  text-align: left !important;
  margin: 35px 0 20px 0 !important;
  font-weight: 800 !important;
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3) !important;
}

/* 공통 CTA 스타일 - 화려하고 매력적인 디자인 + 후킹멘트 박스 */
.cta-section, .auto-cta, .premium-cta {
  text-align: center !important;
  margin: 40px 0 !important;
  padding: 35px !important;
  background: var(--success-gradient) !important;
  border-radius: var(--border-radius-large) !important;
  box-shadow: var(--shadow-strong) !important;
  border: 3px solid rgba(255, 255, 255, 0.4) !important;
  position: relative;
  overflow: hidden;
}

.cta-section::before, .auto-cta::before, .premium-cta::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(45deg, rgba(255, 255, 255, 0.2) 0%, rgba(255, 255, 255, 0.1) 100%);
  pointer-events: none;
}

.cta-button, .premium-cta-button {
  display: inline-block !important;
  background: var(--primary-gradient) !important;
  color: white !important;
  padding: 18px 35px !important;
  border-radius: 25px !important;
  text-decoration: none !important;
  font-weight: bold !important;
  font-size: 18px !important;
  box-shadow: var(--shadow-medium) !important;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
  position: relative;
  z-index: 1;
  border: 2px solid rgba(255, 255, 255, 0.3) !important;
}

.cta-button:hover, .premium-cta-button:hover {
  transform: translateY(-3px) scale(1.05) !important;
  box-shadow: var(--shadow-strong) !important;
}

.cta-hook {
  font-size: 20px !important;
  color: var(--text-primary) !important;
  margin-bottom: 20px !important;
  font-weight: 700 !important;
  text-shadow: 0 1px 2px rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.9) !important;
  padding: 15px 25px !important;
  border-radius: 15px !important;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1) !important;
  border: 2px solid rgba(255, 255, 255, 0.5) !important;
}

/* 반응형 디자인 - 모바일 최적화 */
@media (max-width: 768px) {
  .article-section {
    padding: 30px 20px;
    margin: 30px 0;
  }
  
  .section-body h2 {
    font-size: 26px !important;
  }
  
  .section-body h3 {
    font-size: 22px !important;
  }
  
  .cta-section, .auto-cta, .premium-cta {
    padding: 25px !important;
  }
}
</style>`;

  const cloudSkinCSS = getCommonCSS() + `
<style>
/* ===================================
   소프트 클라우드 스킨 - 블로그스팟 전용
   밝고 몽환적인 구름 테마
   =================================== */

/* 루트 변수 */
:root {
  --cloud-primary: #74b9ff;
  --cloud-secondary: #a29bfe;
  --cloud-accent: #fd79a8;
  --cloud-yellow: #ffeaa7;
  --cloud-gray: #dfe6e9;
  --bg-white: rgba(255, 255, 255, 0.8);
  --bg-white-solid: rgba(255, 255, 255, 0.9);
  --text-primary: #444;
  --text-secondary: #555;
