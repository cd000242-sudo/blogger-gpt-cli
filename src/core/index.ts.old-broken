  }
}
</style>`;

  // WordPress용 프리미엄 그라디언트 스킨 CSS
  const premiumGradientCSS = getCommonCSS() + `
<style>
/* ===================================
   밝고 화려한 프리미엄 그라디언트 스킨
   =================================== */

.premium-article {
  max-width: 1100px;
  margin: 0 auto;
  background: linear-gradient(135deg, #ff6b6b 0%, #4ecdc4 30%, #45b7d1 70%, #f093fb 100%);
  border-radius: 45px;
  padding: 70px;
  box-shadow: var(--shadow-strong);
  position: relative;
  overflow: hidden;
}

.premium-article::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(45deg, rgba(255, 255, 255, 0.15) 0%, rgba(255, 255, 255, 0.08) 100%);
  border-radius: 45px;
  pointer-events: none;
}

.premium-article::after {
  content: '';
  position: absolute;
  top: -100px;
  right: -100px;
  width: 300px;
  height: 300px;
  background: radial-gradient(circle, rgba(255, 107, 107, 0.2) 0%, transparent 70%);
  border-radius: 50%;
  animation: rotate 20s linear infinite;
}

@keyframes rotate {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.premium-article > * {
  background: var(--bg-white);
  backdrop-filter: blur(25px);
  border-radius: var(--border-radius-large);
  padding: 55px;
  box-shadow: var(--shadow-medium);
  border: 3px solid rgba(255, 255, 255, 0.3);
  margin-bottom: 45px;
  position: relative;
  z-index: 1;
}

.premium-content {
  background: var(--bg-white);
  backdrop-filter: blur(25px);
  border-radius: var(--border-radius-large);
  padding: 55px;
  box-shadow: var(--shadow-medium);
  border: 3px solid rgba(255, 255, 255, 0.3);
  margin-bottom: 45px;
  position: relative;
  z-index: 1;
}

.premium-section {
  margin: 65px 0;
  background: var(--bg-white) !important;
  backdrop-filter: blur(30px);
  border-radius: var(--border-radius-large) !important;
  padding: 65px !important;
  border: 3px solid rgba(255, 255, 255, 0.4) !important;
  box-shadow: var(--shadow-strong) !important;
  position: relative;
  overflow: hidden;
}

.premium-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6px;
  background: var(--primary-gradient);
  border-radius: var(--border-radius-large) var(--border-radius-large) 0 0;
}

.premium-section::after {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, rgba(78, 205, 196, 0.1) 0%, transparent 70%);
  pointer-events: none;
}

.premium-body {
  color: var(--text-primary) !important;
  line-height: var(--line-height);
  font-size: var(--font-size-base) !important;
  margin-bottom: 45px;
  position: relative;
  z-index: 1;
}

.premium-body h2 {
  font-size: var(--font-size-h2) !important;
  color: var(--text-primary) !important;
  margin: 55px 0 30px 0;
  font-weight: 900;
  text-shadow: none;
  background: var(--primary-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  position: relative;
}

.premium-body h2::before {
  content: '';
  position: absolute;
  bottom: -10px;
  left: 0;
  width: 80px;
  height: 5px;
  background: var(--secondary-gradient);
  border-radius: 3px;
}

.premium-body h3 {
  font-size: var(--font-size-h3) !important;
  color: var(--text-primary) !important;
  margin: 45px 0 25px 0;
  font-weight: 800;
  text-shadow: none;
  background: var(--accent-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.premium-body p {
  color: var(--text-primary) !important;
  line-height: var(--line-height);
  margin-bottom: 32px !important;
  text-shadow: none;
  font-weight: 500;
  font-size: var(--font-size-base) !important;
  text-shadow: 0 1px 2px rgba(255, 255, 255, 0.8);
}

.premium-section-title {
  font-size: var(--font-size-h1) !important;
  margin-bottom: 45px !important;
  color: #1a1a1a !important;
  font-weight: 900 !important;
  letter-spacing: -1px !important;
  text-shadow: 0 3px 6px rgba(0, 0, 0, 0.1);
  background: var(--primary-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  position: relative;
}

.premium-section-title::before {
  content: '';
  position: absolute;
  bottom: -15px;
  left: 0;
  width: 100px;
  height: 6px;
  background: var(--secondary-gradient);
  border-radius: 3px;
}

@media (max-width: 768px) {
  .premium-article {
    padding: 45px 30px;
  }

  .premium-article > * {
    padding: 35px;
  }

  .premium-section {
    padding: 45px !important;
  }

  .premium-section-title {
    font-size: 2.4rem;
  }
}
</style>`;
  
  // 플랫폼별 HTML 생성 (CSS 포함)
  const fullHtml = isWordPress 
    ? `${premiumGradientCSS}<div class="${articleClass}">
  ${contentHtml}
  ${disclaimerHtml}
</div>`.trim()
    : `${cloudSkinCSS}<div class="${articleClass}">
  ${contentHtml}
  ${disclaimerHtml}
</div>`.trim();
  
  onLog?.('[PROGRESS] 80% - HTML 구조 완성');
  
  console.log(`✅ 전체 글 생성 완료 (${fullHtml.length}자)`);
  onLog?.('[PROGRESS] 90% - 글 생성 완료!');
  onLog?.(`[FINAL RESULT] 최종 글 길이: ${fullHtml.length}자`);
  
  onLog?.('[PROGRESS] 100% - 모든 작업 완료!');
  
  return fullHtml;
}

// ─────────────────────────────────────────────────────────────
// 타입 정의 및 인터페이스
// ─────────────────────────────────────────────────────────────

export interface RunOnePostPayload {
  provider: string;
  openaiKey?: string;
  geminiKey?: string;
  topic: string;
  keywords: string | string[];
  minChars?: number;
  contentMode?: string; // 콘텐츠 모드 추가
  promptMode?: string; // 프롬프트 모드 추가
  manualCtas?: Record<number, { url: string; text: string; hook?: string }>; // 소제목별 수동 CTA
  // 블로거 발행 관련 필드들
  platform?: string;
  blogId?: string;
  googleClientId?: string;
  googleClientSecret?: string;
  redirectUri?: string;
  // 워드프레스 발행 관련 필드들
  wordpressSiteUrl?: string;
  wordpressUsername?: string;
  wordpressPassword?: string;
  wordpressCategories?: string[];
  wordpressTags?: string[];
  wordpressStatus?: string;
  // 네이버 API 관련 필드들
  naverClientId?: string;
  naverClientSecret?: string;
  // 기타 필드들
  googleCseKey?: string;
  googleCseCx?: string;
}

