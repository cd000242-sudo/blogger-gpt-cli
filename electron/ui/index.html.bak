      style="width: 90%; max-width: 600px; background: linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(227, 242, 253, 0.98) 100%); border-radius: 24px; box-shadow: 0 40px 80px rgba(33, 150, 243, 0.3), 0 0 0 4px rgba(33, 150, 243, 0.2); backdrop-filter: blur(30px); border: 2px solid rgba(33, 150, 243, 0.3); overflow: hidden; position: relative;">

      <!-- 모달 헤더 -->
