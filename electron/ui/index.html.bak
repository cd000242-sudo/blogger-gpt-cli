  <div id="main-tab" class="tab-content active">

    <!-- 1. 시간 & 날짜 (컴팩트) -->
    <div
      style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 16px; padding: 24px; margin-bottom: 24px; box-shadow: 0 12px 40px rgba(102, 126, 234, 0.3); text-align: center; color: white;">
      <!-- 실시간 시계 -->
      <div id="realtime-clock"
        style="font-size: 36px; font-weight: 700; color: white; text-shadow: 0 2px 8px rgba(0,0,0,0.3); letter-spacing: 2px; font-family: 'Segoe UI', sans-serif; margin-bottom: 8px;">
        00:00:00</div>
      <div id="realtime-date"
        style="font-size: 16px; color: rgba(255,255,255,0.9); font-weight: 500; letter-spacing: 1px; margin-bottom: 16px;">
        0000년 00월 00일 (월요일)</div>

      <!-- 대형 달력 -->
      <div id="mini-calendar"
        style="background: rgba(255, 255, 255, 0.15); border-radius: 12px; padding: 12px; backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.2); width: 100%; margin: 0 auto;">
        <div
          style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; padding: 0 8px;">
          <span id="calendar-month"
            style="font-weight: 700; color: white; font-size: 16px; text-shadow: 0 2px 6px rgba(0,0,0,0.3);">0월</span>
          <button onclick="showGuide('calendar')"
            style="padding: 6px 12px; background: rgba(255, 255, 255, 0.2); color: white; border: 1px solid rgba(255, 255, 255, 0.3); border-radius: 6px; font-size: 12px; font-weight: 600; cursor: pointer; backdrop-filter: blur(10px);">
            📖 사용법
          </button>
        </div>
        <div
          style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; text-align: center; font-size: 12px; margin-bottom: 8px;">
          <div
            style="color: #ffd700; font-weight: 700; padding: 8px 0; background: rgba(255, 215, 0, 0.25); border-radius: 6px;">
            일</div>
          <div style="font-weight: 700; padding: 8px 0; background: rgba(255, 255, 255, 0.25); border-radius: 6px;">월
          </div>
          <div style="font-weight: 700; padding: 8px 0; background: rgba(255, 255, 255, 0.25); border-radius: 6px;">화
          </div>
          <div style="font-weight: 700; padding: 8px 0; background: rgba(255, 255, 255, 0.25); border-radius: 6px;">수
          </div>
          <div style="font-weight: 700; padding: 8px 0; background: rgba(255, 255, 255, 0.25); border-radius: 6px;">목
          </div>
          <div style="font-weight: 700; padding: 8px 0; background: rgba(255, 255, 255, 0.25); border-radius: 6px;">금
          </div>
          <div
            style="color: #87ceeb; font-weight: 700; padding: 8px 0; background: rgba(135, 206, 235, 0.25); border-radius: 6px;">
            토</div>
        </div>
        <div id="calendar-dates"
          style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; text-align: center; font-size: 14px;">
          <!-- 날짜가 자동으로 추가됩니다 -->
        </div>
      </div>
    </div>


    <!-- 3. 구매 및 문의 (전체 폭) -->
    <div class="card"
      style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; box-shadow: 0 20px 60px rgba(102, 126, 234, 0.3);">
      <div class="card-header" style="border-bottom: 2px solid rgba(255, 255, 255, 0.2); padding-bottom: 20px;">
        <h2 class="card-title"
          style="color: white; font-size: 24px; font-weight: 700; display: flex; align-items: center; gap: 12px;">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path
              d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z">
            </path>
          </svg>
          구매 및 문의
        </h2>
      </div>

      <div class="card-body" style="padding: 32px;">
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;">
          <button class="btn btn-primary" onclick="alert('세팅 영상은 곧 업로드 예정입니다!')"
            style="padding: 20px 24px; background: rgba(255, 255, 255, 0.25); color: white; border: 2px solid rgba(255, 255, 255, 0.5); border-radius: 12px; font-size: 16px; font-weight: 600; backdrop-filter: blur(10px); transition: all 0.3s ease; display: flex; align-items: center; justify-content: center; gap: 8px; opacity: 0.7; cursor: not-allowed;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path
                d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z">
              </path>
              <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon>
            </svg>
            세팅 영상 (곧 업로드 예정)
          </button>
          <button class="btn btn-success" onclick="window.blogger.openExternal('https://leadernam.imweb.me')"
            style="padding: 20px 24px; background: rgba(255, 255, 255, 0.25); color: white; border: 2px solid rgba(255, 255, 255, 0.5); border-radius: 12px; font-size: 16px; font-weight: 600; backdrop-filter: blur(10px); transition: all 0.3s ease; display: flex; align-items: center; justify-content: center; gap: 8px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
            구매 사이트
          </button>
          <button class="btn btn-warning" onclick="window.blogger.openExternal('https://open.kakao.com/o/sPcaslwh')"
            style="padding: 20px 24px; background: rgba(255, 255, 255, 0.25); color: white; border: 2px solid rgba(255, 255, 255, 0.5); border-radius: 12px; font-size: 16px; font-weight: 600; backdrop-filter: blur(10px); transition: all 0.3s ease; display: flex; align-items: center; justify-content: center; gap: 8px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z">
              </path>
            </svg>
            1대1 문의
          </button>
          <button class="btn btn-secondary"
            onclick="window.blogger.openExternal('https://www.youtube.com/@leadernam-s5e')"
            style="padding: 20px 24px; background: rgba(255, 255, 255, 0.25); color: white; border: 2px solid rgba(255, 255, 255, 0.5); border-radius: 12px; font-size: 16px; font-weight: 600; backdrop-filter: blur(10px); transition: all 0.3s ease; display: flex; align-items: center; justify-content: center; gap: 8px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path
                d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z">
              </path>
              <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon>
            </svg>
            leadernam youtube
          </button>
        </div>
      </div>
    </div>

  </div>

  <!-- 썸네일 생성기 -->
  <div id="thumbnail-tab" class="tab-content">
    <!-- 썸네일 생성기 서브 탭 -->
    <div style="display: flex; gap: 12px; margin-bottom: 24px; justify-content: center;">
      <button id="thumbnailGeneratorTab" onclick="showThumbnailSubTab('generator')"
        style="padding: 12px 24px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; transition: all 0.3s ease;">
        🎨 텍스트 썸네일 생성기
      </button>
      <button id="imageConverterTab" onclick="showThumbnailSubTab('converter')"
        style="padding: 12px 24px; background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: white; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; transition: all 0.3s ease; opacity: 0.7;">
        🖼️ 이미지 변환기
      </button>
    </div>

    <!-- 텍스트 썸네일 생성기 -->
    <div id="thumbnail-generator-content"
      style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; align-items: start;">

      <!-- 왼쪽: 설정 패널 -->
      <div class="card"
        style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; box-shadow: 0 20px 60px rgba(102, 126, 234, 0.3);">
        <div class="card-header" style="border-bottom: 2px solid rgba(255, 255, 255, 0.2); padding-bottom: 20px;">
          <span style="font-size: 24px; font-weight: 700; display: flex; align-items: center; gap: 12px;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
              <circle cx="8.5" cy="8.5" r="1.5"></circle>
              <polyline points="21 15 16 10 5 21"></polyline>
            </svg>
            프리미엄 썸네일 생성기
          </span>
        </div>
        <div class="card-body" style="padding: 24px;">

          <!-- 텍스트입력 -->
          <div style="margin-bottom: 24px;">
            <label
              style="display: block; margin-bottom: 8px; font-weight: 600; font-size: 14px; color: rgba(255, 255, 255, 0.9);">
              썸네일 텍스트
            </label>
            <textarea id="thumbnailText" placeholder="예: 2025 최신 블로그 수익화 완벽 가이드"
              style="width: 100%; padding: 16px; border: 2px solid rgba(255, 255, 255, 0.3); border-radius: 12px; background: rgba(255, 255, 255, 0.15); color: white; font-size: 16px; font-weight: 500; resize: vertical; min-height: 100px; backdrop-filter: blur(10px);"
              oninput="updateThumbnailPreview()"></textarea>
          </div>

          <!-- 🖼️ 배경 이미지 설정 -->
          <div
            style="margin-bottom: 24px; padding: 20px; background: rgba(255, 255, 255, 0.1); border-radius: 12px; border: 2px solid rgba(255, 255, 255, 0.2);">
            <h3
              style="font-size: 16px; font-weight: 600; margin-bottom: 16px; color: rgba(255, 255, 255, 0.95); display: flex; align-items: center; gap: 8px;">
              🖼️ 배경 이미지 설정
            </h3>

            <div style="display: flex; flex-direction: column; gap: 16px;">
              <!-- 배경 타입 선택 -->
              <div>
                <label
                  style="font-weight: 600; margin-bottom: 12px; display: block; font-size: 13px; color: rgba(255, 255, 255, 0.9);">
                  배경 타입
                </label>
                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px;">
                  <label
                    style="display: flex; align-items: center; gap: 8px; padding: 12px; background: rgba(255, 255, 255, 0.1); border: 2px solid rgba(255, 255, 255, 0.3); border-radius: 8px; cursor: pointer; transition: all 0.2s;">
                    <input type="radio" name="thumbnailGenBackgroundType" value="none" checked style="cursor: pointer;">
                    <span style="font-size: 13px; color: rgba(255, 255, 255, 0.9);">❌ 배경 없음</span>
                  </label>
                  <label
                    style="display: flex; align-items: center; gap: 8px; padding: 12px; background: rgba(255, 255, 255, 0.1); border: 2px solid rgba(255, 255, 255, 0.3); border-radius: 8px; cursor: pointer; transition: all 0.2s;">
                    <input type="radio" name="thumbnailGenBackgroundType" value="ai" style="cursor: pointer;">
                    <span style="font-size: 13px; color: rgba(255, 255, 255, 0.9);">🤖 AI 이미지</span>
                  </label>
                  <label
                    style="display: flex; align-items: center; gap: 8px; padding: 12px; background: rgba(255, 255, 255, 0.1); border: 2px solid rgba(255, 255, 255, 0.3); border-radius: 8px; cursor: pointer; transition: all 0.2s;">
                    <input type="radio" name="thumbnailGenBackgroundType" value="local" style="cursor: pointer;">
                    <span style="font-size: 13px; color: rgba(255, 255, 255, 0.9);">📁 로컬 업로드</span>
                  </label>
                  <label
                    style="display: flex; align-items: center; gap: 8px; padding: 12px; background: rgba(255, 255, 255, 0.1); border: 2px solid rgba(255, 255, 255, 0.3); border-radius: 8px; cursor: pointer; transition: all 0.2s;">
                    <input type="radio" name="thumbnailGenBackgroundType" value="url" style="cursor: pointer;">
                    <span style="font-size: 13px; color: rgba(255, 255, 255, 0.9);">🔗 URL 입력</span>
                  </label>
                </div>
              </div>

              <!-- 로컬 이미지 업로드 -->
              <div id="thumbnailGenLocalUpload" style="display: none;">
                <label
                  style="font-weight: 600; margin-bottom: 8px; display: block; font-size: 13px; color: rgba(255, 255, 255, 0.9);">
                  이미지 선택
                </label>
                <input type="file" id="thumbnailGenImageFile" accept="image/*"
                  style="width: 100%; padding: 12px; border: 2px solid rgba(255, 255, 255, 0.3); border-radius: 8px; background: rgba(255, 255, 255, 0.15); color: white; font-size: 14px; backdrop-filter: blur(10px);">
              </div>

              <!-- URL 입력 -->
              <div id="thumbnailGenUrlInput" style="display: none;">
                <label
                  style="font-weight: 600; margin-bottom: 8px; display: block; font-size: 13px; color: rgba(255, 255, 255, 0.9);">
                  이미지 URL
                </label>
                <input type="text" id="thumbnailGenImageUrl" placeholder="https://example.com/image.jpg"
                  style="width: 100%; padding: 12px; border: 2px solid rgba(255, 255, 255, 0.3); border-radius: 8px; background: rgba(255, 255, 255, 0.15); color: white; font-size: 14px; backdrop-filter: blur(10px);">
              </div>

              <!-- 배경 투명도 -->
              <div>
                <label
                  style="font-weight: 600; margin-bottom: 8px; display: block; font-size: 13px; color: rgba(255, 255, 255, 0.9);">
                  배경 투명도: <span id="thumbnailGenBgOpacityValue">60%</span>
                </label>
                <input type="range" id="thumbnailGenBgOpacity" min="0" max="100" value="60"
                  style="width: 100%; height: 8px; border-radius: 5px; background: rgba(255, 255, 255, 0.3); outline: none; cursor: pointer;">
              </div>

              <!-- 블러 강도 -->
              <div>
                <label
                  style="font-weight: 600; margin-bottom: 8px; display: block; font-size: 13px; color: rgba(255, 255, 255, 0.9);">
                  블러 강도: <span id="thumbnailGenBgBlurValue">8px</span>
                </label>
                <input type="range" id="thumbnailGenBgBlur" min="0" max="20" value="8"
                  style="width: 100%; height: 8px; border-radius: 5px; background: rgba(255, 255, 255, 0.3); outline: none; cursor: pointer;">
              </div>
            </div>
          </div>

          <!-- 텍스트 크기 조절 -->
          <div style="margin-bottom: 24px;">
            <label
              style="display: block; margin-bottom: 8px; font-weight: 600; font-size: 14px; color: rgba(255, 255, 255, 0.9);">
              폰트 크기: <span id="fontSizeValue">80</span>px
            </label>
            <input type="range" id="thumbnailFontSize" min="40" max="600" value="80"
              style="width: 100%; height: 8px; border-radius: 5px; background: rgba(255, 255, 255, 0.3); outline: none; cursor: pointer;"
              oninput="updateThumbnailPreview()" />
            <div
              style="display: flex; justify-content: space-between; font-size: 11px; color: rgba(255, 255, 255, 0.7); margin-top: 4px;">
              <span>작게</span>
              <span>크게</span>
            </div>
          </div>

          <!-- 색상 설정 그리드 -->
          <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; margin-bottom: 24px;">

            <!-- 배경색 -->
            <div>
              <label
                style="display: block; margin-bottom: 8px; font-weight: 600; font-size: 13px; color: rgba(255, 255, 255, 0.9);">
                🎨 배경색
              </label>
              <div style="position: relative;">
                <input type="color" id="thumbnailBgColor" value="#ffffff"
                  style="width: 100%; height: 50px; border: 3px solid rgba(255, 255, 255, 0.3); border-radius: 10px; cursor: pointer; background: transparent;"
                  oninput="updateThumbnailPreview()" />
                <span id="bgColorValue"
                  style="position: absolute; bottom: -20px; left: 0; font-size: 11px; color: rgba(255, 255, 255, 0.7);">#ffffff</span>
              </div>
            </div>

            <!-- 텍스트색상 -->
            <div>
              <label
                style="display: block; margin-bottom: 8px; font-weight: 600; font-size: 13px; color: rgba(255, 255, 255, 0.9);">
                ✏️ 텍스트
              </label>
              <div style="position: relative;">
                <input type="color" id="thumbnailTextColor" value="#000000"
                  style="width: 100%; height: 50px; border: 3px solid rgba(255, 255, 255, 0.3); border-radius: 10px; cursor: pointer; background: transparent;"
                  oninput="updateThumbnailPreview()" />
                <span id="textColorValue"
                  style="position: absolute; bottom: -20px; left: 0; font-size: 11px; color: rgba(255, 255, 255, 0.7);">#000000</span>
              </div>
            </div>

            <!-- 테두리색 -->
            <div>
              <label
                style="display: block; margin-bottom: 8px; font-weight: 600; font-size: 13px; color: rgba(255, 255, 255, 0.9);">
                🖼️ 테두리
              </label>
              <div style="position: relative;">
                <input type="color" id="thumbnailBorderColor" value="#ff6b35"
                  style="width: 100%; height: 50px; border: 3px solid rgba(255, 255, 255, 0.3); border-radius: 10px; cursor: pointer; background: transparent;"
                  oninput="updateThumbnailPreview()" />
                <span id="borderColorValue"
                  style="position: absolute; bottom: -20px; left: 0; font-size: 11px; color: rgba(255, 255, 255, 0.7);">#ff6b35</span>
              </div>
            </div>
          </div>

          <!-- 프리셋 컬러 -->
          <div style="margin-top: 40px; margin-bottom: 24px;">
            <label
              style="display: block; margin-bottom: 12px; font-weight: 600; font-size: 14px; color: rgba(255, 255, 255, 0.9);">
              🎨 프리셋 테마
            </label>
            <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px;">
              <button onclick="applyPreset('#ffffff', '#000000', '#3b82f6')"
                style="padding: 12px; border: 2px solid rgba(255, 255, 255, 0.3); border-radius: 8px; background: linear-gradient(135deg, #ffffff 0%, #3b82f6 100%); cursor: pointer; transition: transform 0.2s;"
                onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                <span style="font-size: 10px; font-weight: 600; color: #333;">클린</span>
              </button>
              <button onclick="applyPreset('#1e293b', '#ffffff', '#f59e0b')"
                style="padding: 12px; border: 2px solid rgba(255, 255, 255, 0.3); border-radius: 8px; background: linear-gradient(135deg, #1e293b 0%, #f59e0b 100%); cursor: pointer; transition: transform 0.2s;"
                onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                <span style="font-size: 10px; font-weight: 600; color: white;">다크</span>
              </button>
              <button onclick="applyPreset('#fef3c7', '#92400e', '#ef4444')"
                style="padding: 12px; border: 2px solid rgba(255, 255, 255, 0.3); border-radius: 8px; background: linear-gradient(135deg, #fef3c7 0%, #ef4444 100%); cursor: pointer; transition: transform 0.2s;"
                onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                <span style="font-size: 10px; font-weight: 600; color: #92400e;">웜</span>
              </button>
              <button onclick="applyPreset('#ecfdf5', '#065f46', '#10b981')"
                style="padding: 12px; border: 2px solid rgba(255, 255, 255, 0.3); border-radius: 8px; background: linear-gradient(135deg, #ecfdf5 0%, #10b981 100%); cursor: pointer; transition: transform 0.2s;"
                onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                <span style="font-size: 10px; font-weight: 600; color: #065f46;">민트</span>
              </button>
            </div>
          </div>

          <!-- 생성 버튼 -->
          <button class="btn-primary" id="generateThumbnailBtn" onclick="generateThumbnailWithBackground()"
            style="width: 100%; padding: 18px; font-size: 18px; font-weight: 700; background: linear-gradient(135deg, #f59e0b 0%, #ef4444 100%); border: none; border-radius: 12px; color: white; cursor: pointer; box-shadow: 0 10px 30px rgba(245, 158, 11, 0.4); transition: all 0.3s; margin-top: 8px;"
            onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 15px 40px rgba(245, 158, 11, 0.5)'"
            onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 30px rgba(245, 158, 11, 0.4)'">
            ✨ 썸네일 생성하기
          </button>
        </div>
      </div>

      <!-- 오른쪽 미리보기 패널 -->
      <div style="position: sticky; top: 20px;">
        <div class="card"
          style="background: #1e293b; color: white; border: none; box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);">
          <div class="card-header" style="border-bottom: 2px solid rgba(255, 255, 255, 0.1); padding-bottom: 16px;">
            <span style="font-size: 18px; font-weight: 600; display: flex; align-items: center; gap: 10px;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
              실시간 미리보기
            </span>
          </div>
          <div class="card-body" style="padding: 24px;">

            <!-- 미리보기 캔버스 -->
            <div
              style="position: relative; background: #f8fafc; border-radius: 16px; padding: 20px; min-height: 400px; display: flex; align-items: center; justify-content: center;">
              <!-- 🔥 캔버스 추가 (숨김) -->
              <canvas id="thumbnailCanvas" width="1200" height="630" style="display: none;"></canvas>

              <div id="thumbnailPreview"
                style="width: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                <!-- 미리보기 이미지 -->
                <img id="thumbnailPreviewImg"
                  style="max-width: 100%; border-radius: 12px; box-shadow: 0 4px 16px rgba(0,0,0,0.1); display: none;">

                <!-- 플레이스홀더 -->
                <div id="thumbnailPlaceholder" style="text-align: center; color: #64748b;">
                  <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"
                    style="margin: 0 auto 16px;">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                    <circle cx="8.5" cy="8.5" r="1.5"></circle>
                    <polyline points="21 15 16 10 5 21"></polyline>
                  </svg>
                  <p style="font-size: 16px; font-weight: 500; margin-bottom: 8px;">텍스트를 입력하면</p>
                  <p style="font-size: 14px; color: #94a3b8;">실시간으로 미리보기가 표시됩니다</p>
                </div>
              </div>
            </div>

            <!-- 다운로드 버튼 -->
            <button id="downloadThumbnailBtn" onclick="downloadThumbnail()"
              style="width: 100%; padding: 16px; font-size: 16px; font-weight: 600; background: linear-gradient(135deg, #10b981 0%, #059669 100%); border: none; border-radius: 12px; color: white; cursor: pointer; margin-top: 20px; box-shadow: 0 8px 20px rgba(16, 185, 129, 0.3); transition: all 0.3s; display: none;"
              onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 12px 30px rgba(16, 185, 129, 0.4)'"
              onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 8px 20px rgba(16, 185, 129, 0.3)'">
              썸네일 다운로드
            </button>

            <!-- 정보 -->
            <div
              style="margin-top: 20px; padding: 16px; background: rgba(59, 130, 246, 0.1); border-radius: 12px; border-left: 4px solid #3b82f6;">
              <p style="font-size: 13px; color: #cbd5e1; line-height: 1.6;">
                <strong style="color: #3b82f6;">💡 Tip:</strong> 썸네일은 1200x630px로 자동 최적화되어 블로그 및 SNS에 최적화된 비율입니다.
              </p>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- 이미지 변환기 -->
    <div id="image-converter-content"
      style="display: none; grid-template-columns: 1fr 1fr; gap: 24px; align-items: start;">

      <!-- 왼쪽: 변환 설정 패널 -->
      <div class="card"
        style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: white; border: none; box-shadow: 0 20px 60px rgba(79, 172, 254, 0.3);">
        <div class="card-header" style="border-bottom: 2px solid rgba(255, 255, 255, 0.2); padding-bottom: 20px;">
          <span style="font-size: 24px; font-weight: 700; display: flex; align-items: center; gap: 12px;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path
                d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z">
              </path>
              <polyline points="7.5 4.21 12 6.81 16.5 4.21"></polyline>
              <polyline points="7.5 19.79 7.5 14.6 3 12"></polyline>
              <polyline points="21 12 16.5 14.6 16.5 19.79"></polyline>
            </svg>
            프리미엄 이미지 변환기
          </span>
        </div>
        <div class="card-body" style="padding: 24px;">

          <!-- 이미지 업로드 -->
          <div style="margin-bottom: 24px;">
            <label
              style="display: block; margin-bottom: 12px; font-weight: 600; font-size: 16px; color: rgba(255, 255, 255, 0.9);">
              📁 이미지 업로드
            </label>
            <div id="imageDropZone"
              style="border: 2px dashed rgba(255, 255, 255, 0.3); border-radius: 12px; padding: 40px 20px; text-align: center; background: rgba(255, 255, 255, 0.05); transition: all 0.3s ease; cursor: pointer;"
              ondrop="handleImageDrop(event)" ondragover="handleImageDragOver(event)"
              ondragleave="handleImageDragLeave(event)" onclick="document.getElementById('imageFileInput').click()">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                style="margin-bottom: 12px; opacity: 0.7;">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              <p style="font-size: 16px; font-weight: 500; margin-bottom: 8px;">이미지를 드래그하거나 클릭하여 업로드</p>
              <p style="font-size: 14px; color: rgba(255, 255, 255, 0.6);">JPG, PNG, GIF, WebP 지원</p>
              <input type="file" id="imageFileInput" accept="image/*" style="display: none;"
                onchange="handleImageSelect(event)">
            </div>
          </div>

          <!-- 변환 옵션 -->
          <div style="margin-bottom: 24px;">
            <label
              style="display: block; margin-bottom: 12px; font-weight: 600; font-size: 16px; color: rgba(255, 255, 255, 0.9);">
              ⚙️ 변환 옵션
            </label>

            <!-- 포맷 선택 -->
            <div style="margin-bottom: 16px;">
              <label style="display: block; margin-bottom: 8px; font-size: 14px; color: rgba(255, 255, 255, 0.8);">출력
                포맷</label>
              <select id="outputFormat"
                style="width: 100%; padding: 12px; background: linear-gradient(135deg, rgba(102, 126, 234, 0.8) 0%, rgba(118, 75, 162, 0.8) 100%); border: 2px solid rgba(255, 255, 255, 0.4); border-radius: 12px; color: white; font-size: 14px; font-weight: 600; box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);">
                <option value="jpeg" style="background: rgba(102, 126, 234, 0.9); color: white; font-weight: 600;">JPEG
                  (고품질)</option>
                <option value="png" style="background: rgba(102, 126, 234, 0.9); color: white; font-weight: 600;">PNG
                  (투명도 지원)</option>
                <option value="webp" style="background: rgba(102, 126, 234, 0.9); color: white; font-weight: 600;">WebP
                  (최적화)</option>
                <option value="gif" style="background: rgba(102, 126, 234, 0.9); color: white; font-weight: 600;">GIF
                  (애니메이션)</option>
              </select>
            </div>

            <!-- 품질 설정 -->
            <div style="margin-bottom: 16px;">
              <label style="display: block; margin-bottom: 8px; font-size: 14px; color: rgba(255, 255, 255, 0.8);">품질:
                <span id="qualityValue">85</span>%</label>
              <input type="range" id="qualitySlider" min="10" max="100" value="85"
                style="width: 100%; height: 6px; background: rgba(255, 255, 255, 0.2); border-radius: 3px; outline: none;"
                oninput="updateQualityValue(this.value)">
            </div>

            <!-- 크기 조정 -->
            <div style="margin-bottom: 16px;">
              <label style="display: block; margin-bottom: 8px; font-size: 14px; color: rgba(255, 255, 255, 0.8);">크기
                조정</label>
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
                <input type="number" id="resizeWidth" placeholder="너비"
                  style="padding: 8px; background: rgba(255, 255, 255, 0.15); border: 1px solid rgba(255, 255, 255, 0.3); border-radius: 6px; color: white; font-size: 14px;">
                <input type="number" id="resizeHeight" placeholder="높이"
                  style="padding: 8px; background: rgba(255, 255, 255, 0.15); border: 1px solid rgba(255, 255, 255, 0.3); border-radius: 6px; color: white; font-size: 14px;">
              </div>
              <label
                style="display: flex; align-items: center; gap: 8px; margin-top: 8px; font-size: 13px; color: rgba(255, 255, 255, 0.8);">
                <input type="checkbox" id="maintainRatio" checked style="width: 16px; height: 16px;">
                비율 유지
              </label>
            </div>

            <!-- 필터 효과 -->
            <div style="margin-bottom: 24px;">
              <label style="display: block; margin-bottom: 8px; font-size: 14px; color: rgba(255, 255, 255, 0.8);">필터
                효과</label>
              <select id="filterEffect"
                style="width: 100%; padding: 12px; background: linear-gradient(135deg, rgba(102, 126, 234, 0.8) 0%, rgba(118, 75, 162, 0.8) 100%); border: 2px solid rgba(255, 255, 255, 0.4); border-radius: 12px; color: white; font-size: 14px; font-weight: 600; box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);">
                <option value="none" style="background: rgba(102, 126, 234, 0.9); color: white; font-weight: 600;">원본
                </option>
                <option value="grayscale" style="background: rgba(102, 126, 234, 0.9); color: white; font-weight: 600;">
                  흑백</option>
                <option value="sepia" style="background: rgba(102, 126, 234, 0.9); color: white; font-weight: 600;">세피아
                </option>
                <option value="vintage" style="background: rgba(102, 126, 234, 0.9); color: white; font-weight: 600;">
                  빈티지</option>
                <option value="brighten" style="background: rgba(102, 126, 234, 0.9); color: white; font-weight: 600;">
                  밝게</option>
                <option value="darken" style="background: rgba(102, 126, 234, 0.9); color: white; font-weight: 600;">어둡게
                </option>
              </select>
            </div>

            <!-- 변환 버튼 -->
            <button id="convertImageBtn" onclick="convertImage()"
              style="width: 100%; padding: 18px; font-size: 18px; font-weight: 700; background: linear-gradient(135deg, #10b981 0%, #059669 100%); border: none; border-radius: 12px; color: white; cursor: not-allowed; box-shadow: 0 10px 30px rgba(16, 185, 129, 0.4); transition: all 0.3s; margin-top: 8px; opacity: 0.5;"
              onmouseover="if (!this.disabled) { this.style.transform='translateY(-2px)'; this.style.boxShadow='0 15px 40px rgba(16, 185, 129, 0.5)'; }"
              onmouseout="if (!this.disabled) { this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 30px rgba(16, 185, 129, 0.4)'; }"
              disabled>
              🔄 이미지 변환하기
            </button>
          </div>
        </div>
      </div>

      <!-- 오른쪽 미리보기 패널 -->
      <div style="position: sticky; top: 20px;">
        <div class="card"
          style="background: #1e293b; color: white; border: none; box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);">
          <div class="card-header" style="border-bottom: 2px solid rgba(255, 255, 255, 0.1); padding-bottom: 16px;">
            <span style="font-size: 18px; font-weight: 600; display: flex; align-items: center; gap: 10px;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
              변환 미리보기
            </span>
          </div>
          <div class="card-body" style="padding: 24px;">

            <!-- 원본 이미지 -->
            <div style="margin-bottom: 20px;">
              <h4 style="font-size: 14px; font-weight: 600; margin-bottom: 12px; color: rgba(255, 255, 255, 0.8);">📷 원본
              </h4>
              <div id="originalImagePreview"
                style="background: #f8fafc; border-radius: 12px; padding: 20px; min-height: 200px; display: flex; align-items: center; justify-content: center;">
                <div style="text-align: center; color: #64748b;">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"
                    style="margin: 0 auto 12px;">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                    <circle cx="8.5" cy="8.5" r="1.5"></circle>
                    <polyline points="21 15 16 10 5 21"></polyline>
                  </svg>
                  <p style="font-size: 14px;">이미지를 업로드하세요</p>
                </div>
              </div>
            </div>

            <!-- 변환된 이미지 -->
            <div style="margin-bottom: 20px;">
              <h4 style="font-size: 14px; font-weight: 600; margin-bottom: 12px; color: rgba(255, 255, 255, 0.8);">✨ 변환
                결과</h4>
              <div id="convertedImagePreview"
                style="background: #f8fafc; border-radius: 12px; padding: 20px; min-height: 200px; display: flex; align-items: center; justify-content: center;">
                <div style="text-align: center; color: #64748b;">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"
                    style="margin: 0 auto 12px;">
                    <path
                      d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z">
                    </path>
                  </svg>
                  <p style="font-size: 14px;">변환 결과가 여기에 표시됩니다</p>
                </div>
              </div>
            </div>

            <!-- 다운로드 버튼 -->
            <button id="downloadConvertedImageBtn" onclick="downloadConvertedImage()"
              style="width: 100%; padding: 16px; font-size: 16px; font-weight: 600; background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%); border: none; border-radius: 12px; color: white; cursor: pointer; margin-top: 20px; box-shadow: 0 8px 20px rgba(59, 130, 246, 0.3); transition: all 0.3s; display: none;"
              onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 12px 30px rgba(59, 130, 246, 0.4)'"
              onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 8px 20px rgba(59, 130, 246, 0.3)'">
              💾 변환된 이미지 다운로드
            </button>

            <!-- 정보 -->
            <div
              style="margin-top: 20px; padding: 16px; background: rgba(79, 172, 254, 0.1); border-radius: 12px; border-left: 4px solid #4facfe;">
              <p style="font-size: 13px; color: #cbd5e1; line-height: 1.6;">
                <strong style="color: #4facfe;">💡 Tip:</strong> 이미지 변환으로 용량 최적화, 포맷 변경, 크기 조정을 한 번에 처리할 수 있습니다.
              </p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- 포스팅 실행 탭 -->
  <div id="settings-tab" class="tab-content">
    <div style="max-width: 100%; width: 100%; position: relative;">


      <!-- 메인 컨텐츠 -->
      <div>
        <!-- 통합된 메인 포스팅 카드 -->
        <div class="card card-large"
          style="background: linear-gradient(135deg, rgba(15, 23, 42, 0.95) 0%, rgba(30, 41, 59, 0.95) 100%); color: white; border: 1px solid rgba(255, 255, 255, 0.1); box-shadow: 0 25px 80px rgba(0, 0, 0, 0.3); margin-bottom: 32px; position: relative; overflow: hidden; backdrop-filter: blur(20px);">
          <!-- 배경 장식 요소들 -->
          <div
            style="position: absolute; top: -50px; right: -50px; width: 200px; height: 200px; background: radial-gradient(circle, rgba(99, 102, 241, 0.1) 0%, transparent 70%); border-radius: 50%;">
          </div>
          <div
            style="position: absolute; bottom: -30px; left: -30px; width: 150px; height: 150px; background: radial-gradient(circle, rgba(168, 85, 247, 0.1) 0%, transparent 70%); border-radius: 50%;">
          </div>

          <div class="card-header"
            style="border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding: 24px 24px 20px 24px; position: relative; z-index: 1;">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
              <h2 class="card-title"
                style="color: white; font-size: 28px; font-weight: 700; display: flex; align-items: center; gap: 12px; margin: 0;">
                <div
                  style="background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%); padding: 12px; border-radius: 16px; box-shadow: 0 8px 32px rgba(99, 102, 241, 0.3);">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                  </svg>
                </div>
                <div>
                  <div style="font-size: 28px; font-weight: 700;">AI 블로그 포스팅</div>
                  <div style="font-size: 14px; font-weight: 500; color: rgba(255, 255, 255, 0.7); margin-top: 2px;">스마트한
                    콘텐츠 생성으로 블로그 성장</div>
                </div>
              </h2>
              <div style="display: flex; gap: 8px;">
                <span
                  style="background: rgba(16, 185, 129, 0.2); border: 1px solid rgba(16, 185, 129, 0.3); color: #10b981; padding: 6px 12px; border-radius: 12px; font-size: 12px; font-weight: 600;">
                  🤖 Gemini AI
                </span>
                <span
                  style="background: rgba(245, 158, 11, 0.2); border: 1px solid rgba(245, 158, 11, 0.3); color: #f59e0b; padding: 6px 12px; border-radius: 12px; font-size: 12px; font-weight: 600;">
                  ⭐ 프리미엄
                </span>
              </div>
            </div>
          </div>

          <div class="card-body" style="padding: 32px;">
            <!-- 상단: 키워드 입력 영역 -->
            <div
              style="background: rgba(255, 255, 255, 0.05); border-radius: 16px; padding: 24px; margin-bottom: 24px; border: 1px solid rgba(255, 255, 255, 0.1); position: relative;">
              <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
                <div
                  style="background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%); padding: 8px; border-radius: 12px;">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <circle cx="12" cy="12" r="3"></circle>
                    <path
                      d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1 1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z">
                    </path>
                  </svg>
                </div>
                <div>
                  <div style="font-size: 18px; font-weight: 700; color: white;">스마트 키워드 입력</div>
                  <div style="font-size: 12px; color: rgba(255, 255, 255, 0.7);">AI가 자동으로 매력적인 제목을 생성합니다</div>
                </div>
              </div>

              <!-- 키워드 입력 -->
              <div style="margin-bottom: 16px;">
                <label
                  style="color: rgba(255,255,255,0.9); font-weight: 600; font-size: 14px; margin-bottom: 8px; display: flex; align-items: center; gap: 8px;">🔑
                  키워드 (필수)
                  <span
                    style="background: rgba(102, 126, 234, 0.2); color: #a5b4fc; padding: 2px 8px; border-radius: 6px; font-size: 11px; font-weight: 500;">줄바꿈으로
                    여러개 입력 시 연속발행</span>
                </label>
                <textarea id="keywordInput" class="form-input" placeholder="예: 블로그 수익화 방법&#10;AI 마케팅 전략&#10;부수입 만들기"
                  rows="4"
                  style="width: 100%; background: rgba(255, 255, 255, 0.1); border: 2px solid rgba(102, 126, 234, 0.4); color: white; font-size: 15px; padding: 14px 18px; border-radius: 12px; transition: all 0.3s ease; resize: vertical; min-height: 100px; font-family: inherit; line-height: 1.6;"
                  onfocus="this.style.borderColor='rgba(102, 126, 234, 0.8)'; this.style.background='rgba(255,255,255,0.15)'"
                  onblur="this.style.borderColor='rgba(102, 126, 234, 0.4)'; this.style.background='rgba(255,255,255,0.1)'"></textarea>
              </div>

              <!-- URL 입력 (선택) -->
              <div style="margin-bottom: 16px;">
                <label
                  style="color: rgba(255,255,255,0.9); font-weight: 600; font-size: 14px; margin-bottom: 8px; display: flex; align-items: center; gap: 8px;">
                  🔗 참고 URL (선택)
                  <span
                    style="background: rgba(245, 158, 11, 0.2); color: #fbbf24; padding: 2px 8px; border-radius: 6px; font-size: 11px; font-weight: 600;">줄바꿈으로
                    여러개 입력 시 연속발행</span>
                </label>
                <textarea id="referenceUrl" class="form-input"
                  placeholder="참고할 URL을 입력하세요 (쿠팡, 네이버 쇼핑, 블로그 등)&#10;여러 URL 입력 시 키워드와 1:1 매핑&#10;예: https://example.com/product1&#10;https://example.com/product2"
                  rows="3"
                  style="width: 100%; background: rgba(255, 255, 255, 0.08); border: 2px solid rgba(245, 158, 11, 0.3); color: white; font-size: 14px; padding: 12px 16px; border-radius: 12px; transition: all 0.3s ease; resize: vertical; min-height: 80px; font-family: inherit; line-height: 1.6; box-sizing: border-box;"
                  onfocus="this.style.borderColor='rgba(245, 158, 11, 0.6)'; this.style.background='rgba(255,255,255,0.12)'"
                  onblur="this.style.borderColor='rgba(245, 158, 11, 0.3)'; this.style.background='rgba(255,255,255,0.08)'"></textarea>
                <small style="color: rgba(255,255,255,0.5); font-size: 11px; margin-top: 6px; display: block;">💡 URL을
                  입력하면 해당 페이지 내용을 참고하여 콘텐츠를 생성합니다. CTA 버튼으로도 활용됩니다.</small>
              </div>

              <div id="keywordList" style="margin-bottom: 12px; min-height: 20px;">
                <!-- 키워드별 설정이 여기에 동적으로 추가됩니다 -->
              </div>

              <small style="color: rgba(255, 255, 255, 0.6); font-size: 13px;">✨ 키워드만 입력하면 AI가 SEO 최적화된 제목과 콘텐츠를 자동
                생성합니다.</small>
            </div>

            <!-- 초안 입력 영역 (접었다 펼쳤다 가능) -->
            <div
              style="background: rgba(255, 255, 255, 0.05); border-radius: 16px; padding: 24px; margin-bottom: 24px; border: 1px solid rgba(255, 255, 255, 0.1); position: relative;">
              <div
                style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; cursor: pointer;"
                onclick="toggleDraftSection()">
                <div style="display: flex; align-items: center; gap: 12px;">
                  <div
                    style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); padding: 8px; border-radius: 12px;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                      <polyline points="14,2 14,8 20,8"></polyline>
                      <line x1="16" y1="13" x2="8" y2="13"></line>
                      <line x1="16" y1="17" x2="8" y2="17"></line>
                      <polyline points="10,9 9,9 8,9"></polyline>
                    </svg>
                  </div>
                  <div>
                    <div style="font-size: 18px; font-weight: 700; color: white;">초안 입력</div>
                    <div style="font-size: 12px; color: rgba(255, 255, 255, 0.7);">기존 글을 기반으로 새로운 콘텐츠 생성</div>
                  </div>
                </div>
                <div style="display: flex; align-items: center; gap: 8px;">
                  <span id="draftCount"
                    style="background: rgba(255,255,255,0.1); padding: 4px 8px; border-radius: 8px; font-size: 11px; font-weight: 600;">0/5000</span>
                  <svg id="draftToggleIcon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2" style="transition: transform 0.3s ease;">
                    <polyline points="6,9 12,15 18,9"></polyline>
                  </svg>
                </div>
              </div>

              <div id="draftInputSection" style="display: none;">
                <textarea id="draftInput" placeholder="기존 글의 초안을 입력하세요. AI가 이를 기반으로 새로운 콘텐츠를 생성합니다."
                  style="width: 100%; min-height: 200px; padding: 16px; background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.2); border-radius: 12px; color: white; font-size: 14px; line-height: 1.6; resize: vertical; transition: all 0.3s ease; font-family: 'Pretendard', 'Noto Sans KR', sans-serif;"
                  onfocus="this.style.background='rgba(255,255,255,0.15)'; this.style.borderColor='rgba(255,255,255,0.4)'"
                  onblur="this.style.background='rgba(255,255,255,0.1)'; this.style.borderColor='rgba(255,255,255,0.2)'"
                  oninput="updateDraftCount()"></textarea>

                <small style="color: rgba(255, 255, 255, 0.6); font-size: 13px; margin-top: 8px; display: block;">
                  • 기존 글의 내용을 참고하여 새로운 콘텐츠를 생성합니다<br>
                  • 원본의 핵심 내용은 유지하면서 새로운 구조로 재구성합니다<br>
                  • SEO 최적화된 제목과 소제목으로 자동 변환됩니다
                </small>
              </div>
            </div>

            <!-- 페러프레이징 모드용 초안 입력 영역 -->
            <div id="draftInputSection"
              style="background: rgba(255, 255, 255, 0.05); border-radius: 16px; padding: 24px; margin-bottom: 24px; border: 1px solid rgba(255, 255, 255, 0.1); position: relative; display: none;">
              <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
                <div
                  style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); padding: 8px; border-radius: 12px;">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14,2 14,8 20,8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                    <polyline points="10,9 9,9 8,9"></polyline>
                  </svg>
                </div>
                <div>
                  <div style="font-size: 18px; font-weight: 700; color: white;">초안 입력</div>
                  <div style="font-size: 12px; color: rgba(255, 255, 255, 0.7);">기존 글을 MAX 모드 구조로 페러프레이징합니다</div>
                </div>
                <span id="draftCount"
                  style="background: rgba(255,255,255,0.1); padding: 4px 8px; border-radius: 8px; font-size: 11px; font-weight: 600; margin-left: auto;">0/5000</span>
              </div>

              <textarea id="draftInput" placeholder="페러프레이징할 초안을 입력하세요. MAX 모드의 5개 섹션 구조로 재구성됩니다."
                style="width: 100%; min-height: 200px; padding: 16px; background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.2); border-radius: 12px; color: white; font-size: 14px; line-height: 1.6; resize: vertical; transition: all 0.3s ease; font-family: 'Pretendard', 'Noto Sans KR', sans-serif;"
                onfocus="this.style.background='rgba(255,255,255,0.15)'; this.style.borderColor='rgba(255,255,255,0.4)'"
                onblur="this.style.background='rgba(255,255,255,0.1)'; this.style.borderColor='rgba(255,255,255,0.2)'"
                oninput="updateDraftCount()"></textarea>

              <small style="color: rgba(255, 255, 255, 0.6); font-size: 13px; margin-top: 8px; display: block;">
                • 기존 글의 내용을 MAX 모드의 5개 섹션 구조로 재구성합니다<br>
                • 원본의 핵심 내용은 유지하면서 새로운 구조로 페러프레이징합니다<br>
                • SEO 최적화된 제목과 소제목으로 자동 변환됩니다
              </small>
            </div>

            <!-- 중간: 설정 옵션들 -->
            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin-bottom: 24px;">
              <!-- 왼쪽: 콘텐츠 설정 -->
              <div
                style="background: rgba(255, 255, 255, 0.05); border-radius: 16px; padding: 20px; border: 1px solid rgba(255, 255, 255, 0.1); position: relative;">
                <!-- 설정 카드 배경 장식 -->
                <div
                  style="position: absolute; top: -10px; right: -10px; width: 60px; height: 60px; background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%); border-radius: 50%;">
                </div>

                <h3
                  style="color: rgba(255, 255, 255, 0.95); font-size: 18px; font-weight: 700; margin-bottom: 20px; display: flex; align-items: center; gap: 12px; position: relative; z-index: 1;">
                  <div
                    style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); padding: 10px; border-radius: 12px; box-shadow: 0 6px 20px rgba(16, 185, 129, 0.3);">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                      stroke-width="2.5">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                      <polyline points="14,2 14,8 20,8"></polyline>
                      <line x1="16" y1="13" x2="8" y2="13"></line>
                      <line x1="16" y1="17" x2="8" y2="17"></line>
                      <polyline points="10,9 9,9 8,9"></polyline>
                    </svg>
                  </div>
                  <div>
                    <div style="font-size: 18px; font-weight: 700;">콘텐츠 설정</div>
                    <div style="font-size: 11px; font-weight: 500; color: rgba(255, 255, 255, 0.6); margin-top: 2px;">제목
                      & 카테고리</div>
                  </div>
                </h3>

                <div class="form-group" style="margin-bottom: 20px; position: relative; z-index: 1;">
                  <label class="form-label"
                    style="color: rgba(255, 255, 255, 0.9); font-weight: 600; font-size: 14px; margin-bottom: 10px; display: block;">제목
                    생성 모드</label>
                  <select id="titleMode" class="form-input"
                    style="background: linear-gradient(135deg, rgba(30, 41, 59, 0.95) 0%, rgba(51, 65, 85, 0.95) 100%); border: 2px solid rgba(255, 255, 255, 0.6); color: #ffffff; backdrop-filter: blur(15px); font-size: 14px; padding: 12px 16px; cursor: pointer; border-radius: 12px; width: 100%; font-weight: 600; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(30, 41, 59, 0.4);">
                    <option value="auto" style="background: #1e293b; color: #ffffff; font-weight: 600; padding: 8px;">🤖
                      자동 생성 (키워드 기반)</option>
                    <option value="custom" style="background: #1e293b; color: #ffffff; font-weight: 600; padding: 8px;">
                      ✏️ 직접 입력</option>
                  </select>
                  <!-- 직접 입력 모드 시 제목 입력 필드 -->
                  <div id="customTitleWrapper" style="display: none; margin-top: 12px;">
                    <input type="text" id="customTitle" class="form-input"
                      style="background: linear-gradient(135deg, rgba(30, 41, 59, 0.95) 0%, rgba(51, 65, 85, 0.95) 100%); border: 2px solid rgba(168, 85, 247, 0.5); color: #ffffff; backdrop-filter: blur(15px); font-size: 14px; padding: 12px 16px; border-radius: 12px; width: 100%; font-weight: 500; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(168, 85, 247, 0.15);"
                      placeholder="원하는 제목을 직접 입력하세요 (비우면 키워드가 제목으로 사용됩니다)">
                    <small style="color: rgba(168, 85, 247, 0.7); font-size: 11px; margin-top: 4px; display: block;">💡
                      키워드와 별도로 원하는 제목을 지정할 수 있습니다</small>
                  </div>
                  <script>
                    document.getElementById('titleMode').addEventListener('change', function () {
                      const w = document.getElementById('customTitleWrapper');
                      if (w) w.style.display = this.value === 'custom' ? 'block' : 'none';
                    });
                  </script>
                </div>

                <div class="form-group" style="margin-bottom: 20px; position: relative; z-index: 1;">
                  <label class="form-label"
                    style="color: rgba(255, 255, 255, 0.9); font-weight: 600; font-size: 14px; margin-bottom: 10px; display: block;">콘텐츠
                    모드</label>
                  <select id="contentMode" class="form-input"
                    style="background: linear-gradient(135deg, rgba(30, 41, 59, 0.95) 0%, rgba(51, 65, 85, 0.95) 100%); border: 2px solid rgba(255, 255, 255, 0.6); color: #ffffff; backdrop-filter: blur(15px); font-size: 14px; padding: 12px 16px; cursor: pointer; border-radius: 12px; width: 100%; font-weight: 600; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(30, 41, 59, 0.4);">
                    <option value="external"
                      style="background: #1e293b; color: #ffffff; font-weight: 600; padding: 8px;">🎯 SEO 최적화 모드/정보전달
                    </option>
                    <option value="internal"
                      style="background: #1e293b; color: #ffffff; font-weight: 600; padding: 8px;">📝 내부링크 일관성 모드/정보전달
                    </option>
                    <option value="shopping"
                      style="background: #1e293b; color: #ffffff; font-weight: 600; padding: 8px;">🛍️ 쇼핑/구매유도 모드
                    </option>
                    <option value="adsense"
                      style="background: #1e293b; color: #ffffff; font-weight: 600; padding: 8px;">🏆 에드센스승인 모드/정보전달
                    </option>
                    <option value="paraphrasing"
                      style="background: #1e293b; color: #ffffff; font-weight: 600; padding: 8px;">🔄 페러프레이징 모드 (MAX 구조)
                    </option>
                  </select>
                  <small style="color: rgba(255, 255, 255, 0.7); font-size: 12px; margin-top: 6px; display: block;">
                    <strong>SEO 최적화:</strong> SEO 최적화 제목/소제목, 검색 상위노출 중심<br>
                    <strong>일관된 글:</strong> 키워드 중심 일관된 제목/소제목, 내부 콘텐츠 연결<br>
                    <strong>쇼핑/구매유도:</strong> 클릭유도형 제목, 상품 리뷰/비교/추천 콘텐츠<br>
                    <strong>애드센스 승인:</strong> 전문성 강조, 교육적 가치 중심, 신뢰성 확보<br>
                  </small>
                </div>


                <!-- 수동 크롤링 링크 입력 -->
                <div class="form-group" style="margin-bottom: 20px; position: relative; z-index: 1;">
                  <label class="form-label"
                    style="color: rgba(255, 255, 255, 0.9); font-weight: 600; font-size: 14px; margin-bottom: 10px; display: flex; align-items: center; gap: 8px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                      <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                    </svg>
                    수동 크롤링 링크 (선택사항)
                  </label>
                  <div style="display: flex; flex-direction: column; gap: 8px;">
                    <input type="text" id="manualCrawlUrl1" class="form-input" placeholder="제품 링크 1 (예: 쿠팡, 네이버 쇼핑 등)"
                      style="background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.2); color: white; font-size: 13px; padding: 10px 14px; border-radius: 10px;">
                    <input type="text" id="manualCrawlUrl2" class="form-input" placeholder="제품 링크 2 (선택)"
                      style="background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.2); color: white; font-size: 13px; padding: 10px 14px; border-radius: 10px;">
                    <input type="text" id="manualCrawlUrl3" class="form-input" placeholder="제품 링크 3 (선택)"
                      style="background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.2); color: white; font-size: 13px; padding: 10px 14px; border-radius: 10px;">
                  </div>
                  <small style="color: rgba(255, 255, 255, 0.7); font-size: 11px; margin-top: 6px; display: block;">
                    💡 <strong style="color: #fbbf24;">크롤링 실패해도 OK!</strong> 키워드 기반으로 고품질 콘텐츠 자동 생성됩니다.<br>
                    🔗 <strong style="color: #60a5fa;">링크는 CTA 버튼으로 활용</strong> (브랜드커넥트, 쿠팡 등 모두 가능)
                  </small>
                </div>


                <div class="form-group" id="wpCategorySection" style="position: relative; z-index: 1;">
                  <label class="form-label"
                    style="color: rgba(255, 255, 255, 0.9); font-weight: 600; font-size: 14px; margin-bottom: 10px; display: block;">워드프레스
                    카테고리</label>
                  <div style="display: flex; gap: 10px;">
                    <select id="wpCategory" class="form-input"
                      style="background: linear-gradient(135deg, rgba(30, 41, 59, 0.95) 0%, rgba(51, 65, 85, 0.95) 100%); border: 2px solid rgba(255, 255, 255, 0.6); color: #ffffff; backdrop-filter: blur(15px); font-size: 14px; padding: 12px 16px; border-radius: 12px; flex: 1; font-weight: 600; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(30, 41, 59, 0.4);">
                      <option value="" style="background: #1e293b; color: #ffffff; font-weight: 600; padding: 8px;">
                        카테고리를 먼저 로드하세요</option>
                    </select>
                    <button type="button" id="loadWpCategoriesBtn"
                      onclick="if(window.loadWpCategories){window.loadWpCategories();}else if(window.loadWordPressCategories){window.loadWordPressCategories();}else{alert('카테고리 로드 기능 로딩중입니다.');}"
                      style="padding: 12px 16px; background: linear-gradient(135deg, #10b981 0%, #059669 100%); border: none; border-radius: 12px; color: white; font-size: 14px; cursor: pointer; backdrop-filter: blur(15px); transition: all 0.3s ease; box-shadow: 0 6px 20px rgba(16, 185, 129, 0.3);">
                      🔄
                    </button>
                  </div>
                  <small
                    style="color: rgba(255, 255, 255, 0.7); font-size: 12px; margin-top: 6px; display: block;">워드프레스 연결
                    정보를 입력한 후 카테고리를 로드하세요</small>
                </div>
              </div>

              <!-- 가운데: 이미지 설정 -->
              <div
                style="background: rgba(255, 255, 255, 0.12); border-radius: 16px; padding: 24px; backdrop-filter: blur(15px); border: 2px solid rgba(255, 255, 255, 0.2); position: relative; overflow: hidden;">
                <!-- 설정 카드 배경 장식 -->
                <div
                  style="position: absolute; top: -10px; right: -10px; width: 60px; height: 60px; background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%); border-radius: 50%;">
                </div>

                <h3
                  style="color: rgba(255, 255, 255, 0.95); font-size: 18px; font-weight: 700; margin-bottom: 20px; display: flex; align-items: center; gap: 12px; position: relative; z-index: 1;">
                  <div
                    style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); padding: 10px; border-radius: 12px; box-shadow: 0 6px 20px rgba(245, 158, 11, 0.3);">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                      stroke-width="2.5">
                      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                      <circle cx="8.5" cy="8.5" r="1.5"></circle>
                      <polyline points="21,15 16,10 5,21"></polyline>
                    </svg>
                  </div>
                  <div>
                    <div style="font-size: 18px; font-weight: 700;">이미지 설정</div>
                    <div style="font-size: 11px; font-weight: 500; color: rgba(255, 255, 255, 0.6); margin-top: 2px;">
                      썸네일 & 이미지</div>
                  </div>
                </h3>

                <div class="form-group" style="margin-bottom: 20px; position: relative; z-index: 1;">
                  <label class="form-label"
                    style="color: rgba(255, 255, 255, 0.9); font-weight: 600; font-size: 14px; margin-bottom: 10px; display: block;">썸네일
                    타입</label>
                  <select id="thumbnailType" class="form-input"
                    style="background: linear-gradient(135deg, rgba(30, 41, 59, 0.95) 0%, rgba(51, 65, 85, 0.95) 100%); border: 2px solid rgba(255, 255, 255, 0.6); color: #ffffff; backdrop-filter: blur(15px); font-size: 14px; padding: 12px 16px; cursor: pointer; border-radius: 12px; width: 100%; font-weight: 600; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(30, 41, 59, 0.4);">
                    <option value="svg" selected
                      style="background: #1e293b; color: #ffffff; font-weight: 600; padding: 8px;">📝 SVG 썸네일 (기본)
                    </option>
                    <option value="nanobananapro"
                      style="background: #1e293b; color: #ffffff; font-weight: 600; padding: 8px;">🍌 Nano Banana Pro
                    </option>
                    <option value="text" style="background: #1e293b; color: #ffffff; font-weight: 600; padding: 8px;">🎨
                      텍스트 썸네일</option>
                    <option value="cse" style="background: #1e293b; color: #ffffff; font-weight: 600; padding: 8px;">🔍
                      CSE 이미지 검색</option>
                    <option value="deepinfra"
                      style="background: #1e293b; color: #ffffff; font-weight: 600; padding: 8px;">
                      🔥 DeepInfra FLUX-2</option>
                    <option value="stability"
                      style="background: #1e293b; color: #ffffff; font-weight: 600; padding: 8px;">
                      🚀 Stability AI</option>
                    <option value="pollinations"
                      style="background: #1e293b; color: #ffffff; font-weight: 600; padding: 8px;">
                      🌸 Pollinations (무료)</option>
                    <option value="none" style="background: #1e293b; color: #ffffff; font-weight: 600; padding: 8px;">❌
                      썸네일 없음</option>
                  </select>
                </div>

                <div class="form-group" style="margin-bottom: 20px; position: relative; z-index: 1;">
                  <label class="form-label"
                    style="color: rgba(255, 255, 255, 0.9); font-weight: 600; font-size: 14px; margin-bottom: 10px; display: block;">🎭
                    말투/어투 선택</label>
                  <select id="toneStyle" class="form-input"
                    style="background: linear-gradient(135deg, rgba(30, 41, 59, 0.95) 0%, rgba(51, 65, 85, 0.95) 100%); border: 2px solid rgba(255, 255, 255, 0.6); color: #ffffff; backdrop-filter: blur(15px); font-size: 14px; padding: 12px 16px; cursor: pointer; border-radius: 12px; width: 100%; font-weight: 600; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(30, 41, 59, 0.4);">
                    <option value="professional" selected
                      style="background: #1e293b; color: #ffffff; font-weight: 600; padding: 8px;">💼 전문적</option>
                    <option value="friendly"
                      style="background: #1e293b; color: #ffffff; font-weight: 600; padding: 8px;">😊 친근한</option>
                    <option value="casual" style="background: #1e293b; color: #ffffff; font-weight: 600; padding: 8px;">
                      😎 캐주얼</option>
                    <option value="formal" style="background: #1e293b; color: #ffffff; font-weight: 600; padding: 8px;">
                      🎩 격식있는</option>
                    <option value="conversational"
                      style="background: #1e293b; color: #ffffff; font-weight: 600; padding: 8px;">💬 대화체</option>
                  </select>
                </div>

                <!-- H2 이미지 선택 (자동 배치) -->
                <div class="form-group" style="margin-bottom: 20px; position: relative; z-index: 1;">
                  <label class="form-label"
                    style="color: rgba(255, 255, 255, 0.9); font-weight: 600; font-size: 14px; margin-bottom: 10px; display: block;">🖼️
                    H2 섹션 이미지</label>
                  <select id="h2ImageSource" class="form-input"
                    style="background: linear-gradient(135deg, rgba(16, 185, 129, 0.9) 0%, rgba(5, 150, 105, 0.9) 100%); border: 2px solid rgba(16, 185, 129, 0.8); color: #ffffff; backdrop-filter: blur(15px); font-size: 13px; padding: 12px 14px; cursor: pointer; border-radius: 12px; width: 100%; font-weight: 700; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4);">
                    <option value="nanobananapro" selected
                      style="background: #166534; color: #ffffff; font-weight: 700;">🍌 Nano Banana Pro (빠름)</option>
                    <option value="deepinfra" style="background: #dc2626; color: #ffffff; font-weight: 700;">🔥
                      DeepInfra FLUX-2
                      (고품질)</option>
                    <option value="stability" style="background: #1e293b; color: #ffffff; font-weight: 700;">🚀
                      Stability AI</option>
                    <option value="pollinations" style="background: #1e293b; color: #ffffff; font-weight: 700;">🌸
                      Pollinations (무료)</option>
                    <option value="none" style="background: #1e293b; color: #ffffff; font-weight: 700;">❌ 이미지 없음
                    </option>
                  </select>
                  <p style="margin: 8px 0 0 0; font-size: 11px; color: rgba(255, 255, 255, 0.7);">💡 모든 H2 섹션에 자동으로 이미지가
                    배치됩니다</p>
                </div>

              </div>

              <!-- 오른쪽: 발행 설정 -->
              <div
                style="background: rgba(255, 255, 255, 0.12); border-radius: 16px; padding: 24px; backdrop-filter: blur(15px); border: 2px solid rgba(255, 255, 255, 0.2); position: relative; overflow: hidden;">
                <!-- 설정 카드 배경 장식 -->
                <div
                  style="position: absolute; top: -10px; right: -10px; width: 60px; height: 60px; background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%); border-radius: 50%;">
                </div>

                <h3
                  style="color: rgba(255, 255, 255, 0.95); font-size: 18px; font-weight: 700; margin-bottom: 20px; display: flex; align-items: center; gap: 12px; position: relative; z-index: 1;">
                  <div
                    style="background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); padding: 10px; border-radius: 12px; box-shadow: 0 6px 20px rgba(239, 68, 68, 0.3);">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                      stroke-width="2.5">
                      <circle cx="12" cy="12" r="10"></circle>
                      <polygon points="10 8 16 12 10 16 10 8"></polygon>
                    </svg>
                  </div>
                  <div>
                    <div style="font-size: 18px; font-weight: 700;">발행 설정</div>
                    <div style="font-size: 11px; font-weight: 500; color: rgba(255, 255, 255, 0.6); margin-top: 2px;">모드
                      & CTA</div>
                  </div>
                </h3>

                <div class="form-group" style="margin-bottom: 20px; position: relative; z-index: 1;">
                  <label class="form-label"
                    style="color: rgba(255, 255, 255, 0.9); font-weight: 600; font-size: 14px; margin-bottom: 12px; display: block;">포스팅
                    모드</label>
                  <div style="display: flex; flex-direction: column; gap: 10px;">
                    <label
                      style="display: flex; align-items: center; gap: 12px; cursor: pointer; font-size: 14px; color: rgba(255, 255, 255, 0.95); padding: 8px 12px; background: rgba(255,255,255,0.08); border-radius: 10px; transition: all 0.3s ease; border: 2px solid transparent;">
                      <input type="radio" name="postingMode" value="immediate" checked
                        onchange="toggleScheduleSettings()"
                        style="width: 16px; height: 16px; cursor: pointer; accent-color: #ef4444;">
                      <span style="font-weight: 500;">🚀 즉시 발행</span>
                    </label>
                    <label
                      style="display: flex; align-items: center; gap: 12px; cursor: pointer; font-size: 14px; color: rgba(255, 255, 255, 0.95); padding: 8px 12px; background: rgba(255,255,255,0.08); border-radius: 10px; transition: all 0.3s ease; border: 2px solid transparent;">
                      <input type="radio" name="postingMode" value="draft" onchange="toggleScheduleSettings()"
                        style="width: 16px; height: 16px; cursor: pointer; accent-color: #ef4444;">
                      <span style="font-weight: 500;">📝 임시 발행</span>
                    </label>
                    <label
                      style="display: flex; align-items: center; gap: 12px; cursor: pointer; font-size: 14px; color: rgba(255, 255, 255, 0.95); padding: 8px 12px; background: rgba(255,255,255,0.08); border-radius: 10px; transition: all 0.3s ease; border: 2px solid transparent;">
                      <input type="radio" name="postingMode" value="schedule" onchange="toggleScheduleSettings()"
                        style="width: 16px; height: 16px; cursor: pointer; accent-color: #ef4444;">
                      <span style="font-weight: 500;">⏰ 예약 발행</span>
                    </label>
                  </div>
                </div>

                <!-- 예약 설정 (스케줄 모드 선택 시 표시) -->
                <div id="scheduleSettings" class="form-group"
                  style="margin-bottom: 20px; position: relative; z-index: 1; display: none;">
                  <label class="form-label"
                    style="color: rgba(255, 255, 255, 0.9); font-weight: 600; font-size: 14px; margin-bottom: 12px; display: block;">예약
                    시간</label>
                  <input type="datetime-local" id="scheduleDateTime"
                    style="width: 100%; padding: 12px 16px; background: rgba(255, 255, 255, 0.1); border: 2px solid rgba(255, 255, 255, 0.2); border-radius: 12px; color: white; font-size: 14px; transition: all 0.3s ease; box-sizing: border-box;"
                    onfocus="this.style.borderColor='#ef4444'; this.style.background='rgba(255, 255, 255, 0.15)'"
                    onblur="this.style.borderColor='rgba(255, 255, 255, 0.2)'; this.style.background='rgba(255, 255, 255, 0.1)'">
                </div>

                <div class="form-group" style="position: relative; z-index: 1;">
                  <label class="form-label"
                    style="color: rgba(255, 255, 255, 0.9); font-weight: 600; font-size: 14px; margin-bottom: 12px; display: block;">CTA
                    옵션</label>
                  <div style="display: flex; gap: 16px;">
                    <label
                      style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 14px; color: rgba(255, 255, 255, 0.95); padding: 8px 16px; background: rgba(255,255,255,0.08); border-radius: 10px; transition: all 0.3s ease; border: 2px solid transparent; font-weight: 500;">
                      <input type="radio" name="ctaMode" value="auto" checked onchange="toggleCtaSettings()"
                        style="width: 16px; height: 16px; cursor: pointer; accent-color: #ef4444;">
                      🤖 자동
                    </label>
                    <label
                      style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 14px; color: rgba(255, 255, 255, 0.95); padding: 8px 16px; background: rgba(255,255,255,0.08); border-radius: 10px; transition: all 0.3s ease; border: 2px solid transparent; font-weight: 500;">
                      <input type="radio" name="ctaMode" value="manual" onchange="toggleCtaSettings()"
                        style="width: 16px; height: 16px; cursor: pointer; accent-color: #ef4444;">
                      ✏️ 수동
                    </label>
                  </div>
                </div>

                <!-- 수동 CTA 설정 버튼 (수동 선택 시 표시) -->
                <div id="manualCtaSection" class="form-group" style="margin-top: 20px; display: none;">
                  <button type="button" onclick="openManualCtaModal()"
                    style="width: 100%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 12px; padding: 14px 24px; font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);">
                    🔗 소제목별 CTA 설정하기
                  </button>
                  <small style="color: rgba(255, 255, 255, 0.7); font-size: 12px; margin-top: 6px; display: block;">
                    소제목 5개에 대해 개별 CTA 링크를 설정할 수 있습니다 (공란 가능)
                  </small>
                  <div id="manualCtaStatus"
                    style="margin-top: 10px; padding: 10px; background: rgba(59, 130, 246, 0.1); border-radius: 8px; font-size: 12px; color: rgba(255, 255, 255, 0.8); display: none;">
                    ✅ <span id="manualCtaCount">0</span>개의 수동 CTA가 설정되었습니다
                  </div>
                </div>
              </div>
            </div>

            <!-- 하단: 발행 버튼 -->
            <div
              style="background: rgba(255, 255, 255, 0.1); border-radius: 20px; padding: 32px; backdrop-filter: blur(10px); border: 2px solid rgba(255, 255, 255, 0.2);">

              <!-- 초보자 가이드 버튼 -->
              <div style="text-align: center; margin-bottom: 20px;">
                <button onclick="showGuide('api-keys')"
                  style="padding: 12px 24px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; border-radius: 12px; color: white; font-size: 14px; font-weight: 700; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4); display: inline-flex; align-items: center; gap: 8px;"
                  onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(102, 126, 234, 0.5)';"
                  onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 15px rgba(102, 126, 234, 0.4)';">
                  <span style="font-size: 18px;">📚</span>
                  <span>초보자 가이드</span>
                </button>
              </div>

              <!-- 메인 발행 버튼 -->
              <div style="text-align: center; margin-bottom: 20px;">
                <button class="btn btn-success" onclick="publishToPlatform()" id="publishBtn"
                  style="width: 100% !important; max-width: 100% !important; padding: 28px 36px !important; background: linear-gradient(135deg, #ffd700 0%, #ffb347 50%, #ff8c00 100%) !important; border: 3px solid rgba(255, 255, 255, 0.4) !important; border-radius: 20px !important; color: #1e293b !important; font-size: 20px !important; font-weight: 900 !important; cursor: pointer !important; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important; box-shadow: 0 20px 60px rgba(255, 215, 0, 0.6), 0 8px 25px rgba(255, 179, 71, 0.5), inset 0 2px 0 rgba(255, 255, 255, 0.5) !important; position: relative !important; overflow: hidden !important; letter-spacing: 1.5px !important; text-transform: uppercase !important; margin: 0 auto !important; display: block !important; min-height: 100px !important; height: 100px !important;"
                  onmouseover="this.style.transform='translateY(-4px) scale(1.02)'; this.style.boxShadow='0 25px 70px rgba(255, 215, 0, 0.7), 0 12px 35px rgba(255, 179, 71, 0.6), inset 0 2px 0 rgba(255, 255, 255, 0.6)';"
                  onmouseout="this.style.transform='translateY(0) scale(1)'; this.style.boxShadow='0 20px 60px rgba(255, 215, 0, 0.6), 0 8px 25px rgba(255, 179, 71, 0.5), inset 0 2px 0 rgba(255, 255, 255, 0.5)';">
                  <div
                    style="position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent); animation: shimmer 3s infinite;">
                  </div>
                  <span
                    style="position: relative; z-index: 1; display: flex; align-items: center; justify-content: center; gap: 16px;">
                    <span style="font-size: 32px; animation: pulse 2s infinite;">🚀</span>
                    <span style="text-shadow: 0 2px 8px rgba(0,0,0,0.2), 0 4px 16px rgba(255,255,255,0.3);">완전 자동화 고품질
                      블로그 발행 시작</span>
                    <span style="font-size: 28px; animation: pulse 2s infinite 0.5s;">✨</span>
                  </span>
                </button>
                <div
                  style="font-size: 14px; color: rgba(255, 255, 255, 0.9); text-align: center; margin-top: 16px; font-weight: 700; text-shadow: 0 2px 8px rgba(0,0,0,0.4);">
                  🎯 클릭 한 번으로 AI가 콘텐츠 생성부터 발행까지 자동 처리합니다
                </div>
              </div>

              <!-- 작업 중단 버튼 -->
              <div style="text-align: center;">
                <button class="btn btn-secondary" onclick="cancelProgress()" id="cancelBtn"
                  style="width: 100%; max-width: 500px; padding: 14px 24px; background: rgba(239, 68, 68, 0.8); border: none; border-radius: 12px; color: white; font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.3s ease; display: none; box-shadow: 0 8px 25px rgba(239, 68, 68, 0.3); margin: 0 auto;">
                  ❌ 작업 중단
                </button>
              </div>

              <!-- 수동 CTA 설정 (접을 수 있는 섹션) -->
              <div id="manualCtaSettings"
                style="display: none; margin-top: 32px; padding-top: 32px; border-top: 2px solid rgba(255, 255, 255, 0.1);">
                <div style="background: rgba(255, 255, 255, 0.05); border-radius: 16px; padding: 24px;">
                  <label
                    style="color: rgba(255, 255, 255, 0.9); font-weight: 600; font-size: 16px; margin-bottom: 16px; display: block;">
                    📌 수동 CTA 설정
                  </label>
                  <div id="ctaItemsList" style="display: flex; flex-direction: column; gap: 12px; margin-bottom: 16px;">
                    <!-- CTA 항목들이 여기에 동적으로 추가됩니다 -->
                  </div>
                  <button onclick="addCtaItem()"
                    style="width: 100%; padding: 12px 16px; background: rgba(255, 255, 255, 0.15); border: 2px dashed rgba(255, 255, 255, 0.3); border-radius: 10px; color: rgba(255, 255, 255, 0.9); font-size: 14px; font-weight: 600; cursor: pointer; backdrop-filter: blur(10px); transition: all 0.3s ease;">
                    + CTA 항목 추가
                  </button>
                </div>
              </div>

              <style>
                @keyframes pulse {

                  0%,
                  100% {
                    transform: scale(1);
                  }

                  50% {
                    transform: scale(1.15);
                  }
                }
              </style>
            </div>
          </div>
        </div>

        <!-- 발행 로그 카드 -->
        <div class="card"
          style="background: linear-gradient(135deg, #1e293b 0%, #334155 100%); color: white; border: 2px solid rgba(255, 255, 255, 0.1); box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);">
          <div class="card-header" style="border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding: 16px 24px;">
            <h2 class="card-title"
              style="color: white; font-size: 18px; font-weight: 700; display: flex; align-items: center; gap: 10px; margin: 0;">
              <span style="font-size: 20px;">📋</span>
              발행 로그
            </h2>
          </div>

          <div class="card-body" style="padding: 32px;">
            <!-- 구 프로그레스 바 (레거시) -->
            <div id="progressContainer" style="display: none; margin-bottom: 24px;">
              <div
                style="background: rgba(255, 255, 255, 0.2); border-radius: 12px; height: 32px; overflow: hidden; backdrop-filter: blur(10px); border: 2px solid rgba(255, 255, 255, 0.3);">
                <div class="progress-fill" id="progressFillLegacy"
                  style="height: 100%; background: linear-gradient(90deg, rgba(255, 255, 255, 0.5), rgba(255, 255, 255, 0.8)); transition: width 0.3s ease; display: flex; align-items: center; justify-content: flex-end; padding-right: 16px;">
                  <span id="progressTextLegacy"
                    style="font-weight: 700; font-size: 16px; color: rgba(102, 126, 234, 1);">0%</span>
                </div>
              </div>
            </div>

            <!-- 🚀 완전자동 발행 고급 모달 (센터, 적당한 크기) -->
            <div id="premiumProgressBar" class="premium-progress-bar"
              style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.85); backdrop-filter: blur(20px); z-index: 50000; align-items: center; justify-content: center; padding: 20px;">
              <div
                style="width: 90%; max-width: 650px; background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border-radius: 24px; padding: 36px; border: 3px solid rgba(102, 126, 234, 0.5); box-shadow: 0 40px 100px rgba(0, 0, 0, 0.6), 0 0 80px rgba(102, 126, 234, 0.3); position: relative; overflow: hidden; margin: auto;">

                <!-- 배경 글로우 -->
                <div
                  style="position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: radial-gradient(circle, rgba(102, 126, 234, 0.1) 0%, transparent 70%); pointer-events: none;">
                </div>

                <!-- 헤더 -->
                <div
                  style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; position: relative; z-index: 2;">
                  <div style="display: flex; align-items: center; gap: 16px;">
                    <div
                      style="width: 60px; height: 60px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 18px; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 30px rgba(102, 126, 234, 0.5), inset 0 0 20px rgba(255,255,255,0.2);">
                      <span style="font-size: 32px; animation: pulse 2s infinite;">⚡</span>
                    </div>
                    <div>
                      <div
                        style="font-size: 22px; font-weight: 800; color: white; text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);">
                        AI 콘텐츠 생성 중</div>
                      <div style="font-size: 13px; color: rgba(255, 255, 255, 0.6); margin-top: 4px;">완전자동 발행 모드</div>
                    </div>
                  </div>
                  <button onclick="hideProgressModal()"
                    style="width: 46px; height: 46px; background: rgba(255, 255, 255, 0.1); border: 2px solid rgba(255, 255, 255, 0.2); color: rgba(255, 255, 255, 0.8); border-radius: 14px; cursor: pointer; font-size: 20px; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease;"
                    onmouseover="this.style.background='rgba(239, 68, 68, 0.8)'; this.style.transform='rotate(90deg) scale(1.1)';"
                    onmouseout="this.style.background='rgba(255, 255, 255, 0.1)'; this.style.transform='rotate(0deg) scale(1)';">✕</button>
                </div>

                <!-- 진행률 원형 표시 + 텍스트 -->
                <div
                  style="display: flex; align-items: center; gap: 24px; margin-bottom: 28px; position: relative; z-index: 2;">
                  <div style="position: relative; width: 160px; height: 160px; flex-shrink: 0;">
                    <svg width="160" height="160" style="transform: rotate(-90deg);">
                      <circle cx="80" cy="80" r="68" stroke="rgba(255,255,255,0.1)" stroke-width="14" fill="none" />
                      <circle id="progressCircle" cx="80" cy="80" r="68" stroke="url(#progressGradient)"
                        stroke-width="14" fill="none" stroke-linecap="round" stroke-dasharray="427"
                        stroke-dashoffset="427"
                        style="transition: stroke-dashoffset 0.8s cubic-bezier(0.4, 0, 0.2, 1); filter: drop-shadow(0 0 15px rgba(102, 126, 234, 0.5));" />
                      <defs>
                        <linearGradient id="progressGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                          <stop offset="0%" style="stop-color:#667eea" />
                          <stop offset="50%" style="stop-color:#764ba2" />
                          <stop offset="100%" style="stop-color:#f093fb" />
                        </linearGradient>
                      </defs>
                    </svg>
                    <div id="progressPercentage"
                      style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 40px; font-weight: 900; color: white; text-shadow: 0 4px 15px rgba(0,0,0,0.3);">
                      0%</div>
                  </div>
                  <div style="flex: 1;">
                    <div id="progressStep"
                      style="font-size: 16px; color: white; font-weight: 600; margin-bottom: 10px;">작업 준비 중...</div>
                    <div style="display: flex; gap: 24px; font-size: 13px; color: rgba(255, 255, 255, 0.7);">
                      <span id="progressTime">⏱ 경과: 00:00</span>
                      <span id="estimatedTime">--:--</span>
                    </div>
                  </div>
                </div>

                <!-- 막대 진행률 바 -->
                <div style="margin-bottom: 28px; position: relative; z-index: 2;">
                  <div
                    style="background: rgba(255, 255, 255, 0.1); border-radius: 12px; height: 16px; overflow: hidden;">
                    <div id="progressFill"
                      style="height: 100%; width: 0%; background: linear-gradient(90deg, #667eea 0%, #764ba2 50%, #f093fb 100%); border-radius: 12px; transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1); position: relative;">
                      <div
                        style="position: absolute; top: 0; left: -100%; width: 200%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent); animation: shimmer 2s infinite;">
                      </div>
                    </div>
                  </div>
                </div>

                <!-- 단계 표시 -->
                <div
                  style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-bottom: 28px; position: relative; z-index: 2;">
                  <div class="progress-stage" data-stage="crawl"
                    style="text-align: center; padding: 14px 10px; background: rgba(255,255,255,0.05); border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); transition: all 0.4s ease;">
                    <div style="font-size: 24px; margin-bottom: 6px;">🔍</div>
                    <div style="font-size: 11px; color: rgba(255,255,255,0.5); font-weight: 600;">크롤링</div>
                  </div>
                  <div class="progress-stage" data-stage="title"
                    style="text-align: center; padding: 14px 10px; background: rgba(255,255,255,0.05); border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); transition: all 0.4s ease;">
                    <div style="font-size: 24px; margin-bottom: 6px;">📝</div>
                    <div style="font-size: 11px; color: rgba(255,255,255,0.5); font-weight: 600;">제목</div>
                  </div>
                  <div class="progress-stage" data-stage="structure"
                    style="text-align: center; padding: 14px 10px; background: rgba(255,255,255,0.05); border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); transition: all 0.4s ease;">
                    <div style="font-size: 24px; margin-bottom: 6px;">📑</div>
                    <div style="font-size: 11px; color: rgba(255,255,255,0.5); font-weight: 600;">구조</div>
                  </div>
                  <div class="progress-stage" data-stage="content"
                    style="text-align: center; padding: 14px 10px; background: rgba(255,255,255,0.05); border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); transition: all 0.4s ease;">
                    <div style="font-size: 24px; margin-bottom: 6px;">✍️</div>
                    <div style="font-size: 11px; color: rgba(255,255,255,0.5); font-weight: 600;">본문</div>
                  </div>
                  <div class="progress-stage" data-stage="publish"
                    style="text-align: center; padding: 14px 10px; background: rgba(255,255,255,0.05); border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); transition: all 0.4s ease;">
                    <div style="font-size: 24px; margin-bottom: 6px;">🚀</div>
                    <div style="font-size: 11px; color: rgba(255,255,255,0.5); font-weight: 600;">발행</div>
                  </div>
                </div>

                <!-- 로그 영역 (스크롤 가능) -->
                <div
                  style="background: rgba(0,0,0,0.4); border-radius: 14px; padding: 20px; max-height: 250px; overflow-y: auto; position: relative; z-index: 2; border: 1px solid rgba(255,255,255,0.1);">
                  <div id="progressLogContent"
                    style="font-family: 'Consolas', 'Monaco', monospace; font-size: 13px; line-height: 1.8; color: rgba(255,255,255,0.7);">
                    <div style="color: #60a5fa;">🚀 발행 준비 중...</div>
                  </div>
                </div>
              </div>
            </div>

            <style>
              .progress-stage.active {
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
                box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
              }

              .progress-stage.active div {
                color: white !important;
              }

              .progress-stage.completed {
                background: linear-gradient(135deg, #10b981 0%, #059669 100%) !important;
              }

              .progress-stage.completed div {
                color: white !important;
              }
            </style>

            <!-- 알림 시스템 (중앙, 초록색) -->
            <div id="notificationContainer"
              style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 20000; pointer-events: none; display: none;">
              <div id="notificationMessage"
                style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white; padding: 16px 32px; border-radius: 12px; font-size: 16px; font-weight: 600; box-shadow: 0 10px 30px rgba(16, 185, 129, 0.4); backdrop-filter: blur(10px); border: 2px solid rgba(255, 255, 255, 0.3); animation: notificationSlideIn 0.3s ease-out;">
              </div>
            </div>

            <!-- 로그 컨테이너 (접힘/펼침) -->
            <div style="margin-top: 16px;">
              <div onclick="toggleLogContainer()"
                style="display: flex; align-items: center; gap: 10px; padding: 12px 16px; background: rgba(255, 255, 255, 0.1); border-radius: 10px 10px 0 0; cursor: pointer; border: 2px solid rgba(255, 255, 255, 0.2); border-bottom: none;">
                <span id="logToggleIcon" style="font-size: 14px; transition: transform 0.3s;">▶</span>
                <span style="color: rgba(255,255,255,0.9); font-weight: 600; font-size: 14px;">📋 발행 로그</span>
                <span style="color: rgba(255,255,255,0.5); font-size: 12px; margin-left: auto;">클릭하여 펼치기/접기</span>
              </div>
              <div id="logContainer"
                style="display: none; max-height: 400px; min-height: 200px; overflow-y: auto; background: rgba(255, 255, 255, 0.15); padding: 20px; border-radius: 0 0 12px 12px; backdrop-filter: blur(10px); border: 2px solid rgba(255, 255, 255, 0.3); border-top: none;">
                <div id="logContent">
                  <div style="text-align: center; padding: 60px 20px;">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                      style="opacity: 0.5; margin-bottom: 16px;">
                      <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
                    </svg>
                    <p style="color: rgba(255, 255, 255, 0.8); font-size: 16px; font-weight: 500;">포스팅을 시작하면 실시간 진행 상황이
                      여기에 표시됩니다.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 발행글 목록 모달 -->
      <div id="publishedPostsModal"
        style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.7); z-index: 10001; backdrop-filter: blur(10px);">
        <div
          style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 90%; max-width: 1000px; max-height: 80vh; background: linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 250, 252, 0.98) 100%); border-radius: 24px; padding: 40px; box-shadow: 0 30px 90px rgba(0, 0, 0, 0.3); overflow-y: auto;">
          <!-- 모달 헤더 -->
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px;">
            <h2
              style="font-size: 32px; font-weight: 900; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); background-clip: text; -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin: 0;">
              📚 발행글 목록
            </h2>
            <button onclick="closePublishedPostsModal()"
              style="background: #ef4444; color: white; border: none; width: 40px; height: 40px; border-radius: 50%; font-size: 20px; cursor: pointer; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 15px rgba(239, 68, 68, 0.3);">
              ✕
            </button>
          </div>

          <!-- 모달 바디 -->
          <div id="publishedPostsList" style="display: grid; gap: 16px;">
            <!-- 발행글 목록이 여기에 동적으로 추가됩니다 -->
          </div>
        </div>
      </div>

      <!-- 환경 설정 카드들 (숨김 처리) -->
      <div style="display: none;">

        <!-- API 키 설정 카드 -->
        <div class="card card-large"
          style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; box-shadow: 0 20px 60px rgba(102, 126, 234, 0.3);">
          <div class="card-header" style="border-bottom: 2px solid rgba(255, 255, 255, 0.2); padding-bottom: 20px;">
            <h2 class="card-title"
              style="color: white; font-size: 24px; font-weight: 700; display: flex; align-items: center; gap: 12px;">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path
                  d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4">
                </path>
              </svg>
              API 키 설정
            </h2>
          </div>

          <div class="card-body" style="padding: 24px;">
            <!-- AI 모델 API 키들 -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px;">
              <div class="form-group">
                <label class="form-label"
                  style="color: rgba(255, 255, 255, 0.9); font-weight: 600; display: flex; align-items: center; gap: 8px;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="3"></circle>
                    <path d="M12 1v6m0 6v6m11-7h-6m-6 0H1"></path>
                  </svg>
                  Gemini API
                </label>
                <input type="text" id="geminiKey" class="form-input" placeholder="AIza..."
                  style="background: rgba(255, 255, 255, 0.15); border: 2px solid rgba(255, 255, 255, 0.3); color: white; backdrop-filter: blur(10px);">
                <small class="form-text" style="color: rgba(255, 255, 255, 0.7);">Google AI Studio에서 발급</small>
              </div>

              <div class="form-group">
                <label class="form-label"
                  style="color: rgba(255, 255, 255, 0.9); font-weight: 600; display: flex; align-items: center; gap: 8px;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path
                      d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z">
                    </path>
                    <polyline points="3.27,6.96 12,12.01 20.73,6.96"></polyline>
                    <line x1="12" y1="22.08" x2="12" y2="12"></line>
                  </svg>
                  OpenAI API 키
                </label>
                <input type="text" id="openaiApiKey" class="form-input" placeholder="sk-..."
                  style="background: rgba(255, 255, 255, 0.15); border: 2px solid rgba(255, 255, 255, 0.3); color: white; backdrop-filter: blur(10px);">
                <small class="form-text" style="color: rgba(255, 255, 255, 0.7);">OpenAI Platform에서 발급</small>
              </div>

              <div class="form-group">
                <label class="form-label"
                  style="color: rgba(255, 255, 255, 0.9); font-weight: 600; display: flex; align-items: center; gap: 8px;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                    <circle cx="8.5" cy="8.5" r="1.5"></circle>
                    <polyline points="21 15 16 10 5 21"></polyline>
                  </svg>
                  Pexels API
                </label>
                <input type="text" id="pexelsApiKey" class="form-input" placeholder="Pexels API 키"
                  style="background: rgba(255, 255, 255, 0.15); border: 2px solid rgba(255, 255, 255, 0.3); color: white; backdrop-filter: blur(10px);">
                <small class="form-text" style="color: rgba(255, 255, 255, 0.7);">무료 이미지 검색 (월 20,000회 무료)</small>
              </div>

              <div class="form-group">
                <label class="form-label"
                  style="color: rgba(255, 255, 255, 0.9); font-weight: 600; display: flex; align-items: center; gap: 8px;">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path
                      d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4">
                    </path>
                  </svg>
                  DALL-E API
                </label>
                <input type="text" id="dalleApiKey" class="form-input" placeholder="OpenAI DALL-E API 키"
                  style="background: rgba(255, 255, 255, 0.15); border: 2px solid rgba(255, 255, 255, 0.3); color: white; backdrop-filter: blur(10px);">
                <small class="form-text" style="color: rgba(255, 255, 255, 0.7);">AI 이미지 생성 (유료)</small>
              </div>

              <div class="form-group">
                <label class="form-label"
                  style="color: rgba(255, 255, 255, 0.9); font-weight: 600; display: flex; align-items: center; gap: 8px;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path
                      d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z">
                    </path>
                    <polyline points="3.27,6.96 12,12.01 20.73,6.96"></polyline>
                    <line x1="12" y1="22.08" x2="12" y2="12"></line>
                  </svg>
                  오픈 API 키
                </label>
                <input type="text" id="openApiKey" class="form-input" placeholder="오픈 API 키"
                  style="background: rgba(255, 255, 255, 0.15); border: 2px solid rgba(255, 255, 255, 0.3); color: white; backdrop-filter: blur(10px);">
                <small class="form-text" style="color: rgba(255, 255, 255, 0.7);">추가 API 키</small>
              </div>
            </div>

            <!-- Google CSE 설정 -->
            <div style="border-top: 2px solid rgba(255, 255, 255, 0.2); padding-top: 20px;">
              <h3
                style="color: white; font-size: 18px; font-weight: 600; margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="11" cy="11" r="8"></circle>
                  <path d="M21 21l-4.35-4.35"></path>
                </svg>
                Google 검색 설정
              </h3>

              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div class="form-group">
                  <label class="form-label" style="color: rgba(255, 255, 255, 0.9); font-weight: 600;">Google CSE
                    Key</label>
                  <input type="text" id="googleCseKey" class="form-input" placeholder="AIza..."
                    style="background: rgba(255, 255, 255, 0.15); border: 2px solid rgba(255, 255, 255, 0.3); color: white; backdrop-filter: blur(10px);">
                </div>

                <div class="form-group">
                  <label class="form-label" style="color: rgba(255, 255, 255, 0.9); font-weight: 600;">Google CSE
                    CX</label>
                  <input type="text" id="googleCseCx" class="form-input" placeholder="ab12cd34efg:xyz123"
                    style="background: rgba(255, 255, 255, 0.15); border: 2px solid rgba(255, 255, 255, 0.3); color: white; backdrop-filter: blur(10px);">
                </div>
              </div>

              <small class="form-text" style="color: rgba(255, 255, 255, 0.7); margin-top: 8px; display: block;">
                할당량 초과 시 자동으로 AI 기반 폴백 검색이 작동합니다. (무료: 하루 100회)
              </small>
            </div>

            <!-- Naver API 설정 -->
            <div style="border-top: 2px solid rgba(255, 255, 255, 0.2); padding-top: 20px; margin-top: 20px;">
              <h3
                style="color: white; font-size: 18px; font-weight: 600; margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="11" cy="11" r="8"></circle>
                  <path d="M21 21l-4.35-4.35"></path>
                </svg>
                네이버 검색 설정
              </h3>

              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div class="form-group">
                  <label class="form-label" style="color: rgba(255, 255, 255, 0.9); font-weight: 600;">Naver Client
                    ID</label>
                  <input type="text" id="naverClientId" class="form-input" placeholder="abc123def456..."
                    style="background: rgba(255, 255, 255, 0.15); border: 2px solid rgba(255, 255, 255, 0.3); color: white; backdrop-filter: blur(10px);">
                </div>

                <div class="form-group">
                  <label class="form-label" style="color: rgba(255, 255, 255, 0.9); font-weight: 600;">Naver Client
                    Secret</label>
                  <input type="text" id="naverClientSecret" class="form-input" placeholder="XYZ123..."
                    style="background: rgba(255, 255, 255, 0.15); border: 2px solid rgba(255, 255, 255, 0.3); color: white; backdrop-filter: blur(10px);">
                </div>
              </div>

              <small class="form-text" style="color: rgba(255, 255, 255, 0.7); margin-top: 8px; display: block;">
                Google CSE 할당량 초과 시 네이버 검색으로 자동 폴백됩니다. (무료: 하루 25,000회)
              </small>
            </div>

          </div>
        </div>

        <!-- 플랫폼 설정 카드 -->
        <div class="card card-large"
          style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white; border: none; box-shadow: 0 20px 60px rgba(240, 147, 251, 0.3);">
          <div class="card-header" style="border-bottom: 2px solid rgba(255, 255, 255, 0.2); padding-bottom: 20px;">
            <h2 class="card-title"
              style="color: white; font-size: 24px; font-weight: 700; display: flex; align-items: center; gap: 12px;">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                <line x1="8" y1="21" x2="16" y2="21"></line>
                <line x1="12" y1="17" x2="12" y2="21"></line>
              </svg>
              플랫폼 설정
            </h2>
          </div>

          <div class="card-body" style="padding: 24px;">
            <!-- 플랫폼 선택은 환경설정에서만 사용 -->


            <!-- WordPress 설정 (플랫폼이 WordPress일 때만 표시) -->
            <div id="wordpressSettings" style="display: block;">
              <div style="border-top: 2px solid rgba(255, 255, 255, 0.2); padding-top: 20px;">
                <h3 style="color: white; font-size: 18px; font-weight: 600; margin-bottom: 16px;">WordPress 설정</h3>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                  <div class="form-group">
                    <label class="form-label" style="color: rgba(255, 255, 255, 0.9); font-weight: 600;">사이트 URL</label>
                    <input type="text" id="wordpressSiteUrl" class="form-input" placeholder="https://yoursite.com"
                      style="background: rgba(255, 255, 255, 0.15); border: 2px solid rgba(255, 255, 255, 0.3); color: white; backdrop-filter: blur(10px);">
                  </div>

                  <div class="form-group">
                    <label class="form-label" style="color: rgba(255, 255, 255, 0.9); font-weight: 600;">사용자명</label>
                    <input type="text" id="wordpressUsername" class="form-input" placeholder="admin"
                      style="background: rgba(255, 255, 255, 0.15); border: 2px solid rgba(255, 255, 255, 0.3); color: white; backdrop-filter: blur(10px);">
                  </div>
                </div>

                <div class="form-group" style="margin-bottom: 20px;">
                  <label class="form-label"
                    style="color: rgba(255, 255, 255, 0.9); font-weight: 600; display: flex; align-items: center; gap: 8px;">
                    Application Password
                    <button type="button" id="wpAppPasswordGuideBtnSemiAuto"
                      onclick="if(window.showWordPressAppPasswordGuide){window.showWordPressAppPasswordGuide();}else{alert('가이드 기능 로딩중입니다.');}"
                      style="padding: 4px 12px; background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white; border: none; border-radius: 6px; font-size: 11px; cursor: pointer; font-weight: 600;">
                      ❓ 발급 방법
                    </button>
                  </label>
                  <input type="password" id="wordpressPasswordSemiAuto" class="form-input"
                    placeholder="예: l3rq pnAO QTfU 8RjE mwVc j9kQ"
                    style="background: rgba(255, 255, 255, 0.15); border: 2px solid rgba(255, 255, 255, 0.3); color: white; backdrop-filter: blur(10px);">
                  <small style="display: block; margin-top: 6px; color: rgba(255, 255, 255, 0.7); font-size: 11px;">⚠️
                    일반 비밀번호 ❌ → <strong>애플리케이션 비밀번호</strong> ✅ 를 입력하세요</small>
                </div>

                <div class="form-group" style="margin-bottom: 20px;">
                  <label class="form-label" style="color: rgba(255, 255, 255, 0.9); font-weight: 600;">카테고리 선택</label>
                  <div style="margin-bottom: 12px;">
                    <button class="btn btn-secondary"
                      onclick="if(window.loadWordPressCategories){window.loadWordPressCategories();}else{alert('카테고리 로드 기능 로딩중입니다.');}"
                      id="btnLoadCategories"
                      style="padding: 12px 20px; background: rgba(255, 255, 255, 0.2); color: white; border: 2px solid rgba(255, 255, 255, 0.3); border-radius: 8px; cursor: pointer; font-weight: 600; backdrop-filter: blur(10px); transition: all 0.3s ease;">
                      📂 카테고리 불러오기
                    </button>
                    <span id="categoriesStatus"
                      style="margin-left: 12px; font-size: 12px; color: rgba(255, 255, 255, 0.7);"></span>
                  </div>
                  <div id="categoriesContainer" style="display: none;">
                    <div
                      style="max-height: 150px; overflow-y: auto; border: 2px solid rgba(255, 255, 255, 0.3); border-radius: 8px; padding: 12px; background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px);">
                      <div id="categoriesList"></div>
                    </div>
                  </div>
                  <input type="text" id="wordpressCategories" class="form-input" placeholder="선택된 카테고리" readonly
                    style="margin-top: 12px; background: rgba(255, 255, 255, 0.1); border: 2px solid rgba(255, 255, 255, 0.2); color: rgba(255, 255, 255, 0.8); backdrop-filter: blur(10px);">
                </div>

                <div class="form-group">
                  <button class="btn btn-secondary" onclick="testWordPressConnection()" id="btnTestWordPress"
                    style="padding: 12px 24px; background: rgba(255, 255, 255, 0.2); color: white; border: 2px solid rgba(255, 255, 255, 0.3); border-radius: 8px; cursor: pointer; font-weight: 600; backdrop-filter: blur(10px); transition: all 0.3s ease;">
                    🔗 WordPress 연결 테스트
                  </button>
                  <small class="form-text" style="color: rgba(255, 255, 255, 0.7); margin-top: 8px; display: block;">
                    WordPress 연결 상태를 확인합니다.
                  </small>
                </div>
              </div>
            </div>


          </div>
        </div>

        <!-- 고급 설정 카드 -->
        <div class="card card-large"
          style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: white; border: none; box-shadow: 0 20px 60px rgba(79, 172, 254, 0.3);">
          <div class="card-header" style="border-bottom: 2px solid rgba(255, 255, 255, 0.2); padding-bottom: 20px;">
            <h2 class="card-title"
              style="color: white; font-size: 24px; font-weight: 700; display: flex; align-items: center; gap: 12px;">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M12 1v6m0 6v6m11-7h-6m-6 0H1"></path>
              </svg>
              고급 설정
            </h2>
          </div>

          <div class="card-body" style="padding: 24px;">
            <!-- 프롬프트 설정 -->
            <div class="form-group" style="margin-bottom: 24px;">
              <label class="form-label" style="color: rgba(255, 255, 255, 0.9); font-weight: 600; font-size: 16px;">프롬프트
                설정</label>
              <div style="display: flex; gap: 12px; margin-top: 12px;">
                <button class="btn" onclick="setPromptMode('default')" id="default-prompt-btn"
                  style="flex: 1; padding: 12px 20px; background: rgba(255, 255, 255, 0.2); color: white; border: 2px solid rgba(255, 255, 255, 0.3); border-radius: 8px; cursor: pointer; font-weight: 600; backdrop-filter: blur(10px); transition: all 0.3s ease;">
                  기본 프롬프트
                </button>
                <button class="btn btn-secondary" onclick="setPromptMode('custom')" id="custom-prompt-btn"
                  style="flex: 1; padding: 12px 20px; background: rgba(255, 255, 255, 0.1); color: rgba(255, 255, 255, 0.7); border: 2px solid rgba(255, 255, 255, 0.2); border-radius: 8px; cursor: pointer; font-weight: 600; backdrop-filter: blur(10px); transition: all 0.3s ease;">
                  사용자 정의 프롬프트
                </button>
              </div>

              <div id="custom-prompt-section" style="display: none; margin-top: 16px;">
                <textarea id="customPrompt" class="form-input" rows="8"
                  placeholder="사용자 정의 프롬프트를 입력하세요..&#10;&#10;예시:&#10;간단하고 가독성 좋은 블로그 스타일로 작성해주세요.&#10;- 제목은 H1으로&#10;- 섹션은 H2로&#10;- 가독성 높은 문단으로 구성&#10;- 2000자 이상 작성&#10;- 한글만 사용"
                  style="background: rgba(255, 255, 255, 0.15); border: 2px solid rgba(255, 255, 255, 0.3); color: white; backdrop-filter: blur(10px);"></textarea>
                <small class="form-text" style="color: rgba(255, 255, 255, 0.7); margin-top: 8px; display: block;">
                  사용자 정의 프롬프트를 입력하면 AI가 해당 지침에 따라 글을 생성합니다.
                </small>
              </div>
            </div>

            <!-- 검색 설정 -->
            <div class="form-group">
              <label class="form-label" style="color: rgba(255, 255, 255, 0.9); font-weight: 600; font-size: 16px;">🔍
                검색 설정</label>
              <div
                style="display: flex; align-items: center; gap: 12px; margin-top: 12px; padding: 16px; background: rgba(255, 255, 255, 0.1); border: 2px solid rgba(255, 255, 255, 0.2); border-radius: 8px; backdrop-filter: blur(10px);">
                <input type="checkbox" id="useGoogleSearch" style="transform: scale(1.5);">
                <label for="useGoogleSearch" style="margin: 0; font-weight: 600; color: white; flex: 1;">
                  구글 상위 노출 글 분석 기반 생성
                </label>
              </div>
              <small class="form-text" style="color: rgba(255, 255, 255, 0.7); margin-top: 8px; display: block;">
                체크하면 구글 상위 노출 글 3개를 크롤링하여 분석한 뒤 경쟁력 있는 글을 생성합니다.
              </small>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 콘텐츠 변환 탭 -->
  <div id="content-tab" class="tab-content">
    <!-- 콘텐츠 변환 그리드 -->
    <div class="grid">
      <!-- 콘텐츠 변환 -->
      <div class="card card-large">
        <h2 class="card-title">🔄 콘텐츠 변환</h2>

        <div class="form-group">
          <label class="form-label">원본 포스트 URL 또는 글 내용</label>
          <input type="text" id="contentUrl" class="form-input" placeholder="예: https://myblog.com/post/123 또는 블로그 URL"
            style="margin-bottom: 10px;">
          <textarea id="contentText" class="form-input" rows="8"
            placeholder="또는 변형할 글 내용을 직접 입력하세요...&#10;&#10;예시:&#10;안녕하세요! 오늘은 맛있는 레시피를 소개합니다.&#10;재료: 밀가루, 계란, 우유..."></textarea>
          <p style="font-size: 12px; color: #64748b; margin-top: 8px;">💡 URL을 입력하면 자동으로 해당 페이지에서 텍스트를 크롤링합니다. 또는 직접 글을
            입력해도 됩니다.</p>
        </div>

        <div class="form-group">
          <label class="form-label">AI 모델</label>
          <button class="btn btn-primary btn-block" onclick="setAIProvider('smart')" style="margin-bottom: 15px;">
            ✨ 스마트 AI - 상황에 따라 최적 모델 자동 선택
          </button>
        </div>

        <div class="form-group">
          <label class="form-label">변형 유형</label>
          <div class="btn-group" style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
            <button class="btn" onclick="generateContentVariation('news')">📰 뉴스형</button>
            <button class="btn" onclick="generateContentVariation('guide')">📚 가이드형</button>
            <button class="btn" onclick="generateContentVariation('review')">⭐ 리뷰형</button>
            <button class="btn" onclick="generateContentVariation('analysis')">🔍 분석형</button>
            <button class="btn" onclick="generateContentVariation('story')">📖 스토리형</button>
            <button class="btn" onclick="generateContentVariation('comparison')">⚖️ 비교형</button>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">변형 옵션</label>
          <div class="btn-group" style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
            <button class="btn btn-secondary" onclick="generateContentVariation('seo')">🚀 SEO 최적화</button>
            <button class="btn btn-secondary" onclick="generateContentVariation('readable')">👓 가독성 향상</button>
            <button class="btn btn-secondary" onclick="generateContentVariation('engaging')">💬 참여도 증대</button>
            <button class="btn btn-secondary" onclick="generateContentVariation('adsense')">💰 애드센스 친화</button>
          </div>
        </div>

        <div class="btn-group">
          <button class="btn btn-success" onclick="generateAllVariations()">전체 변형 생성</button>
          <button class="btn" onclick="previewVariations()">미리보기</button>
        </div>
      </div>

      <!-- 변형 결과 -->
      <div class="card card-large">
        <h2 class="card-title">📄 변형 결과</h2>

        <div id="variationResults"
          style="max-height: 400px; overflow-y: auto; border: 1px solid #e5e7eb; border-radius: 8px; padding: 12px; background: #f9fafb;">
          <p style="color: #6b7280; text-align: center; margin: 20px 0;">변형된 콘텐츠가 여기에 표시됩니다</p>
        </div>

        <div class="btn-group" style="margin-top: 12px;">
          <button class="btn btn-primary" onclick="generateContentVariation('guide')">변형 생성</button>
          <button class="btn" onclick="copyVariations()">복사</button>
          <button class="btn btn-success" onclick="postVariations()">발행</button>
          <button class="btn btn-secondary" onclick="clearVariations()">지우기</button>
        </div>
      </div>
    </div>
  </div>

  <!-- 엑셀 포스팅 탭 -->
  <div id="excel-tab" class="tab-content">
    <div style="display: flex; flex-direction: column; gap: 24px; padding: 24px;">

      <!-- 엑셀 파일 업로드 카드 -->
      <div
        style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 20px; padding: 32px; box-shadow: 0 20px 60px rgba(102, 126, 234, 0.3);">
        <div style="text-align: center; margin-bottom: 32px;">
          <h2 style="color: white; margin: 0 0 12px 0; font-size: 28px; font-weight: 700;">📊 엑셀 대량 포스팅</h2>
          <p style="color: rgba(255, 255, 255, 0.8); margin: 0; font-size: 16px;">엑셀 파일로 여러 포스트를 한 번에 생성하고 발행하세요</p>
        </div>

        <!-- 파일 업로드 영역 (드래그앤드롭 지원) -->
        <div id="fileDropZone"
          style="background: rgba(255, 255, 255, 0.15); border: 3px dashed rgba(255, 255, 255, 0.4); border-radius: 16px; padding: 40px; text-align: center; margin-bottom: 24px; backdrop-filter: blur(10px); transition: all 0.3s ease; cursor: pointer;"
          ondrop="handleFileDrop(event)" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)"
          onclick="document.getElementById('excelFile').click()">
          <div style="margin-bottom: 20px;">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              style="color: rgba(255, 255, 255, 0.8);">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14,2 14,8 20,8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
              <polyline points="10,9 9,9 8,9"></polyline>
            </svg>
          </div>
          <input type="file" id="excelFile" accept=".xlsx,.xls" style="display: none;"
            onchange="handleExcelFileSelect(event)">
          <div
            style="padding: 16px 32px; background: rgba(255, 255, 255, 0.2); border: 2px solid rgba(255, 255, 255, 0.4); border-radius: 12px; color: white; font-size: 16px; font-weight: 600; transition: all 0.3s ease; margin-bottom: 12px; display: inline-block;">
            📁 엑셀 파일 선택 또는 드래그앤드롭
          </div>
          <p style="color: rgba(255, 255, 255, 0.7); margin: 0; font-size: 14px;">.xlsx 또는 .xls 파일을 선택하거나 여기에 끌어다 놓으세요
          </p>
        </div>

        <!-- 선택된 파일 정보 -->
        <div id="selectedFileInfo"
          style="display: none; background: rgba(255, 255, 255, 0.1); border-radius: 12px; padding: 16px; margin-bottom: 24px; backdrop-filter: blur(10px);">
          <div style="display: flex; align-items: center; gap: 12px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              style="color: #4ade80;">
              <path d="M9 12l2 2 4-4"></path>
              <circle cx="12" cy="12" r="10"></circle>
            </svg>
            <span style="color: white; font-weight: 600;">파일이 선택되었습니다</span>
          </div>
        </div>

        <!-- 실행 버튼들 -->
        <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
          <button onclick="runExcelBatch()"
            style="padding: 16px 32px; background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); border: none; color: white; border-radius: 12px; cursor: pointer; font-weight: 600; font-size: 16px; transition: all 0.3s ease; box-shadow: 0 8px 24px rgba(79, 172, 254, 0.3);">
            🚀 배치 처리 시작
          </button>
          <div style="display: flex; flex-direction: column; gap: 8px;">
            <button onclick="downloadExcelTemplate()"
              style="padding: 16px 32px; background: linear-gradient(135deg, #4ade80 0%, #22c55e 100%); border: none; color: white; border-radius: 12px; cursor: pointer; font-weight: 600; font-size: 16px; transition: all 0.3s ease; box-shadow: 0 8px 24px rgba(74, 222, 128, 0.3);">
              👶 초보자용 템플릿 (간단)
            </button>
            <button onclick="downloadAdvancedExcelTemplate()"
              style="padding: 16px 32px; background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%); border: none; color: white; border-radius: 12px; cursor: pointer; font-weight: 600; font-size: 16px; transition: all 0.3s ease; box-shadow: 0 8px 24px rgba(59, 130, 246, 0.3);">
              🔧 고급 사용자용 (상세)
            </button>
          </div>
        </div>
      </div>

      <!-- 엑셀 형식 안내 카드 -->
      <div
        style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); border-radius: 20px; padding: 32px; box-shadow: 0 20px 60px rgba(240, 147, 251, 0.3);">
        <div style="text-align: center; margin-bottom: 24px;">
          <h3 style="color: white; margin: 0 0 8px 0; font-size: 22px; font-weight: 700;">📋 템플릿 선택 가이드</h3>
          <p style="color: rgba(255, 255, 255, 0.8); margin: 0; font-size: 14px;">레벨에 맞는 템플릿을 선택하세요</p>
        </div>

        <div
          style="background: rgba(255, 255, 255, 0.15); border-radius: 16px; padding: 24px; backdrop-filter: blur(10px);">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">

            <!-- 초보자용 템플릿 -->
            <div>
              <h4 style="color: #4ade80; margin: 0 0 16px 0; font-size: 16px; font-weight: 600;">👶 초보자용 (간단)</h4>
              <div
                style="background: rgba(74, 222, 128, 0.1); border-radius: 8px; padding: 16px; border: 2px solid rgba(74, 222, 128, 0.3);">
                <div style="margin-bottom: 8px; font-size: 12px;">
                  <span style="color: white; font-weight: 600;">📝 포스트 제목</span>
                  <span style="color: rgba(255, 255, 255, 0.7); margin-left: 4px;">- 글 제목만 입력</span>
                </div>
                <div style="margin-bottom: 8px; font-size: 12px;">
                  <span style="color: white; font-weight: 600;">🏷️ 키워드</span>
                  <span style="color: rgba(255, 255, 255, 0.7); margin-left: 4px;">- 쉼표로 구분</span>
                </div>
                <div style="margin-bottom: 8px; font-size: 12px;">
                  <span style="color: white; font-weight: 600;">🤖 AI 모드</span>
                  <span style="color: rgba(255, 255, 255, 0.7); margin-left: 4px;">- Gemini AI</span>
                </div>
                <div style="margin-bottom: 8px; font-size: 12px;">
                  <span style="color: white; font-weight: 600;">📱 플랫폼</span>
                  <span style="color: rgba(255, 255, 255, 0.7); margin-left: 4px;">- 블로거/워드프레스</span>
                </div>
                <div style="margin-bottom: 8px; font-size: 12px;">
                  <span style="color: white; font-weight: 600;">⏰ 발행 방식</span>
                  <span style="color: rgba(255, 255, 255, 0.7); margin-left: 4px;">- 임시저장/즉시발행/예약발행</span>
                </div>
                <div style="margin-bottom: 8px; font-size: 12px;">
                  <span style="color: white; font-weight: 600;">🖼️ 썸네일</span>
                  <span style="color: rgba(255, 255, 255, 0.7); margin-left: 4px;">- 자동생성/달리/펙셀스</span>
                </div>
                <div style="margin-bottom: 8px; font-size: 12px;">
                  <span style="color: #4ade80; font-weight: 600;">✅ 모든 옵션을 쉽게 선택할 수 있어요!</span>
                </div>
              </div>
            </div>

            <!-- 고급 사용자용 템플릿 -->
            <div>
              <h4 style="color: #3b82f6; margin: 0 0 16px 0; font-size: 16px; font-weight: 600;">🔧 고급 사용자용 (상세)</h4>
              <div
                style="background: rgba(59, 130, 246, 0.1); border-radius: 8px; padding: 16px; border: 2px solid rgba(59, 130, 246, 0.3);">
                <div style="margin-bottom: 8px; font-size: 12px;">
                  <span style="color: white; font-weight: 600;">topic</span>
                  <span style="color: rgba(255, 255, 255, 0.7); margin-left: 4px;">- 포스트 제목</span>
                </div>
                <div style="margin-bottom: 8px; font-size: 12px;">
                  <span style="color: white; font-weight: 600;">aiMode</span>
                  <span style="color: rgba(255, 255, 255, 0.7); margin-left: 4px;">- gemini</span>
                </div>
                <div style="margin-bottom: 8px; font-size: 12px;">
                  <span style="color: white; font-weight: 600;">platform</span>
                  <span style="color: rgba(255, 255, 255, 0.7); margin-left: 4px;">- blogger/wordpress</span>
                </div>
                <div style="margin-bottom: 8px; font-size: 12px;">
                  <span style="color: white; font-weight: 600;">thumbnailMode</span>
                  <span style="color: rgba(255, 255, 255, 0.7); margin-left: 4px;">- dalle/pexels/bfl/cse</span>
                </div>
                <div style="margin-bottom: 8px; font-size: 12px;">
                  <span style="color: #3b82f6; font-weight: 600;">⚙️ 모든 옵션 직접 설정</span>
                </div>
              </div>
            </div>
          </div>

          <div
            style="text-align: center; margin-top: 20px; padding: 16px; background: rgba(255, 255, 255, 0.1); border-radius: 8px;">
            <p style="color: #ffd93d; margin: 0 0 8px 0; font-weight: 600; font-size: 14px;">💡 템플릿 다운로드 버튼을 클릭하면 예시 파일을
              받을 수 있습니다!</p>
            <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-top: 12px;">
              <button onclick="showTemplatePreview()"
                style="padding: 8px 16px; background: rgba(255, 255, 255, 0.2); border: 1px solid rgba(255, 255, 255, 0.3); color: white; border-radius: 6px; cursor: pointer; font-size: 12px; transition: all 0.3s ease;">
                👁️ 미리보기
              </button>
              <button onclick="downloadExcelTemplate()"
                style="padding: 8px 16px; background: rgba(255, 255, 255, 0.2); border: 1px solid rgba(255, 255, 255, 0.3); color: white; border-radius: 6px; cursor: pointer; font-size: 12px; transition: all 0.3s ease;">
                📥 다운로드
              </button>
              <button onclick="showQuickGuide()"
                style="padding: 8px 16px; background: rgba(255, 255, 255, 0.2); border: 1px solid rgba(255, 255, 255, 0.3); color: white; border-radius: 6px; cursor: pointer; font-size: 12px; transition: all 0.3s ease;">
                📖 가이드
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- 배치 처리 결과 카드 -->
      <div
        style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); border-radius: 20px; padding: 32px; box-shadow: 0 20px 60px rgba(79, 172, 254, 0.3);">
        <div style="text-align: center; margin-bottom: 24px;">
          <h3 style="color: white; margin: 0 0 8px 0; font-size: 22px; font-weight: 700;">📈 배치 처리 결과</h3>
          <p style="color: rgba(255, 255, 255, 0.8); margin: 0; font-size: 14px;">포스팅 결과와 통계를 확인하세요</p>
        </div>

        <div id="excelResults"
          style="background: rgba(255, 255, 255, 0.15); border-radius: 16px; padding: 24px; max-height: 400px; overflow-y: auto; backdrop-filter: blur(10px); margin-bottom: 24px;">
          <div style="text-align: center; padding: 40px;">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              style="color: rgba(255, 255, 255, 0.5); margin-bottom: 16px;">
              <path d="M9 11H5a2 2 0 0 0-2 2v3c0 1.1.9 2 2 2h4"></path>
              <path d="M15 11h4a2 2 0 0 1 2 2v3c0 1.1-.9 2-2 2h-4"></path>
              <path d="M9 11V9a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2"></path>
            </svg>
            <p style="color: rgba(255, 255, 255, 0.7); margin: 0; font-size: 16px;">배치 처리 결과가 여기에 표시됩니다</p>
          </div>
        </div>

        <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
          <button onclick="downloadExcelResults()"
            style="padding: 12px 24px; background: rgba(255, 255, 255, 0.2); border: 2px solid rgba(255, 255, 255, 0.4); color: white; border-radius: 10px; cursor: pointer; font-weight: 600; font-size: 14px; transition: all 0.3s ease;">
            💾 결과 다운로드
          </button>
          <button onclick="clearExcelResults()"
            style="padding: 12px 24px; background: rgba(255, 107, 107, 0.3); border: 2px solid rgba(255, 107, 107, 0.5); color: white; border-radius: 10px; cursor: pointer; font-weight: 600; font-size: 14px; transition: all 0.3s ease;">
            🗑️ 결과 지우기
          </button>
        </div>
      </div>

    </div>
  </div>


  <!-- ES6 모듈 시스템 -->
  <!-- 반자동 이미지 관리 탭 -->
  <div id="semi-auto-tab" class="tab-content" style="display: none;">
    <div class="container" style="max-width: 1600px; margin: 0 auto; padding: 40px 24px;">

      <!-- 상단: 제목/키워드 입력 + 반자동 발행 버튼 -->
      <div class="card"
        style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; box-shadow: 0 20px 60px rgba(102, 126, 234, 0.3); margin-bottom: 32px;">
        <div class="card-header" style="border-bottom: 2px solid rgba(255, 255, 255, 0.2); padding-bottom: 20px;">
          <h2 class="card-title"
            style="color: white; font-size: 28px; font-weight: 700; display: flex; align-items: center; gap: 12px;">
            <span style="font-size: 32px;">🎨</span>
            반자동 이미지 관리
          </h2>
        </div>

        <div class="card-body" style="padding: 32px;">
          <div style="display: grid; grid-template-columns: 1fr auto; gap: 20px; align-items: end;">
            <div>
              <label class="form-label"
                style="color: #1e293b !important; font-weight: 600; font-size: 16px; margin-bottom: 12px; display: block;">
                📝 제목 또는 키워드 입력
              </label>
              <input type="text" id="semiAutoKeyword" class="form-input" placeholder="예: 2025년 최고의 노트북 추천"
                style="background: rgba(255, 255, 255, 0.15); border: 2px solid rgba(255, 255, 255, 0.3); color: #1e293b !important; backdrop-filter: blur(10px); font-size: 16px; padding: 16px 20px; font-weight: 600;">
            </div>
            <div>
              <button onclick="generateSemiAutoContent()" id="semiAutoGenerateBtn"
                style="padding: 18px 40px; background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%); border: 2px solid rgba(255, 255, 255, 0.4); border-radius: 14px; color: #1e293b; font-size: 16px; font-weight: 800; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 6px 20px rgba(255, 215, 0, 0.5); white-space: nowrap;"
                onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 10px 30px rgba(255, 215, 0, 0.6)';"
                onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 6px 20px rgba(255, 215, 0, 0.5)';">
                <span style="font-size: 20px;">⚡</span> 반자동으로 발행하기
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- 2단 레이아웃: 왼쪽(소제목 분석 + 이미지 생성), 오른쪽(미리보기) -->
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 32px;">

        <!-- 왼쪽: 소제목 분석 & 이미지 생성 -->
        <div>
          <!-- 소제목 분석 카드 -->
          <div class="card"
            style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white; border: none; box-shadow: 0 20px 60px rgba(240, 147, 251, 0.3); margin-bottom: 24px;">
            <div class="card-header" style="border-bottom: 2px solid rgba(255, 255, 255, 0.2); padding-bottom: 16px;">
              <h3 class="card-title"
                style="color: white; font-size: 20px; font-weight: 700; display: flex; align-items: center; gap: 10px;">
                <span style="font-size: 24px;">📋</span>
                소제목 분석
              </h3>
            </div>

            <div class="card-body" style="padding: 24px;">
              <div id="semiAutoSubtopics" style="display: flex; flex-direction: column; gap: 16px;">
                <div style="text-align: center; padding: 40px 20px; color: #1e293b !important;">
                  <p style="font-size: 16px; margin: 0; color: #1e293b !important;">반자동 발행하기 버튼을 클릭하면<br>자동으로 소제목이
                    분석됩니다.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- 이미지 소스 선택 -->
          <div class="card"
            style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: white; border: none; box-shadow: 0 20px 60px rgba(79, 172, 254, 0.3); margin-bottom: 24px;">
            <div class="card-body" style="padding: 20px;">
              <label class="form-label"
                style="color: #1e293b !important; font-weight: 600; font-size: 16px; margin-bottom: 12px; display: block;">
                🖼️ 이미지 소스 선택
              </label>
              <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px;">
                <button onclick="setSemiAutoImageSource('nanobananapro')" id="semiAutoNanoBananaBtn"
                  class="semi-auto-image-source-btn active"
                  style="padding: 12px 16px; background: rgba(251, 191, 36, 0.3); border: 2px solid #fbbf24; border-radius: 10px; color: white; font-weight: 700; cursor: pointer; transition: all 0.3s ease;">
                  🍌 Nano Banana Pro <span
                    style="font-size: 10px; background: #fbbf24; color: #1e293b; padding: 2px 6px; border-radius: 4px; margin-left: 4px;">빠름</span>
                </button>
                <button onclick="setSemiAutoImageSource('deepinfra')" id="semiAutoDeepInfraBtn"
                  class="semi-auto-image-source-btn"
                  style="padding: 12px 16px; background: rgba(239, 68, 68, 0.1); border: 2px solid rgba(239, 68, 68, 0.3); border-radius: 10px; color: rgba(255, 255, 255, 0.7); font-weight: 700; cursor: pointer; transition: all 0.3s ease;">
                  🔥 DeepInfra FLUX-2 <span
                    style="font-size: 10px; background: #ef4444; color: white; padding: 2px 6px; border-radius: 4px; margin-left: 4px;">고품질</span>
                </button>
                <button onclick="setSemiAutoImageSource('stability')" id="semiAutoStabilityBtn"
                  class="semi-auto-image-source-btn"
                  style="padding: 12px 16px; background: rgba(255, 255, 255, 0.1); border: 2px solid rgba(255, 255, 255, 0.3); border-radius: 10px; color: rgba(255, 255, 255, 0.7); font-weight: 700; cursor: pointer; transition: all 0.3s ease;">
                  🚀 Stability AI
                </button>
                <button onclick="setSemiAutoImageSource('pollinations')" id="semiAutoPollinationsBtn"
                  class="semi-auto-image-source-btn"
                  style="padding: 12px 16px; background: rgba(255, 255, 255, 0.1); border: 2px solid rgba(255, 255, 255, 0.3); border-radius: 10px; color: rgba(255, 255, 255, 0.7); font-weight: 700; cursor: pointer; transition: all 0.3s ease;">
                  🌸 Pollinations <span
                    style="font-size: 10px; background: #10b981; padding: 2px 6px; border-radius: 4px; margin-left: 4px;">무료</span>
                </button>
              </div>
            </div>
          </div>

          <!-- 🔗 자동 내부링크 설정 -->
          <div class="card"
            style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; box-shadow: 0 20px 60px rgba(102, 126, 234, 0.3); margin-bottom: 24px;">
            <div class="card-body" style="padding: 20px;">
              <label class="form-label"
                style="color: white; font-weight: 600; font-size: 16px; margin-bottom: 12px; display: block;">
                🔗 자동 내부링크 설정
              </label>

              <!-- 내부링크 활성화 토글 -->
              <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
                <label class="toggle-switch"
                  style="position: relative; display: inline-block; width: 50px; height: 26px;">
                  <input type="checkbox" id="enableInternalLinks" checked style="opacity: 0; width: 0; height: 0;">
                  <span class="toggle-slider"
                    style="position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background: rgba(255,255,255,0.3); transition: 0.3s; border-radius: 26px;"></span>
                </label>
                <span style="color: white; font-weight: 600;">내부링크 자동 삽입</span>
              </div>

              <!-- 내부링크 개수 선택 -->
              <div id="internalLinkOptions" style="display: block;">
                <label class="form-label"
                  style="color: rgba(255,255,255,0.8); font-size: 14px; margin-bottom: 8px; display: block;">
                  📊 H2 섹션당 내부링크 개수
                </label>
                <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                  <button onclick="setInternalLinkCount(0)" id="linkCount0" class="internal-link-count-btn"
                    style="padding: 10px 16px; background: rgba(255,255,255,0.1); border: 2px solid rgba(255,255,255,0.3); border-radius: 8px; color: rgba(255,255,255,0.7); font-weight: 600; cursor: pointer; transition: all 0.3s;">
                    없음
                  </button>
                  <button onclick="setInternalLinkCount(1)" id="linkCount1" class="internal-link-count-btn active"
                    style="padding: 10px 16px; background: rgba(255,215,0,0.3); border: 2px solid #ffd700; border-radius: 8px; color: white; font-weight: 600; cursor: pointer; transition: all 0.3s;">
                    1개
                  </button>
                  <button onclick="setInternalLinkCount(2)" id="linkCount2" class="internal-link-count-btn"
                    style="padding: 10px 16px; background: rgba(255,255,255,0.1); border: 2px solid rgba(255,255,255,0.3); border-radius: 8px; color: rgba(255,255,255,0.7); font-weight: 600; cursor: pointer; transition: all 0.3s;">
                    2개
                  </button>
                  <button onclick="setInternalLinkCount(3)" id="linkCount3" class="internal-link-count-btn"
                    style="padding: 10px 16px; background: rgba(255,255,255,0.1); border: 2px solid rgba(255,255,255,0.3); border-radius: 8px; color: rgba(255,255,255,0.7); font-weight: 600; cursor: pointer; transition: all 0.3s;">
                    3개
                  </button>
                </div>

                <!-- 내부링크 URL 입력 -->
                <div style="margin-top: 16px;">
                  <label class="form-label"
                    style="color: rgba(255,255,255,0.8); font-size: 14px; margin-bottom: 8px; display: block;">
                    🌐 내 블로그 URL (내부링크 자동 검색용)
                  </label>
                  <input type="text" id="internalLinkBlogUrl" placeholder="예: https://myblog.tistory.com"
                    style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.15); border: 2px solid rgba(255,255,255,0.3); border-radius: 10px; color: white; font-size: 14px; backdrop-filter: blur(10px);">
                  <p style="color: rgba(255,255,255,0.6); font-size: 12px; margin-top: 6px;">
                    💡 입력하면 키워드와 관련된 기존 글을 자동으로 찾아 연결합니다
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- 이미지 생성 영역 -->
          <div class="card"
            style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); color: white; border: none; box-shadow: 0 20px 60px rgba(250, 112, 154, 0.3);">
            <div class="card-header" style="border-bottom: 2px solid rgba(255, 255, 255, 0.2); padding-bottom: 16px;">
              <h3 class="card-title"
                style="color: white; font-size: 20px; font-weight: 700; display: flex; align-items: center; gap: 10px;">
                <span style="font-size: 24px;">🎨</span>
                이미지 생성
              </h3>
            </div>

            <div class="card-body" style="padding: 24px;">
              <div id="semiAutoImageGeneration" style="display: flex; flex-direction: column; gap: 20px;">
                <div style="text-align: center; padding: 40px 20px; color: #1e293b !important;">
                  <p style="font-size: 16px; margin: 0; color: #1e293b !important;">소제목 분석 후<br>이미지 생성 영역이 표시됩니다.</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 오른쪽: 미리보기 -->
        <div>
          <div class="card"
            style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); color: white; border: none; box-shadow: 0 20px 60px rgba(67, 233, 123, 0.3);">
            <div class="card-header" style="border-bottom: 2px solid rgba(255, 255, 255, 0.2); padding-bottom: 16px;">
              <h3 class="card-title"
                style="color: white; font-size: 20px; font-weight: 700; display: flex; align-items: center; justify-content: space-between;">
                <span style="display: flex; align-items: center; gap: 10px;">
                  <span style="font-size: 24px;">👁️</span>
                  미리보기
                </span>
                <div style="display: flex; gap: 8px;">
                  <button onclick="setSemiAutoPreviewPlatform('blogspot')" id="semiAutoPreviewBlogspotBtn"
                    class="semi-auto-preview-platform-btn active"
                    style="padding: 8px 16px; background: rgba(255, 255, 255, 0.3); border: 2px solid white; border-radius: 8px; color: white; font-size: 13px; font-weight: 700; cursor: pointer; transition: all 0.3s ease;">
                    블로그스팟
                  </button>
                  <button onclick="setSemiAutoPreviewPlatform('wordpress')" id="semiAutoPreviewWordpressBtn"
                    class="semi-auto-preview-platform-btn"
                    style="padding: 8px 16px; background: rgba(255, 255, 255, 0.1); border: 2px solid rgba(255, 255, 255, 0.3); border-radius: 8px; color: rgba(255, 255, 255, 0.7); font-size: 13px; font-weight: 700; cursor: pointer; transition: all 0.3s ease;">
                    워드프레스
                  </button>
                </div>
              </h3>
            </div>

            <div class="card-body" style="padding: 0; max-height: calc(100vh - 200px); overflow-y: auto;">
              <!-- 미리보기 컨테이너 (블로그스팟/워드프레스 스타일 적용) -->
              <div id="semiAutoPreview" style="background: white; min-height: 600px; color: #1e293b !important;">
                <div style="padding: 60px 40px; text-align: center; color: #1e293b !important;">
                  <p style="font-size: 18px; margin: 0; color: #1e293b !important;">반자동 발행하기 버튼을 클릭하면<br>미리보기가 표시됩니다.
                  </p>
                </div>
              </div>
            </div>

            <!-- 하단: 적용하기 + 발행 버튼 -->
            <div class="card-footer"
              style="border-top: 2px solid rgba(255, 255, 255, 0.2); padding: 20px; display: flex; gap: 12px;">
              <button onclick="applySemiAutoImages()" id="semiAutoApplyBtn"
                style="flex: 1; padding: 16px 24px; background: rgba(255, 255, 255, 0.3); border: 2px solid rgba(255, 255, 255, 0.5); border-radius: 12px; color: white; font-size: 16px; font-weight: 700; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);"
                onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(0, 0, 0, 0.3)';"
                onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 15px rgba(0, 0, 0, 0.2)';"
                disabled>
                <span style="font-size: 18px;">✅</span> 적용하기
              </button>
              <button onclick="publishSemiAutoContent()" id="semiAutoPublishBtn"
                style="flex: 2; padding: 16px 24px; background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%); border: 2px solid rgba(255, 255, 255, 0.5); border-radius: 12px; color: #1e293b; font-size: 16px; font-weight: 800; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 6px 20px rgba(255, 215, 0, 0.5);"
                onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 10px 30px rgba(255, 215, 0, 0.6)';"
                onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 6px 20px rgba(255, 215, 0, 0.5)';"
                disabled>
                <span style="font-size: 20px;">🚀</span> 반자동 발행 시작하기
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 거미줄치기 통합글 만들기 탭 -->
  <div id="internal-links-tab" class="tab-content"
    style="display: none; padding: 40px; max-width: 1200px; margin: 0 auto; background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%); min-height: 100vh;">
    <div style="text-align: center; margin-bottom: 48px;">
      <div
        style="background: linear-gradient(135deg, #ff6b6b 0%, #feca57 100%); background-clip: text; -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-size: 48px; font-weight: 900; margin-bottom: 16px;">
        🕸️ 거미줄치기 통합글 만들기
      </div>
      <p style="color: #64748b; font-size: 18px; font-weight: 500;">5개의 글을 선택하여 각 글의 70% 핵심 내용과 CTA가 포함된 통합글을 생성하세요</p>
    </div>

    <!-- 글 주소 입력 섹션 -->
    <div
      style="background: white; border-radius: 24px; padding: 40px; margin-bottom: 32px; box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);">
      <h3 style="font-size: 24px; font-weight: 700; color: #1e293b; margin-bottom: 24px;">📝 글 주소 입력 (최대 5개)</h3>
      <div id="urlInputsContainer" style="display: grid; gap: 16px;">
        <!-- 동적으로 생성됨 -->
      </div>
      <div style="display: flex; gap: 12px; margin-top: 16px;">
        <button onclick="openPublishedPostsModal()"
          style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; padding: 12px 24px; border-radius: 12px; font-size: 14px; font-weight: 600; cursor: pointer; box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);">
          📚 생성 글 목록에서 불러오기
        </button>
        <button onclick="addUrlInput()"
          style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white; border: none; padding: 12px 24px; border-radius: 12px; font-size: 14px; font-weight: 600; cursor: pointer; box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);">
          ➕ 주소 추가
        </button>
        <button onclick="clearUrlInputs()"
          style="background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); color: white; border: none; padding: 12px 24px; border-radius: 12px; font-size: 14px; font-weight: 600; cursor: pointer; box-shadow: 0 4px 15px rgba(239, 68, 68, 0.3);">
          🗑️ 모두 지우기
        </button>
      </div>
    </div>

    <!-- 선택한 글 목록 (최대 5개) -->
    <div
      style="background: white; border-radius: 24px; padding: 40px; margin-bottom: 32px; box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);">
      <h3 style="font-size: 24px; font-weight: 700; color: #1e293b; margin-bottom: 24px;">✅ 선택한 글 (최대 5개)</h3>
      <div id="selectedPostsList" style="min-height: 100px;">
        <div style="text-align: center; color: #94a3b8; padding: 40px;">
          <div style="font-size: 48px; margin-bottom: 16px;">📝</div>
          <div style="font-size: 16px;">위에서 글 주소를 입력하거나 생성 글 목록에서 불러오세요</div>
        </div>
      </div>
    </div>

    <!-- 통합글 생성 섹션 -->
    <div
      style="background: white; border-radius: 24px; padding: 40px; margin-bottom: 32px; box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);">
      <h3 style="font-size: 24px; font-weight: 700; color: #1e293b; margin-bottom: 24px;">🚀 통합글 생성</h3>
      <div style="margin-bottom: 24px;">
        <label style="display: block; font-size: 14px; font-weight: 600; color: #374151; margin-bottom: 8px;">📝 통합글 제목
          (SEO 최적화, 5개 글 모두 충족)</label>
        <input type="text" id="spiderWebTitle" placeholder="5개 글을 모두 포함하는 SEO 최적화된 제목을 입력하세요 (자동 생성 가능)"
          style="width: 100%; padding: 16px; border: 2px solid #e5e7eb; border-radius: 12px; font-size: 16px; background: #f9fafb; transition: all 0.3s ease; box-sizing: border-box;"
          onfocus="this.style.borderColor='#667eea'; this.style.backgroundColor='#ffffff';"
          onblur="this.style.borderColor='#e5e7eb'; this.style.backgroundColor='#f9fafb';">
        <small style="display: block; margin-top: 8px; font-size: 12px; color: #64748b;">제목을 비워두면 선택한 글들을 분석하여 자동으로 SEO
          최적화된 제목을 생성합니다</small>
      </div>
      <button onclick="generateSpiderWebContent()"
