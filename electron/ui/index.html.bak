      <div
        style="width: 95%; max-width: 720px; max-height: 90vh; background: white; border-radius: 24px; padding: 32px; overflow-y: auto; box-shadow: 0 40px 100px rgba(0, 0, 0, 0.5);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
