  <script src="./script.js"></script>

  <script type="module">
    // 모듈 로딩 확인 및 에러 처리
    import('./modules/main.js?v=' + Date.now())
      .then(() => {
        console.log('✅ [MODULE] 모듈 로딩 완료');
        // 모듈 로딩 완료 이벤트 발생
        window.dispatchEvent(new CustomEvent('modulesLoaded', { detail: { success: true } }));

        // 전역 함수 등록 확인
        const requiredFunctions = [
          'showTab', 'runPosting', 'openSettingsModal', 'openExternalLinksModal'
        ];
        const missingFunctions = requiredFunctions.filter(fn => typeof window[fn] !== 'function');
        if (missingFunctions.length > 0) {
          console.warn('⚠️ [MODULE] 일부 전역 함수가 등록되지 않았습니다:', missingFunctions);
        } else {
          console.log('✅ [MODULE] 모든 필수 전역 함수가 등록되었습니다');
        }
      })
      .catch(error => {
        console.error('❌ [MODULE] 모듈 로딩 실패:', error);
        console.error('❌ 에러 상세:', {
          message: error?.message,
          stack: error?.stack,
          name: error?.name,
          fileName: error?.fileName,
          lineNumber: error?.lineNumber,
          columnNumber: error?.columnNumber
        });

        // 모듈 로딩 실패 이벤트 발생
        window.dispatchEvent(new CustomEvent('modulesLoaded', { detail: { success: false, error } }));

        // 사용자에게 알림
        alert('❌ 모듈 로딩 실패:\n\n' + (error?.message || String(error)) + '\n\n브라우저 콘솔을 확인해주세요.');
      });
  </script>
  <!-- 블로그 발행 크래시 방지 스크립트 -->
  <script>
    /**
     * 블로그 글 발행 시 크래시 방지 시스템
     * 주의: 전역 에러 핸들러는 main.js에서 처리하므로 여기서는 제거
     * console 함수 사용 금지 (재귀 방지)
     */
    (function () {
      'use strict';

      function safeExecute(func, context, args) {
        try {
          return func.apply(context, args);
        } catch (error) {
          // console.error 사용 안 함 - 브라우저 기본 동작에 맡김
          // UI에만 로깅 (addLog가 사용 가능한 경우)
          if (typeof window.addLog === 'function') {
            try {
              window.addLog(`❌ 함수 실행 오류: ${func.name || '익명'} - ${error.message}`, 'error');
            } catch (e) {
              // 무시
            }
          }
          return { ok: false, error: error.message };
        }
      }

      // 비동기 함수 안전 실행 래퍼
      async function safeExecuteAsync(func, context, args) {
        try {
          return await func.apply(context, args);
        } catch (error) {
          // console.error 사용 안 함 - 브라우저 기본 동작에 맡김
          // UI에만 로깅
          if (typeof window.addLog === 'function') {
            try {
              window.addLog(`❌ 비동기 함수 실행 오류: ${func.name || '익명'} - ${error.message}`, 'error');
            } catch (e) {
              // 무시
            }
          }
          return { ok: false, error: error.message };
        }
      }

      // 블로그 발행 함수 보호 (DOM 로드 후)
      function protectBlogFunctions() {
        setTimeout(function () {
          // publishToPlatform 함수 보호
          if (typeof window.publishToPlatform === 'function') {
            const originalPublish = window.publishToPlatform;
            window.publishToPlatform = async function (...args) {
              return await safeExecuteAsync(originalPublish, this, args);
            };
          }

          // runPosting 함수 보호
          if (typeof window.runPosting === 'function') {
            const originalRunPosting = window.runPosting;
            window.runPosting = async function (...args) {
              return await safeExecuteAsync(originalRunPosting, this, args);
            };
          }
        }, 1000);
      }

      // DOM 로드 후 실행
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', protectBlogFunctions);
      } else {
        protectBlogFunctions();
      }
    })();
  </script>

  <!-- 내부 링크 모듈 로드 -->
  <script src="./modules/internal-links.js"></script>
  <script src="./modules/internal-links-global.js"></script>

  <!-- 탭 전환 함수 -->
  <script>
    function showTab(tabName) {
      console.log('[TABS] 탭 전환 시도:', tabName);

      // 모든 탭 콘텐츠 숨기기
      const allTabs = [
        'main-tab',
        'thumbnail-tab',
        'settings-tab',
        'semi-auto-tab',
        'schedule-tab',
        'internal-links-tab'
      ];

      allTabs.forEach(id => {
        const tab = document.getElementById(id);
        if (tab) {
          tab.style.display = 'none';
          console.log('[TABS] 탭 숨김:', id);
        } else {
          console.warn('[TABS] 탭 요소를 찾을 수 없음:', id);
        }
      });

      // 선택한 탭 표시
      const targetTabId = tabName + '-tab';
      const targetTab = document.getElementById(targetTabId);
      if (targetTab) {
        targetTab.style.display = 'block';
        // 강제로 표시 (혹시 모를 CSS 문제 대비)
        targetTab.style.visibility = 'visible';
        targetTab.style.opacity = '1';
        console.log('[TABS] ✅ 탭 전환 완료:', tabName, '→', targetTabId);
      } else {
        console.error('[TABS] ❌ 탭을 찾을 수 없음:', targetTabId);
        console.error('[TABS] 사용 가능한 탭:', allTabs);
        // DOM에 실제로 존재하는 탭 확인
        allTabs.forEach(id => {
          const exists = document.getElementById(id);
          console.log('[TABS] 탭 존재 여부:', id, exists ? '✅' : '❌');
        });
      }

      // 탭 버튼 active 상태 업데이트
      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.classList.remove('active');
        // 버튼의 onclick 속성에서 탭 이름 추출하여 매칭
        const btnOnClick = btn.getAttribute('onclick');
        if (btnOnClick) {
          // 'internal-links' 같은 경우를 정확히 매칭
          const matchPattern = new RegExp(`['"]${tabName.replace('-', '\\-')}['"]`);
          if (matchPattern.test(btnOnClick)) {
            btn.classList.add('active');
            console.log('[TABS] 버튼 active 설정:', btn.textContent);
          }
        }
      });
    }

    // 전역 스코프에 노출
    window.showTab = showTab;

    console.log('[TABS] showTab 함수 등록 완료');
  </script>

  <!-- 🔥 Blogger OAuth 인증 및 다중 계정 관리 -->
  <script>
    // Blogger OAuth 인증 함수
    async function authenticateBlogger() {
      const blogId = document.getElementById('blogId')?.value?.trim();
      const clientId = document.getElementById('googleClientId')?.value?.trim();
      const clientSecret = document.getElementById('googleClientSecret')?.value?.trim();

      // 입력값 검증
      if (!blogId || !clientId || !clientSecret) {
        alert('❌ Blog ID, Client ID, Client Secret을 모두 입력해주세요.');
        return;
      }

      // 버튼 상태 변경
      const authBtn = document.getElementById('bloggerAuthBtn');
      const authStatus = document.getElementById('bloggerAuthStatus');
      if (authBtn) {
        authBtn.disabled = true;
        authBtn.innerHTML = '⏳ 인증 중...';
      }
      if (authStatus) {
        authStatus.textContent = '🔄 브라우저에서 Google 로그인 진행 중...';
        authStatus.style.color = '#0369a1';
      }

      try {
        // IPC를 통해 메인 프로세스에 OAuth 인증 요청
        if (window.electronAPI && window.electronAPI.authenticateBlogger) {
          const result = await window.electronAPI.authenticateBlogger({
            blogId,
            clientId,
            clientSecret
          });

          if (result.success) {
            if (authStatus) {
              authStatus.textContent = '✅ 인증 성공! 토큰이 저장되었습니다.';
              authStatus.style.color = '#059669';
            }
            if (authBtn) {
              authBtn.innerHTML = '✅ 인증 완료';
              authBtn.style.background = 'linear-gradient(135deg, #059669 0%, #047857 100%)';
            }

            // 계정 목록에 추가
            addAccountToList({
              blogId,
              email: result.email || 'Unknown',
              blogName: result.blogName || 'Blogger',
              authenticated: true
            });

            alert('✅ Blogger 인증이 완료되었습니다!');
          } else {
            throw new Error(result.error || '인증 실패');
          }
        } else {
          // electronAPI가 없는 경우 (개발 환경)
          alert('⚠️ Electron 환경에서만 OAuth 인증이 가능합니다.\n\n개발 모드에서는 수동으로 토큰을 설정해주세요.');
        }
      } catch (error) {
        console.error('Blogger 인증 오류:', error);
        if (authStatus) {
          authStatus.textContent = '❌ 인증 실패: ' + (error.message || '알 수 없는 오류');
          authStatus.style.color = '#dc2626';
        }
        if (authBtn) {
          authBtn.disabled = false;
          authBtn.innerHTML = '🚀 다시 시도';
        }
        alert('❌ 인증 실패:\n' + (error.message || '알 수 없는 오류') + '\n\n가이드를 확인하고 다시 시도해주세요.');
      }
    }

    // 다중 계정 추가
    function addBloggerAccount() {
      const blogId = document.getElementById('blogId')?.value?.trim();
      const clientId = document.getElementById('googleClientId')?.value?.trim();
      const clientSecret = document.getElementById('googleClientSecret')?.value?.trim();

      if (!blogId || !clientId || !clientSecret) {
        alert('❌ 먼저 Blog ID, Client ID, Client Secret을 입력하고 인증을 완료해주세요.');
        return;
      }

      // 현재 계정 정보 저장
      const accounts = JSON.parse(localStorage.getItem('bloggerAccounts') || '[]');
      const existingIndex = accounts.findIndex(a => a.blogId === blogId);

      const newAccount = {
        blogId,
        clientId,
        clientSecret,
        addedAt: new Date().toISOString(),
        name: '블로그 ' + (accounts.length + 1)
      };

      if (existingIndex >= 0) {
        accounts[existingIndex] = newAccount;
      } else {
        accounts.push(newAccount);
      }

      localStorage.setItem('bloggerAccounts', JSON.stringify(accounts));
      renderBloggerAccounts();
      alert('✅ 계정이 저장되었습니다.');
    }

    // 계정 목록 렌더링
    function renderBloggerAccounts() {
      const container = document.getElementById('bloggerAccountsList');
      if (!container) return;

      const accounts = JSON.parse(localStorage.getItem('bloggerAccounts') || '[]');

      if (accounts.length === 0) {
        container.innerHTML = '<p style="margin: 0; font-size: 12px; color: #64748b; text-align: center; padding: 12px;">저장된 계정이 없습니다</p>';
        return;
      }

      container.innerHTML = accounts.map((account, index) => `
        <div style="display: flex; align-items: center; justify-content: space-between; padding: 10px 12px; background: white; border-radius: 8px; border: 1px solid #e2e8f0;">
          <div style="display: flex; align-items: center; gap: 10px;">
            <span style="font-size: 18px;">🅱️</span>
            <div>
              <div style="font-weight: 600; color: #1e293b; font-size: 13px;">${account.name || '블로그 ' + (index + 1)}</div>
              <div style="font-size: 11px; color: #64748b;">ID: ${account.blogId.substring(0, 10)}...</div>
            </div>
          </div>
          <div style="display: flex; gap: 6px;">
            <button onclick="loadBloggerAccount(${index})" style="padding: 6px 10px; background: #3b82f6; color: white; border: none; border-radius: 6px; font-size: 11px; font-weight: 600; cursor: pointer;">불러오기</button>
            <button onclick="deleteBloggerAccount(${index})" style="padding: 6px 10px; background: #ef4444; color: white; border: none; border-radius: 6px; font-size: 11px; font-weight: 600; cursor: pointer;">삭제</button>
          </div>
        </div>
      `).join('');
    }

    // 계정 불러오기
    function loadBloggerAccount(index) {
      const accounts = JSON.parse(localStorage.getItem('bloggerAccounts') || '[]');
      const account = accounts[index];

      if (!account) return;

      document.getElementById('blogId').value = account.blogId || '';
      document.getElementById('googleClientId').value = account.clientId || '';
      document.getElementById('googleClientSecret').value = account.clientSecret || '';

      alert('✅ 계정 정보를 불러왔습니다. 인증하기 버튼을 클릭하세요.');
    }

    // 계정 삭제
    function deleteBloggerAccount(index) {
      if (!confirm('이 계정을 삭제하시겠습니까?')) return;

      const accounts = JSON.parse(localStorage.getItem('bloggerAccounts') || '[]');
      accounts.splice(index, 1);
      localStorage.setItem('bloggerAccounts', JSON.stringify(accounts));
      renderBloggerAccounts();
    }

    // 계정 목록에 추가 (인증 성공 시)
    function addAccountToList(accountInfo) {
      const accounts = JSON.parse(localStorage.getItem('bloggerAccounts') || '[]');
      const existingIndex = accounts.findIndex(a => a.blogId === accountInfo.blogId);

      if (existingIndex >= 0) {
        accounts[existingIndex] = { ...accounts[existingIndex], ...accountInfo };
      } else {
        accounts.push(accountInfo);
      }

      localStorage.setItem('bloggerAccounts', JSON.stringify(accounts));
      renderBloggerAccounts();
    }

    // Blogger 가이드 토글
    function toggleBloggerGuide() {
      const guide = document.getElementById('bloggerOAuthGuide');
      if (guide) {
        guide.style.display = guide.style.display === 'none' ? 'block' : 'none';
      }
    }

    // 플랫폼 선택
    function selectPlatform(platform) {
      // 라디오 버튼 체크
      const radio = document.getElementById('platform-' + platform);
      if (radio) radio.checked = true;

      // 선택 박스 스타일 업데이트
      const bloggerBox = document.getElementById('blogger-select-box');
      const wordpressBox = document.getElementById('wordpress-select-box');
      const bloggerFields = document.getElementById('blogger-fields');
      const wordpressFields = document.getElementById('wordpress-fields');

      if (platform === 'blogger') {
        if (bloggerBox) {
          bloggerBox.style.borderColor = '#f97316';
          bloggerBox.style.background = '#fff7ed';
        }
        if (wordpressBox) {
          wordpressBox.style.borderColor = '#e2e8f0';
          wordpressBox.style.background = 'white';
        }
        if (bloggerFields) bloggerFields.style.display = 'block';
        if (wordpressFields) wordpressFields.style.display = 'none';
      } else {
        if (wordpressBox) {
          wordpressBox.style.borderColor = '#6366f1';
          wordpressBox.style.background = '#f5f3ff';
        }
        if (bloggerBox) {
          bloggerBox.style.borderColor = '#e2e8f0';
          bloggerBox.style.background = 'white';
        }
        if (wordpressFields) wordpressFields.style.display = 'block';
        if (bloggerFields) bloggerFields.style.display = 'none';
      }

      // 상태 박스 업데이트
      const platformIcon = document.getElementById('platformIcon');
      const platformName = document.getElementById('platformName');
      const platformStatus = document.getElementById('platformStatus');

      if (platform === 'blogger') {
        if (platformIcon) platformIcon.textContent = '🅱️';
        if (platformName) platformName.textContent = 'Blogger';
        if (platformStatus) platformStatus.textContent = 'Google 블로그 플랫폼';
      } else {
        if (platformIcon) platformIcon.textContent = '🌐';
        if (platformName) platformName.textContent = 'WordPress';
        if (platformStatus) platformStatus.textContent = '자체 호스팅 블로그';
      }
    }

    // 페이지 로드 시 계정 목록 렌더링
    document.addEventListener('DOMContentLoaded', function () {
      renderBloggerAccounts();
      refreshConnectionStatus();
    });

    // 🔥 연동 상태 새로고침 함수
    async function refreshConnectionStatus() {
      // Gemini API 상태
      const geminiKey = document.getElementById('geminiKey')?.value?.trim();
      const geminiStatus = document.getElementById('status-gemini');
      const geminiText = document.getElementById('status-gemini-text');
      if (geminiKey) {
        if (geminiStatus) geminiStatus.textContent = '✅';
        if (geminiText) geminiText.textContent = '연동됨';
      } else {
        if (geminiStatus) geminiStatus.textContent = '❌';
        if (geminiText) geminiText.textContent = '미설정';
      }

      // 플랫폼 상태 (Blogger/WordPress)
      const blogId = document.getElementById('blogId')?.value?.trim();
      const wpUrl = document.getElementById('wordpressSiteUrl')?.value?.trim();
      const platformStatus = document.getElementById('status-platform');
      const platformText = document.getElementById('status-platform-text');
      if (blogId || wpUrl) {
        if (platformStatus) platformStatus.textContent = '✅';
        if (platformText) platformText.textContent = blogId ? 'Blogger 연동됨' : 'WordPress 연동됨';
      } else {
        if (platformStatus) platformStatus.textContent = '❌';
        if (platformText) platformText.textContent = '미설정';
      }

      // 네이버 API 상태
      const naverId = document.getElementById('naverCustomerId')?.value?.trim();
      const naverSecret = document.getElementById('naverSecretKey')?.value?.trim();
      const naverStatus = document.getElementById('status-naver');
      const naverText = document.getElementById('status-naver-text');
      if (naverId && naverSecret) {
        if (naverStatus) naverStatus.textContent = '✅';
        if (naverText) naverText.textContent = '연동됨';
      } else {
        if (naverStatus) naverStatus.textContent = '⚪';
        if (naverText) naverText.textContent = '선택사항';
      }

      // Google CSE 상태
      const cseKey = document.getElementById('googleCseKey')?.value?.trim();
      const cseCx = document.getElementById('googleCseCx')?.value?.trim();
      const cseStatus = document.getElementById('status-cse');
      const cseText = document.getElementById('status-cse-text');
      if (cseKey && cseCx) {
        if (cseStatus) cseStatus.textContent = '✅';
        if (cseText) cseText.textContent = '연동됨';
      } else {
        if (cseStatus) cseStatus.textContent = '⚪';
        if (cseText) cseText.textContent = '선택사항';
      }
    }

    // 전역 스코프에 노출
    window.authenticateBlogger = authenticateBlogger;
    window.addBloggerAccount = addBloggerAccount;
    window.loadBloggerAccount = loadBloggerAccount;
    window.deleteBloggerAccount = deleteBloggerAccount;
    window.toggleBloggerGuide = toggleBloggerGuide;
    window.selectPlatform = selectPlatform;
    window.refreshConnectionStatus = refreshConnectionStatus;
  </script>

  <!-- 🔥 다중계정 관리 및 동시 발행 모달 -->
  <div id="multiAccountModal"
    style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.9); backdrop-filter: blur(10px); z-index: 10000; overflow-y: auto;">
    <div style="max-width: 1200px; margin: 20px auto; padding: 20px;">
      <!-- 헤더 -->
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div style="display: flex; align-items: center; gap: 16px;">
          <div
            style="width: 60px; height: 60px; background: linear-gradient(135deg, #8b5cf6, #6d28d9); border-radius: 16px; display: flex; align-items: center; justify-content: center;">
            <span style="font-size: 32px;">👥</span>
          </div>
          <div>
            <h2 style="margin: 0; color: white; font-size: 28px; font-weight: 800;">다중계정 관리 & 동시 발행</h2>
            <p style="margin: 4px 0 0 0; color: rgba(255,255,255,0.7); font-size: 14px;">최대 10개 계정 동시 발행 | 연속 대량 발행 지원
            </p>
          </div>
        </div>
        <button onclick="closeMultiAccountModal()"
          style="width: 50px; height: 50px; background: rgba(255,255,255,0.1); border: 2px solid rgba(255,255,255,0.2); border-radius: 14px; color: white; font-size: 24px; cursor: pointer;">✕</button>
      </div>

      <!-- 계정 추가 버튼들 -->
      <div style="display: flex; gap: 12px; margin-bottom: 24px;">
        <button onclick="addMultiAccount('blogger')"
          style="flex: 1; padding: 16px; background: linear-gradient(135deg, #f97316, #ea580c); border: none; border-radius: 12px; color: white; font-size: 15px; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px;">
          <span style="font-size: 20px;">🅱️</span> Blogger 계정 추가
        </button>
        <button onclick="addMultiAccount('wordpress')"
          style="flex: 1; padding: 16px; background: linear-gradient(135deg, #3b82f6, #2563eb); border: none; border-radius: 12px; color: white; font-size: 15px; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px;">
          <span style="font-size: 20px;">🌐</span> WordPress 계정 추가
        </button>
      </div>

      <!-- 계정 목록 -->
      <div id="multiAccountList" style="display: flex; flex-direction: column; gap: 16px; margin-bottom: 24px;">
        <!-- 계정 카드들이 여기에 동적으로 추가됩니다 -->
        <div
          style="text-align: center; padding: 40px; background: rgba(255,255,255,0.05); border-radius: 16px; border: 2px dashed rgba(255,255,255,0.2);">
          <span style="font-size: 48px;">📭</span>
          <p style="color: rgba(255,255,255,0.6); margin: 16px 0 0 0;">등록된 계정이 없습니다. 위 버튼으로 계정을 추가하세요.</p>
        </div>
      </div>

      <!-- 동시 발행 설정 -->
      <div
        style="background: linear-gradient(135deg, #1e293b, #334155); border-radius: 16px; padding: 24px; margin-bottom: 24px; border: 2px solid rgba(139, 92, 246, 0.3);">
        <h3
          style="margin: 0 0 20px 0; color: white; font-size: 18px; font-weight: 700; display: flex; align-items: center; gap: 10px;">
          <span style="font-size: 24px;">⚡</span> 동시 발행 설정
        </h3>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px;">
          <div>
            <label
              style="display: block; color: rgba(255,255,255,0.8); font-size: 13px; font-weight: 600; margin-bottom: 8px;">발행
              모드</label>
            <select id="multiPublishMode"
              style="width: 100%; padding: 12px; background: rgba(255,255,255,0.1); border: 2px solid rgba(255,255,255,0.2); border-radius: 10px; color: white; font-size: 14px;">
              <option value="simultaneous">🚀 동시 발행 (선택된 계정 한번에)</option>
              <option value="sequential">📋 순차 발행 (하나씩 차례로)</option>
              <option value="batch">🔄 연속 대량 발행 (무한 반복)</option>
            </select>
          </div>
          <div>
            <label
              style="display: block; color: rgba(255,255,255,0.8); font-size: 13px; font-weight: 600; margin-bottom: 8px;">발행
              간격 (순차/연속 모드)</label>
            <select id="multiPublishInterval"
              style="width: 100%; padding: 12px; background: rgba(255,255,255,0.1); border: 2px solid rgba(255,255,255,0.2); border-radius: 10px; color: white; font-size: 14px;">
              <option value="0">즉시 (간격 없음)</option>
              <option value="30">30초</option>
              <option value="60" selected>1분</option>
              <option value="180">3분</option>
              <option value="300">5분</option>
              <option value="600">10분</option>
            </select>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
          <div>
            <label
              style="display: block; color: rgba(255,255,255,0.8); font-size: 13px; font-weight: 600; margin-bottom: 8px;">연속
              발행 횟수 (대량 발행 모드)</label>
            <input type="number" id="multiPublishCount" value="10" min="1" max="100"
              style="width: 100%; padding: 12px; background: rgba(255,255,255,0.1); border: 2px solid rgba(255,255,255,0.2); border-radius: 10px; color: white; font-size: 14px; box-sizing: border-box;">
          </div>
          <div>
            <label
              style="display: block; color: rgba(255,255,255,0.8); font-size: 13px; font-weight: 600; margin-bottom: 8px;">선택된
              계정</label>
            <div id="selectedAccountCount"
              style="padding: 12px; background: rgba(139, 92, 246, 0.2); border: 2px solid rgba(139, 92, 246, 0.4); border-radius: 10px; color: #a78bfa; font-size: 14px; font-weight: 700; text-align: center;">
              0개 선택됨
            </div>
          </div>
        </div>
      </div>

      <!-- 발행 버튼 -->
      <div style="display: flex; gap: 16px;">
        <button onclick="startMultiPublish()" id="multiPublishBtn"
          style="flex: 2; padding: 20px; background: linear-gradient(135deg, #ffd700, #ff8c00); border: none; border-radius: 14px; color: #1e293b; font-size: 18px; font-weight: 900; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 12px; box-shadow: 0 8px 30px rgba(255, 215, 0, 0.5);">
          <span style="font-size: 28px;">🚀</span>
          <span>선택된 계정 동시 발행 시작</span>
        </button>
        <button onclick="stopMultiPublish()" id="multiStopBtn"
          style="flex: 1; padding: 20px; background: linear-gradient(135deg, #ef4444, #dc2626); border: none; border-radius: 14px; color: white; font-size: 16px; font-weight: 700; cursor: pointer; display: none; align-items: center; justify-content: center; gap: 10px;">
          <span style="font-size: 24px;">⏹️</span>
          <span>발행 중단</span>
        </button>
      </div>

      <!-- 발행 진행 상황 -->
      <div id="multiPublishProgress"
        style="display: none; margin-top: 24px; background: rgba(255,255,255,0.05); border-radius: 16px; padding: 20px;">
        <h4 style="margin: 0 0 16px 0; color: white; font-size: 16px; font-weight: 700;">📊 발행 진행 상황</h4>
        <div id="multiPublishLog"
          style="max-height: 300px; overflow-y: auto; font-family: monospace; font-size: 12px; color: rgba(255,255,255,0.8); background: rgba(0,0,0,0.3); border-radius: 10px; padding: 16px;">
          <!-- 로그가 여기에 표시됩니다 -->
        </div>
      </div>
    </div>
  </div>

  <!-- 🔥 다중계정 관리 JavaScript -->
  <script>
    // 다중 계정 저장소
    let multiAccounts = JSON.parse(localStorage.getItem('multiAccounts') || '[]');
    let isMultiPublishing = false;
    let multiPublishAbort = false;

    // 모달 열기
    function openMultiAccountModal() {
      document.getElementById('multiAccountModal').style.display = 'block';
      renderMultiAccountList();
    }

    // 모달 닫기
    function closeMultiAccountModal() {
      document.getElementById('multiAccountModal').style.display = 'none';
    }

    // 계정 추가
    function addMultiAccount(type) {
      const id = 'acc_' + Date.now();
      const newAccount = {
        id,
        type, // 'blogger' or 'wordpress'
        name: type === 'blogger' ? 'Blogger 계정 ' + (multiAccounts.filter(a => a.type === 'blogger').length + 1) : 'WordPress 계정 ' + (multiAccounts.filter(a => a.type === 'wordpress').length + 1),
        enabled: true,
        settings: {
          // Blogger 설정
          blogId: '',
          clientId: '',
          clientSecret: '',
          // WordPress 설정
          siteUrl: '',
          username: '',
          password: '',
          // 공통 설정
          keyword: '',
          crawlUrl: '',
          imageSource: 'nanobananapro',
          toneStyle: 'professional',
          contentMode: 'external'
        }
      };

      multiAccounts.push(newAccount);
      saveMultiAccounts();
      renderMultiAccountList();
    }

    // 계정 삭제
    function deleteMultiAccount(id) {
      if (!confirm('이 계정을 삭제하시겠습니까?')) return;
      multiAccounts = multiAccounts.filter(a => a.id !== id);
      saveMultiAccounts();
      renderMultiAccountList();
    }

    // 계정 토글
    function toggleMultiAccount(id) {
      const account = multiAccounts.find(a => a.id === id);
      if (account) {
        account.enabled = !account.enabled;
        saveMultiAccounts();
        renderMultiAccountList();
      }
    }

    // 계정 설정 업데이트
    function updateMultiAccountSetting(id, field, value) {
      const account = multiAccounts.find(a => a.id === id);
      if (account) {
        if (field === 'name') {
          account.name = value;
        } else {
          account.settings[field] = value;
        }
        saveMultiAccounts();
      }
    }

    // 저장
    function saveMultiAccounts() {
      localStorage.setItem('multiAccounts', JSON.stringify(multiAccounts));
      updateSelectedCount();
    }

    // 선택된 계정 수 업데이트
    function updateSelectedCount() {
      const count = multiAccounts.filter(a => a.enabled).length;
      const el = document.getElementById('selectedAccountCount');
      if (el) el.textContent = count + '개 선택됨';
    }

    // 계정 목록 렌더링
    function renderMultiAccountList() {
      const container = document.getElementById('multiAccountList');
      if (!container) return;

      if (multiAccounts.length === 0) {
        container.innerHTML = `
          <div style="text-align: center; padding: 40px; background: rgba(255,255,255,0.05); border-radius: 16px; border: 2px dashed rgba(255,255,255,0.2);">
            <span style="font-size: 48px;">📭</span>
            <p style="color: rgba(255,255,255,0.6); margin: 16px 0 0 0;">등록된 계정이 없습니다. 위 버튼으로 계정을 추가하세요.</p>
          </div>
        `;
        updateSelectedCount();
        return;
      }

      container.innerHTML = multiAccounts.map(account => `
        <div style="background: ${account.enabled ? 'linear-gradient(135deg, rgba(139, 92, 246, 0.15), rgba(109, 40, 217, 0.15))' : 'rgba(255,255,255,0.05)'}; border: 2px solid ${account.enabled ? 'rgba(139, 92, 246, 0.5)' : 'rgba(255,255,255,0.1)'}; border-radius: 16px; padding: 20px; transition: all 0.3s ease;">
          <!-- 헤더 -->
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
            <div style="display: flex; align-items: center; gap: 12px;">
              <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                <input type="checkbox" ${account.enabled ? 'checked' : ''} onchange="toggleMultiAccount('${account.id}')" style="width: 20px; height: 20px; accent-color: #8b5cf6;">
                <span style="font-size: 24px;">${account.type === 'blogger' ? '🅱️' : '🌐'}</span>
              </label>
              <input type="text" value="${account.name}" onchange="updateMultiAccountSetting('${account.id}', 'name', this.value)" style="background: transparent; border: none; color: white; font-size: 16px; font-weight: 700; width: 200px;">
            </div>
            <button onclick="deleteMultiAccount('${account.id}')" style="padding: 8px 16px; background: rgba(239, 68, 68, 0.2); border: 1px solid rgba(239, 68, 68, 0.4); border-radius: 8px; color: #f87171; font-size: 12px; font-weight: 600; cursor: pointer;">🗑️ 삭제</button>
          </div>
          
          <!-- 설정 그리드 -->
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;">
            ${account.type === 'blogger' ? `
              <div>
                <label style="display: block; color: rgba(255,255,255,0.6); font-size: 11px; margin-bottom: 4px;">Blog ID</label>
                <input type="text" value="${account.settings.blogId || ''}" onchange="updateMultiAccountSetting('${account.id}', 'blogId', this.value)" placeholder="블로그 ID" style="width: 100%; padding: 10px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: white; font-size: 13px; box-sizing: border-box;">
              </div>
              <div>
                <label style="display: block; color: rgba(255,255,255,0.6); font-size: 11px; margin-bottom: 4px;">Client ID</label>
                <input type="text" value="${account.settings.clientId || ''}" onchange="updateMultiAccountSetting('${account.id}', 'clientId', this.value)" placeholder="OAuth Client ID" style="width: 100%; padding: 10px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: white; font-size: 13px; box-sizing: border-box;">
              </div>
              <div>
                <label style="display: block; color: rgba(255,255,255,0.6); font-size: 11px; margin-bottom: 4px;">Client Secret</label>
                <input type="password" value="${account.settings.clientSecret || ''}" onchange="updateMultiAccountSetting('${account.id}', 'clientSecret', this.value)" placeholder="OAuth Secret" style="width: 100%; padding: 10px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: white; font-size: 13px; box-sizing: border-box;">
              </div>
            ` : `
              <div>
                <label style="display: block; color: rgba(255,255,255,0.6); font-size: 11px; margin-bottom: 4px;">Site URL</label>
                <input type="text" value="${account.settings.siteUrl || ''}" onchange="updateMultiAccountSetting('${account.id}', 'siteUrl', this.value)" placeholder="https://yoursite.com" style="width: 100%; padding: 10px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: white; font-size: 13px; box-sizing: border-box;">
              </div>
              <div>
                <label style="display: block; color: rgba(255,255,255,0.6); font-size: 11px; margin-bottom: 4px;">Username</label>
                <input type="text" value="${account.settings.username || ''}" onchange="updateMultiAccountSetting('${account.id}', 'username', this.value)" placeholder="관리자 아이디" style="width: 100%; padding: 10px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: white; font-size: 13px; box-sizing: border-box;">
              </div>
              <div>
                <label style="display: block; color: rgba(255,255,255,0.6); font-size: 11px; margin-bottom: 4px;">App Password</label>
                <input type="password" value="${account.settings.password || ''}" onchange="updateMultiAccountSetting('${account.id}', 'password', this.value)" placeholder="애플리케이션 비밀번호" style="width: 100%; padding: 10px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: white; font-size: 13px; box-sizing: border-box;">
              </div>
            `}
            <div>
              <label style="display: block; color: rgba(255,255,255,0.6); font-size: 11px; margin-bottom: 4px;">키워드</label>
              <input type="text" value="${account.settings.keyword || ''}" onchange="updateMultiAccountSetting('${account.id}', 'keyword', this.value)" placeholder="발행할 키워드" style="width: 100%; padding: 10px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: white; font-size: 13px; box-sizing: border-box;">
            </div>
            <div>
              <label style="display: block; color: rgba(255,255,255,0.6); font-size: 11px; margin-bottom: 4px;">크롤링 URL (선택)</label>
              <input type="text" value="${account.settings.crawlUrl || ''}" onchange="updateMultiAccountSetting('${account.id}', 'crawlUrl', this.value)" placeholder="제품 링크" style="width: 100%; padding: 10px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: white; font-size: 13px; box-sizing: border-box;">
            </div>
            <div>
              <label style="display: block; color: rgba(255,255,255,0.6); font-size: 11px; margin-bottom: 4px;">이미지 소스</label>
              <select onchange="updateMultiAccountSetting('${account.id}', 'imageSource', this.value)" style="width: 100%; padding: 10px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: white; font-size: 13px;">
                <option value="nanobananapro" ${account.settings.imageSource === 'nanobananapro' ? 'selected' : ''}>🍌 Nano Banana Pro</option>
                <option value="deepinfra" ${account.settings.imageSource === 'deepinfra' ? 'selected' : ''}>🔥 DeepInfra FLUX-2</option>
                <option value="stability" ${account.settings.imageSource === 'stability' ? 'selected' : ''}>🚀 Stability AI</option>
                <option value="pollinations" ${account.settings.imageSource === 'pollinations' ? 'selected' : ''}>🌸 Pollinations (무료)</option>
                <option value="none" ${account.settings.imageSource === 'none' ? 'selected' : ''}>❌ 이미지 없음</option>
              </select>
            </div>
          </div>
        </div>
      `).join('');

      updateSelectedCount();
    }

    // 동시 발행 시작
    async function startMultiPublish() {
      const enabledAccounts = multiAccounts.filter(a => a.enabled);

      if (enabledAccounts.length === 0) {
        alert('발행할 계정을 선택해주세요.');
        return;
      }

      // 키워드 확인
      const missingKeyword = enabledAccounts.find(a => !a.settings.keyword?.trim());
      if (missingKeyword) {
        alert(`"${missingKeyword.name}" 계정에 키워드가 입력되지 않았습니다.`);
        return;
      }

      isMultiPublishing = true;
      multiPublishAbort = false;

      // UI 업데이트
      document.getElementById('multiPublishBtn').style.display = 'none';
      document.getElementById('multiStopBtn').style.display = 'flex';
      document.getElementById('multiPublishProgress').style.display = 'block';

      const logContainer = document.getElementById('multiPublishLog');
      logContainer.innerHTML = '';

      const mode = document.getElementById('multiPublishMode').value;
      const interval = parseInt(document.getElementById('multiPublishInterval').value) * 1000;
      const batchCount = parseInt(document.getElementById('multiPublishCount').value);

      const addLog = (msg, type = 'info') => {
        const colors = { info: '#60a5fa', success: '#34d399', error: '#f87171', warning: '#fbbf24' };
        const time = new Date().toLocaleTimeString();
        logContainer.innerHTML += `<div style="color: ${colors[type]}; margin-bottom: 4px;">[${time}] ${msg}</div>`;
        logContainer.scrollTop = logContainer.scrollHeight;
      };

      addLog(`🚀 ${mode === 'simultaneous' ? '동시' : mode === 'sequential' ? '순차' : '연속 대량'} 발행 시작 - ${enabledAccounts.length}개 계정`, 'info');

      try {
        if (mode === 'simultaneous') {
          // 동시 발행 - 모든 계정 병렬 처리
          addLog(`⚡ ${enabledAccounts.length}개 계정 동시 발행 중...`, 'info');

          const promises = enabledAccounts.map(async (account) => {
            try {
              addLog(`📝 [${account.name}] 발행 시작: "${account.settings.keyword}"`, 'info');
              await publishToAccount(account);
              addLog(`✅ [${account.name}] 발행 완료!`, 'success');
              return { account, success: true };
            } catch (error) {
              addLog(`❌ [${account.name}] 발행 실패: ${error.message}`, 'error');
              return { account, success: false, error };
            }
          });

          const results = await Promise.all(promises);
          const successCount = results.filter(r => r.success).length;
          addLog(`🎉 동시 발행 완료! 성공: ${successCount}/${enabledAccounts.length}`, 'success');

        } else if (mode === 'sequential') {
          // 순차 발행
          for (let i = 0; i < enabledAccounts.length; i++) {
            if (multiPublishAbort) {
              addLog('⏹️ 발행이 중단되었습니다.', 'warning');
              break;
            }

            const account = enabledAccounts[i];
            addLog(`📝 [${i + 1}/${enabledAccounts.length}] [${account.name}] 발행 시작: "${account.settings.keyword}"`, 'info');

            try {
              await publishToAccount(account);
              addLog(`✅ [${account.name}] 발행 완료!`, 'success');
            } catch (error) {
              addLog(`❌ [${account.name}] 발행 실패: ${error.message}`, 'error');
            }

            if (i < enabledAccounts.length - 1 && interval > 0) {
              addLog(`⏳ ${interval / 1000}초 대기 중...`, 'info');
              await new Promise(resolve => setTimeout(resolve, interval));
            }
          }
          addLog('🎉 순차 발행 완료!', 'success');

        } else if (mode === 'batch') {
          // 연속 대량 발행
          for (let batch = 0; batch < batchCount; batch++) {
            if (multiPublishAbort) {
              addLog('⏹️ 발행이 중단되었습니다.', 'warning');
              break;
            }

            addLog(`🔄 [라운드 ${batch + 1}/${batchCount}] 시작`, 'info');

            for (let i = 0; i < enabledAccounts.length; i++) {
              if (multiPublishAbort) break;

              const account = enabledAccounts[i];
              addLog(`📝 [${account.name}] 발행 시작: "${account.settings.keyword}"`, 'info');

              try {
                await publishToAccount(account);
                addLog(`✅ [${account.name}] 발행 완료!`, 'success');
              } catch (error) {
                addLog(`❌ [${account.name}] 발행 실패: ${error.message}`, 'error');
              }

              if (interval > 0) {
                addLog(`⏳ ${interval / 1000}초 대기 중...`, 'info');
                await new Promise(resolve => setTimeout(resolve, interval));
              }
            }

            if (batch < batchCount - 1) {
              addLog(`✨ 라운드 ${batch + 1} 완료. 다음 라운드 준비...`, 'success');
            }
          }
          addLog(`🎉 연속 대량 발행 완료! 총 ${batchCount * enabledAccounts.length}개 발행 시도`, 'success');
        }

      } catch (error) {
        addLog(`❌ 오류 발생: ${error.message}`, 'error');
      }

      // UI 복원
      isMultiPublishing = false;
      document.getElementById('multiPublishBtn').style.display = 'flex';
      document.getElementById('multiStopBtn').style.display = 'none';
    }

    // 발행 중단
    function stopMultiPublish() {
      multiPublishAbort = true;
    }

    // 개별 계정 발행
    async function publishToAccount(account) {
      // 실제 발행 로직 - runMultiAccountPost API 호출
      const payload = {
        platform: account.type,
        keyword: account.settings.keyword,
        crawlUrl: account.settings.crawlUrl || '',
        imageSource: account.settings.imageSource || 'nanobananapro',
        toneStyle: account.settings.toneStyle || 'professional',
        contentMode: account.settings.contentMode || 'external',
        // Blogger 설정
        blogId: account.settings.blogId || '',
        googleClientId: account.settings.clientId || '',
        googleClientSecret: account.settings.clientSecret || '',
        // WordPress 설정
        wordpressSiteUrl: account.settings.siteUrl || '',
        wordpressUsername: account.settings.username || '',
        wordpressPassword: account.settings.password || ''
      };

      console.log('[MULTI-PUBLISH] 🚀 발행 요청:', account.name, payload.keyword);

      // 실제 발행 API 호출 - runMultiAccountPost 사용
      if (window.electronAPI && window.electronAPI.runMultiAccountPost) {
        const result = await window.electronAPI.runMultiAccountPost(payload);
        if (!result.ok) {
          throw new Error(result.error || '발행 실패');
        }
        console.log('[MULTI-PUBLISH] ✅ 발행 성공:', result.url);
        return result;
      } else if (window.blogger && window.blogger.runMultiAccountPost) {
        const result = await window.blogger.runMultiAccountPost(payload);
        if (!result.ok) {
          throw new Error(result.error || '발행 실패');
        }
        console.log('[MULTI-PUBLISH] ✅ 발행 성공:', result.url);
        return result;
      } else {
        throw new Error('발행 API를 찾을 수 없습니다. 앱을 재시작해주세요.');
      }
    }

    // 전역 노출
    window.openMultiAccountModal = openMultiAccountModal;
    window.closeMultiAccountModal = closeMultiAccountModal;
    window.addMultiAccount = addMultiAccount;
    window.deleteMultiAccount = deleteMultiAccount;
    window.toggleMultiAccount = toggleMultiAccount;
    window.updateMultiAccountSetting = updateMultiAccountSetting;
    window.startMultiPublish = startMultiPublish;
    window.stopMultiPublish = stopMultiPublish;

    // API 키 발급 모달 함수
    window.openApiKeyGuideModal = function () {
      const modal = document.getElementById('apiKeyGuideModal');
      if (modal) {
        modal.style.display = 'flex';
      }
    };
    window.closeApiKeyGuideModal = function () {
      const modal = document.getElementById('apiKeyGuideModal');
      if (modal) {
        modal.style.display = 'none';
      }
    };
    // API 키 발급 페이지 열기 함수들
    window.openApiPage = function (provider) {
      const urls = {
        'gemini': 'https://aistudio.google.com/app/apikey',
        'perplexity': 'https://www.perplexity.ai/settings/api',
        'deepinfra': 'https://deepinfra.com/dash/api_keys',
        'naver': 'https://developers.naver.com/apps/#/register',
        'cse': 'https://programmablesearchengine.google.com/controlpanel/all'
      };
      const url = urls[provider];
      if (url) {
        window.electronAPI?.openExternal?.(url) || window.open(url, '_blank');
        closeApiKeyGuideModal();
      }
    };
  </script>

  <!-- 🔑 API 키 발급 모달 -->
  <div id="apiKeyGuideModal"
    style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(20px); z-index: 10001; align-items: center; justify-content: center;">
    <div
      style="width: 90%; max-width: 550px; background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); border-radius: 24px; padding: 40px; box-shadow: 0 30px 80px rgba(0, 0, 0, 0.6); border: 2px solid rgba(255, 255, 255, 0.1);">

      <!-- 헤더 -->
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px;">
        <div style="display: flex; align-items: center; gap: 16px;">
          <div
            style="width: 56px; height: 56px; background: linear-gradient(135deg, #10b981 0%, #059669 100%); border-radius: 16px; display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 25px rgba(16, 185, 129, 0.4);">
            <span style="font-size: 28px;">🔑</span>
          </div>
          <div>
            <h2 style="font-size: 24px; font-weight: 800; color: white; margin: 0;">API 키 발급받기</h2>
            <p style="font-size: 13px; color: rgba(255, 255, 255, 0.6); margin: 4px 0 0 0;">클릭하면 브라우저에서 열립니다</p>
          </div>
        </div>
        <button onclick="closeApiKeyGuideModal()"
          style="width: 44px; height: 44px; background: rgba(255,255,255,0.1); border: 2px solid rgba(255,255,255,0.2); border-radius: 12px; color: white; font-size: 18px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease;"
          onmouseover="this.style.background='rgba(239, 68, 68, 0.8)'"
          onmouseout="this.style.background='rgba(255,255,255,0.1)'">✕</button>
      </div>

      <!-- API 발급 버튼들 -->
      <div style="display: flex; flex-direction: column; gap: 14px;">

        <!-- Gemini API -->
        <button onclick="openApiPage('gemini')"
          style="width: 100%; padding: 20px 24px; background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); color: white; border: none; border-radius: 16px; font-size: 16px; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 16px; box-shadow: 0 8px 25px rgba(239, 68, 68, 0.4); transition: all 0.3s ease;"
          onmouseover="this.style.transform='translateX(8px)'; this.style.boxShadow='0 12px 35px rgba(239, 68, 68, 0.5)';"
          onmouseout="this.style.transform='translateX(0)'; this.style.boxShadow='0 8px 25px rgba(239, 68, 68, 0.4)';">
          <span style="font-size: 28px;">🚀</span>
          <span style="flex: 1; text-align: left;">Gemini API 키 발급하러 가기</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </button>

        <!-- Perplexity API -->
        <button onclick="openApiPage('perplexity')"
          style="width: 100%; padding: 20px 24px; background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%); color: white; border: none; border-radius: 16px; font-size: 16px; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 16px; box-shadow: 0 8px 25px rgba(139, 92, 246, 0.4); transition: all 0.3s ease;"
          onmouseover="this.style.transform='translateX(8px)'; this.style.boxShadow='0 12px 35px rgba(139, 92, 246, 0.5)';"
          onmouseout="this.style.transform='translateX(0)'; this.style.boxShadow='0 8px 25px rgba(139, 92, 246, 0.4)';">
          <span style="font-size: 28px;">🔮</span>
          <span style="flex: 1; text-align: left;">Perplexity API 키 발급하러 가기</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </button>

        <!-- DeepInfra API -->
        <button onclick="openApiPage('deepinfra')"
          style="width: 100%; padding: 20px 24px; background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); color: white; border: none; border-radius: 16px; font-size: 16px; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 16px; box-shadow: 0 8px 25px rgba(59, 130, 246, 0.4); transition: all 0.3s ease;"
          onmouseover="this.style.transform='translateX(8px)'; this.style.boxShadow='0 12px 35px rgba(59, 130, 246, 0.5)';"
          onmouseout="this.style.transform='translateX(0)'; this.style.boxShadow='0 8px 25px rgba(59, 130, 246, 0.4)';">
          <span style="font-size: 28px;">🔵</span>
          <span style="flex: 1; text-align: left;">DeepInfra API 키 발급하러 가기</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </button>

        <!-- 네이버 API -->
        <button onclick="openApiPage('naver')"
          style="width: 100%; padding: 20px 24px; background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white; border: none; border-radius: 16px; font-size: 16px; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 16px; box-shadow: 0 8px 25px rgba(16, 185, 129, 0.4); transition: all 0.3s ease;"
          onmouseover="this.style.transform='translateX(8px)'; this.style.boxShadow='0 12px 35px rgba(16, 185, 129, 0.5)';"
          onmouseout="this.style.transform='translateX(0)'; this.style.boxShadow='0 8px 25px rgba(16, 185, 129, 0.4)';">
          <span style="font-size: 28px;">🟢</span>
          <span style="flex: 1; text-align: left;">네이버 API 키 발급하러 가기</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </button>

        <!-- Google CSE -->
        <button onclick="openApiPage('cse')"
          style="width: 100%; padding: 20px 24px; background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: white; border: none; border-radius: 16px; font-size: 16px; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 16px; box-shadow: 0 8px 25px rgba(245, 158, 11, 0.4); transition: all 0.3s ease;"
          onmouseover="this.style.transform='translateX(8px)'; this.style.boxShadow='0 12px 35px rgba(245, 158, 11, 0.5)';"
          onmouseout="this.style.transform='translateX(0)'; this.style.boxShadow='0 8px 25px rgba(245, 158, 11, 0.4)';">
          <span style="font-size: 28px;">🟡</span>
          <span style="flex: 1; text-align: left;">Google CSE 발급하러 가기</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </button>

      </div>

      <!-- 안내 메시지 -->
      <div
        style="margin-top: 24px; padding: 16px; background: rgba(16, 185, 129, 0.15); border-radius: 12px; border-left: 4px solid #10b981;">
        <p style="margin: 0; font-size: 13px; color: rgba(255, 255, 255, 0.8); line-height: 1.6;">
          💡 <strong style="color: #6ee7b7;">Gemini API 키 하나만 있으면</strong> 글 생성과 이미지 생성 모두 가능합니다!
        </p>
      </div>
    </div>
  </div>

</body>

</html>