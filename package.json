{
  "name": "lba",
  "version": "3.1.1",
  "description": "LEADERNAM Orbit - AI-powered blog automation",
  "main": "electron/main.js",
  "scripts": {
    "test:blog-analyzer": "ts-node test-naver-blog-analyzer.ts",
    "ultimate-blog": "ts-node src/core/ultimate-blog.ts",
    "test:ultimate": "ts-node test-ultimate-blog.ts",
    "test:blog-stats": "ts-node test-blog-stats-extraction.ts",
    "build": "node --max-old-space-size=8192 node_modules/typescript/bin/tsc && node --max-old-space-size=8192 node_modules/typescript/bin/tsc -p tsconfig.electron.json && node -e \"const fs = require('fs'); const path = require('path'); if (!fs.existsSync('dist/core')) fs.mkdirSync('dist/core', { recursive: true }); fs.copyFileSync('src/core/blogger-publisher.js', 'dist/core/blogger-publisher.js'); if (fs.existsSync('dist/wordpress/wordpress-publisher.js')) { fs.copyFileSync('dist/wordpress/wordpress-publisher.js', 'src/wordpress/wordpress-publisher.js'); console.log('✅ wordpress-publisher.js synced from dist to src'); }\" && node copy-ui.js",
    "start": "cross-env NODE_ENV=development electron .",
    "start:prod": "electron .",
    "dev": "ts-node src/core/index.ts",
    "test": "jest",
    "test:posting": "ts-node test-posting.ts",
    "test:realtime": "ts-node test-realtime-keywords.ts",
    "test:daum-sections": "node test-daum-sections.js",
    "test:blogger-api": "node test-blogger-api.js",
    "test:posting-execution": "node test-posting-execution.js",
    "test:publish": "ts-node test-publish.ts",
    "test:blogger": "ts-node test-blogger-only.ts",
    "test:thumbnail": "ts-node test-thumbnail.ts",
    "test:env": "ts-node test-env-and-thumbnail.ts",
    "test:post-generation": "ts-node test-post-generation.ts",
    "test:post-simple": "ts-node test-post-generation-simple.ts",
    "test:quick-validate": "ts-node 빠른_검증_스크립트.ts",
    "test:detailed-validate": "ts-node 상세_검증_스크립트.ts",
    "api:blog-index": "ts-node start-blog-index-api.ts",
    "test:api": "ts-node test-blog-index-api.ts",
    "test:coupang-advanced": "ts-node test-coupang-advanced.ts",
    "crawl": "ts-node src/cli.ts crawl",
    "generate": "ts-node src/cli.ts generate",
    "watch": "tsc --watch",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder --win --mac --linux",
    "pack": "npm run build && node setup-pack-env.js && electron-builder --dir",
    "setup-pack-env": "node setup-pack-env.js",
    "pre-release": "node scripts/pre-release-check.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@types/bcryptjs": "^2.4.6",
    "axios": "^1.13.0",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.1.2",
    "dayjs": "^1.11.18",
    "dotenv": "^16.3.1",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "ghost-cursor": "^1.4.2",
    "googleapis": "^164.1.0",
    "helmet": "^8.1.0",
    "openai": "^4.20.0",
    "p-limit": "^5.0.0",
    "p-queue": "^8.0.1",
    "playwright": "^1.56.1",
    "puppeteer": "^21.11.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-adblocker": "^2.13.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "xlsx": "^0.18.5"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@fontsource/noto-sans-kr": "^5.2.9",
    "@types/cheerio": "^0.22.31",
    "@types/express": "^5.0.5",
    "@types/jest": "^29.5.8",
    "@types/natural": "^6.0.0",
    "@types/node": "^20.19.23",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "cross-env": "^10.1.0",
    "electron": "^39.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  },
  "keywords": [
    "blog",
    "automation",
    "ai",
    "crawling",
    "seo",
    "content-generation"
  ],
  "author": "Blog Automation Premium",
  "license": "MIT",
  "build": {
    "appId": "com.leadernam.orbit",
    "productName": "LEADERNAM Orbit",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "src/**/*.js",
      "src/**/*.json",
      "data/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/**/*.{md,ts,map}"
    ],
    "asarUnpack": [
      "**/node_modules/sharp/**/*",
      "**/node_modules/@img/sharp-*/**/*",
      "**/node_modules/sharp-win32-*/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "publisherName": "Leadernam"
    },
    "mac": {
      "target": [
        {
          "target": "default",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "${productName}",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "menuCategory": true
    },
    "compression": "maximum"
  }
}
